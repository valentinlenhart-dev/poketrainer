---
export interface Props {
  slot: string;
  format?: 'auto' | 'fluid' | 'rectangle';
  layout?: 'in-article' | '';
  label?: boolean;
}

const { slot, format = 'auto', layout = '', label = true } = Astro.props;
const PUBLISHER = 'ca-pub-6295830585093654';

// Si le slot est encore un placeholder, on n'affiche rien
const isPlaceholder = !slot || slot.startsWith('SLOT_') || slot.includes('XXXX');
---

{!isPlaceholder && (
  <div class="ad-slot">
    {label && <span class="ad-slot__label">Publicité</span>}
    <ins
      class="adsbygoogle"
      style={layout === 'in-article'
        ? 'display:block;text-align:center'
        : 'display:block'}
      data-ad-client={PUBLISHER}
      data-ad-slot={slot}
      data-ad-format={format}
      data-ad-layout={layout === 'in-article' ? 'in-article' : undefined}
      data-full-width-responsive="true"
    ></ins>
  </div>
)}
