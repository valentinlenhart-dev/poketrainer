---
export interface Props {
  crumbs: { label: string; href?: string; type?: string; pkmNames?: string; gameFr?: string }[];
}
const { crumbs } = Astro.props;

// Map French static labels → i18n keys (runtime translation via data-i18n-ui)
const CRUMB_KEYS: Record<string, string> = {
  'Accueil':      'crumb.home',
  'Top prénoms':  'crumb.top-names',
  'Légendaires':  'crumb.legendaries',
  'Prénoms':      'crumb.prenames',
  'Objets':       'crumb.items',
  'Pokémon':      'crumb.pokemon',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": crumbs.map((c, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": c.label,
    ...(c.href ? { "item": `https://ledresseurenmoi.com${c.href}` } : {}),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<nav class="breadcrumb" aria-label="Fil d'Ariane" data-i18n-ui="crumb.aria">
  {crumbs.map((c, i) => {
    const i18nKey = CRUMB_KEYS[c.label];
    return (
      <>
        {i > 0 && <span class="breadcrumb__sep" aria-hidden="true">›</span>}
        {c.href
          ? <a href={c.href} {...(i18nKey ? { 'data-i18n-ui': i18nKey } : {})}>{c.label}</a>
          : c.gameFr
          ? <span aria-current="page" data-game-fr={c.gameFr}>{c.label}</span>
          : c.type
          ? <span aria-current="page" data-i18n-type-crumb={c.type}>{c.label}</span>
          : c.pkmNames
          ? <span aria-current="page" data-pkm-names={c.pkmNames}>{c.label}</span>
          : <span aria-current="page" {...(i18nKey ? { 'data-i18n-ui': i18nKey } : {})}>{c.label}</span>
        }
      </>
    );
  })}
</nav>
