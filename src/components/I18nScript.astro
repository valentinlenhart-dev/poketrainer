---
/**
 * I18nScript.astro — Script i18n côté client réutilisable
 * Traduit automatiquement les éléments data-i18n-ui, data-i18n-rarity, data-type
 * selon la langue du navigateur.
 *
 * À importer dans toutes les pages statiques qui ont du contenu traduisible.
 */
import allTranslations from '../data/translations.json';
const T = allTranslations as Record<string, Record<string, string>>;
---

<script define:vars={{ T }}>
(function () {
  // ── Traductions des types par langue ─────────────────────────
  const TYPE_I18N = {
    fr: { fire:'Feu', water:'Eau', grass:'Plante', electric:'Électrik', ice:'Glace', fighting:'Combat', poison:'Poison', ground:'Sol', flying:'Vol', psychic:'Psy', bug:'Insecte', rock:'Roche', ghost:'Spectre', dragon:'Dragon', dark:'Ténèbres', steel:'Acier', fairy:'Fée', normal:'Normal' },
    en: { fire:'Fire', water:'Water', grass:'Grass', electric:'Electric', ice:'Ice', fighting:'Fighting', poison:'Poison', ground:'Ground', flying:'Flying', psychic:'Psychic', bug:'Bug', rock:'Rock', ghost:'Ghost', dragon:'Dragon', dark:'Dark', steel:'Steel', fairy:'Fairy', normal:'Normal' },
    de: { fire:'Feuer', water:'Wasser', grass:'Pflanze', electric:'Elektro', ice:'Eis', fighting:'Kampf', poison:'Gift', ground:'Boden', flying:'Flug', psychic:'Psycho', bug:'Käfer', rock:'Gestein', ghost:'Geist', dragon:'Drache', dark:'Unlicht', steel:'Stahl', fairy:'Fee', normal:'Normal' },
    es: { fire:'Fuego', water:'Agua', grass:'Planta', electric:'Eléctrico', ice:'Hielo', fighting:'Lucha', poison:'Veneno', ground:'Tierra', flying:'Volador', psychic:'Psíquico', bug:'Bicho', rock:'Roca', ghost:'Fantasma', dragon:'Dragón', dark:'Siniestro', steel:'Acero', fairy:'Hada', normal:'Normal' },
    ja: { fire:'ほのお', water:'みず', grass:'くさ', electric:'でんき', ice:'こおり', fighting:'かくとう', poison:'どく', ground:'じめん', flying:'ひこう', psychic:'エスパー', bug:'むし', rock:'いわ', ghost:'ゴースト', dragon:'ドラゴン', dark:'あく', steel:'はがね', fairy:'フェアリー', normal:'ノーマル' },
    it: { fire:'Fuoco', water:'Acqua', grass:'Erba', electric:'Elettro', ice:'Ghiaccio', fighting:'Lotta', poison:'Veleno', ground:'Terra', flying:'Volante', psychic:'Psico', bug:'Coleottero', rock:'Roccia', ghost:'Spettro', dragon:'Drago', dark:'Buio', steel:'Acciaio', fairy:'Folletto', normal:'Normale' },
    ko: { fire:'불꽃', water:'물', grass:'풀', electric:'전기', ice:'얼음', fighting:'격투', poison:'독', ground:'땅', flying:'비행', psychic:'에스퍼', bug:'벌레', rock:'바위', ghost:'고스트', dragon:'드래곤', dark:'악', steel:'강철', fairy:'페어리', normal:'노말' },
    'zh-Hans': { fire:'火', water:'水', grass:'草', electric:'电', ice:'冰', fighting:'格斗', poison:'毒', ground:'地面', flying:'飞行', psychic:'超能力', bug:'虫', rock:'岩石', ghost:'幽灵', dragon:'龙', dark:'恶', steel:'钢', fairy:'妖精', normal:'一般' },
    'zh-Hant': { fire:'火', water:'水', grass:'草', electric:'電', ice:'冰', fighting:'格鬥', poison:'毒', ground:'地面', flying:'飛行', psychic:'超能力', bug:'蟲', rock:'岩石', ghost:'幽靈', dragon:'龍', dark:'惡', steel:'鋼', fairy:'妖精', normal:'一般' },
    'pt-BR': { fire:'Fogo', water:'Água', grass:'Planta', electric:'Elétrico', ice:'Gelo', fighting:'Lutador', poison:'Venenoso', ground:'Terra', flying:'Voador', psychic:'Psíquico', bug:'Inseto', rock:'Pedra', ghost:'Fantasma', dragon:'Dragão', dark:'Sombrio', steel:'Aço', fairy:'Fada', normal:'Normal' },
  };

  // ── Détection de la langue ───────────────────────────────────
  const supported = ['fr','en','de','es','ja','it','ko','zh-Hans','zh-Hant','pt-BR'];
  function detectLang() {
    for (const l of navigator.languages ?? [navigator.language]) {
      if (l.startsWith('zh-Hant') || l === 'zh-TW' || l === 'zh-HK') return 'zh-Hant';
      if (l.startsWith('zh-Hans') || l === 'zh-CN' || l === 'zh-SG' || l === 'zh') return 'zh-Hans';
      if (l === 'pt-BR' || l === 'pt') return 'pt-BR';
      const s = l.split('-')[0].toLowerCase();
      if (supported.includes(s)) return s;
    }
    return 'fr';
  }

  // ── Traductions noms de jeux complets ────────────────────────
  const GAME_I18N = {
    en: {'Pokémon Colosseum':'Colosseum','Pokémon Cristal':'Crystal','Pokémon Diamant Perle':'Diamond & Pearl','Pokémon Diamant Étincelant et Perle Scintillante':'Brilliant Diamond & Shining Pearl','Pokémon HeartGold SoulSilver':'HeartGold & SoulSilver',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go, Pikachu & Eevee",'Pokémon Noir 2 et Blanc 2':'Black 2 & White 2','Pokémon Noir et Blanc':'Black & White','Pokémon Or et Argent':'Gold & Silver','Pokémon Platine':'Platinum','Pokémon Rouge Feu Vert Feuille':'FireRed & LeafGreen','Pokémon Rubis Oméga Saphir Alpha':'Omega Ruby & Alpha Sapphire','Pokémon Rubis Saphir':'Ruby & Sapphire','Pokémon Soleil et Lune':'Sun & Moon','Pokémon Ultra-Soleil et Ultra-Lune':'Ultra Sun & Ultra Moon','Pokémon X et Y':'X & Y','Pokémon XD : Le Souffle des Ténèbres':'XD: Gale of Darkness','Pokémon Écarlate et Violet':'Scarlet & Violet','Pokémon Émeraude':'Emerald','Pokémon Épée et Bouclier':'Sword & Shield'},
    de: {'Pokémon Colosseum':'Colosseum','Pokémon Cristal':'Kristall','Pokémon Diamant Perle':'Diamant & Perl','Pokémon Diamant Étincelant et Perle Scintillante':'Strahlender Diamant & Leuchtende Perle','Pokémon HeartGold SoulSilver':'HeartGold & SoulSilver',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go, Pikachu & Evoli",'Pokémon Noir 2 et Blanc 2':'Schwarz 2 & Weiß 2','Pokémon Noir et Blanc':'Schwarz & Weiß','Pokémon Or et Argent':'Gold & Silber','Pokémon Platine':'Platin','Pokémon Rouge Feu Vert Feuille':'Feuerrot & Blattgrün','Pokémon Rubis Oméga Saphir Alpha':'Omega Rubin & Alpha Saphir','Pokémon Rubis Saphir':'Rubin & Saphir','Pokémon Soleil et Lune':'Sonne & Mond','Pokémon Ultra-Soleil et Ultra-Lune':'Ultrasonne & Ultramond','Pokémon X et Y':'X & Y','Pokémon XD : Le Souffle des Ténèbres':'XD: Der Dunkle Sturm','Pokémon Écarlate et Violet':'Karmesin & Purpur','Pokémon Émeraude':'Smaragd','Pokémon Épée et Bouclier':'Schwert & Schild'},
    es: {'Pokémon Colosseum':'Colosseum','Pokémon Cristal':'Cristal','Pokémon Diamant Perle':'Diamante & Perla','Pokémon Diamant Étincelant et Perle Scintillante':'Diamante Brillante & Perla Reluciente','Pokémon HeartGold SoulSilver':'HeartGold & SoulSilver',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go, Pikachu & Eevee",'Pokémon Noir 2 et Blanc 2':'Negro 2 & Blanco 2','Pokémon Noir et Blanc':'Negro & Blanco','Pokémon Or et Argent':'Oro & Plata','Pokémon Platine':'Platino','Pokémon Rouge Feu Vert Feuille':'RojoFuego & VerdeHoja','Pokémon Rubis Oméga Saphir Alpha':'Rubí Omega & Zafiro Alfa','Pokémon Rubis Saphir':'Rubí & Zafiro','Pokémon Soleil et Lune':'Sol & Luna','Pokémon Ultra-Soleil et Ultra-Lune':'Ultrasol & Ultraluna','Pokémon X et Y':'X & Y','Pokémon XD : Le Souffle des Ténèbres':'XD: El Torbellino Oscuro','Pokémon Écarlate et Violet':'Escarlata & Púrpura','Pokémon Émeraude':'Esmeralda','Pokémon Épée et Bouclier':'Espada & Escudo'},
    ja: {'Pokémon Colosseum':'コロシアム','Pokémon Cristal':'クリスタル','Pokémon Diamant Perle':'ダイヤモンド&パール','Pokémon Diamant Étincelant et Perle Scintillante':'ブリリアントダイヤモンド&シャイニングパール','Pokémon HeartGold SoulSilver':'ハートゴールド&ソウルシルバー',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go! ピカチュウ&イーブイ",'Pokémon Noir 2 et Blanc 2':'ブラック2&ホワイト2','Pokémon Noir et Blanc':'ブラック&ホワイト','Pokémon Or et Argent':'金&銀','Pokémon Platine':'プラチナ','Pokémon Rouge Feu Vert Feuille':'ファイアレッド&リーフグリーン','Pokémon Rubis Oméga Saphir Alpha':'オメガルビー&アルファサファイア','Pokémon Rubis Saphir':'ルビー&サファイア','Pokémon Soleil et Lune':'サン&ムーン','Pokémon Ultra-Soleil et Ultra-Lune':'ウルトラサン&ウルトラムーン','Pokémon X et Y':'X&Y','Pokémon XD : Le Souffle des Ténèbres':'XD 闇の旋風','Pokémon Écarlate et Violet':'スカーレット&バイオレット','Pokémon Émeraude':'エメラルド','Pokémon Épée et Bouclier':'ソード&シールド'},
    it: {'Pokémon Colosseum':'Colosseum','Pokémon Cristal':'Cristallo','Pokémon Diamant Perle':'Diamante & Perla','Pokémon Diamant Étincelant et Perle Scintillante':'Diamante Lucente & Perla Splendente','Pokémon HeartGold SoulSilver':'HeartGold & SoulSilver',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go, Pikachu & Eevee",'Pokémon Noir 2 et Blanc 2':'Nero 2 & Bianco 2','Pokémon Noir et Blanc':'Nero & Bianco','Pokémon Or et Argent':'Oro & Argento','Pokémon Platine':'Platino','Pokémon Rouge Feu Vert Feuille':'Rosso Fuoco & Verde Foglia','Pokémon Rubis Oméga Saphir Alpha':'Rubino Omega & Zaffiro Alpha','Pokémon Rubis Saphir':'Rubino & Zaffiro','Pokémon Soleil et Lune':'Sole & Luna','Pokémon Ultra-Soleil et Ultra-Lune':'Ultrasole & Ultraluna','Pokémon X et Y':'X & Y','Pokémon XD : Le Souffle des Ténèbres':'XD: La Tempesta Oscura','Pokémon Écarlate et Violet':'Scarlatto & Violetto','Pokémon Émeraude':'Smeraldo','Pokémon Épée et Bouclier':'Spada & Scudo'},
    ko: {'Pokémon Colosseum':'콜로세움','Pokémon Cristal':'크리스탈','Pokémon Diamant Perle':'다이아몬드&펄','Pokémon Diamant Étincelant et Perle Scintillante':'브릴리언트 다이아몬드&샤이닝 펄','Pokémon HeartGold SoulSilver':'하트골드&소울실버',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go! 피카츄&이브이",'Pokémon Noir 2 et Blanc 2':'블랙 2&화이트 2','Pokémon Noir et Blanc':'블랙&화이트','Pokémon Or et Argent':'골드&실버','Pokémon Platine':'플래티넘','Pokémon Rouge Feu Vert Feuille':'파이어레드&리프그린','Pokémon Rubis Oméga Saphir Alpha':'오메가루비&알파사파이어','Pokémon Rubis Saphir':'루비&사파이어','Pokémon Soleil et Lune':'썬&문','Pokémon Ultra-Soleil et Ultra-Lune':'울트라썬&울트라문','Pokémon X et Y':'X&Y','Pokémon XD : Le Souffle des Ténèbres':'XD 어둠의 선풍','Pokémon Écarlate et Violet':'스칼렛&바이올렛','Pokémon Émeraude':'에메랄드','Pokémon Épée et Bouclier':'소드&실드'},
    'zh-Hans': {'Pokémon Colosseum':'战斗旋转剧场','Pokémon Cristal':'水晶','Pokémon Diamant Perle':'钻石&珍珠','Pokémon Diamant Étincelant et Perle Scintillante':'晶灿钻石&明亮珍珠','Pokémon HeartGold SoulSilver':'心金&魂银',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go! 皮卡丘&伊布",'Pokémon Noir 2 et Blanc 2':'黑2&白2','Pokémon Noir et Blanc':'黑&白','Pokémon Or et Argent':'金&银','Pokémon Platine':'白金','Pokémon Rouge Feu Vert Feuille':'火红&叶绿','Pokémon Rubis Oméga Saphir Alpha':'Ω红宝石&α蓝宝石','Pokémon Rubis Saphir':'红宝石&蓝宝石','Pokémon Soleil et Lune':'太阳&月亮','Pokémon Ultra-Soleil et Ultra-Lune':'究极之日&究极之月','Pokémon X et Y':'X&Y','Pokémon XD : Le Souffle des Ténèbres':'XD 暗之旋风','Pokémon Écarlate et Violet':'朱&紫','Pokémon Émeraude':'翡翠','Pokémon Épée et Bouclier':'剑&盾'},
    'zh-Hant': {'Pokémon Colosseum':'戰鬥旋轉劇場','Pokémon Cristal':'水晶','Pokémon Diamant Perle':'鑽石&珍珠','Pokémon Diamant Étincelant et Perle Scintillante':'晶燦鑽石&明亮珍珠','Pokémon HeartGold SoulSilver':'心金&魂銀',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go! 皮卡丘&伊布",'Pokémon Noir 2 et Blanc 2':'黑2&白2','Pokémon Noir et Blanc':'黑&白','Pokémon Or et Argent':'金&銀','Pokémon Platine':'白金','Pokémon Rouge Feu Vert Feuille':'火紅&葉綠','Pokémon Rubis Oméga Saphir Alpha':'Ω紅寶石&α藍寶石','Pokémon Rubis Saphir':'紅寶石&藍寶石','Pokémon Soleil et Lune':'太陽&月亮','Pokémon Ultra-Soleil et Ultra-Lune':'究極之日&究極之月','Pokémon X et Y':'X&Y','Pokémon XD : Le Souffle des Ténèbres':'XD 暗之旋風','Pokémon Écarlate et Violet':'朱&紫','Pokémon Émeraude':'翡翠','Pokémon Épée et Bouclier':'劍&盾'},
    'pt-BR': {'Pokémon Colosseum':'Colosseum','Pokémon Cristal':'Crystal','Pokémon Diamant Perle':'Diamante & Pérola','Pokémon Diamant Étincelant et Perle Scintillante':'Diamante Brilhante & Pérola Cintilante','Pokémon HeartGold SoulSilver':'HeartGold & SoulSilver',"Pokémon Let's Go, Pikachu et Évoli":"Let's Go, Pikachu & Eevee",'Pokémon Noir 2 et Blanc 2':'Preto 2 & Branco 2','Pokémon Noir et Blanc':'Preto & Branco','Pokémon Or et Argent':'Ouro & Prata','Pokémon Platine':'Platina','Pokémon Rouge Feu Vert Feuille':'Vermelho Fogo & Verde Folha','Pokémon Rubis Oméga Saphir Alpha':'Rubi Ômega & Safira Alfa','Pokémon Rubis Saphir':'Rubi & Safira','Pokémon Soleil et Lune':'Sol & Lua','Pokémon Ultra-Soleil et Ultra-Lune':'UltraSol & UltraLua','Pokémon X et Y':'X & Y','Pokémon XD : Le Souffle des Ténèbres':'XD: Gale of Darkness','Pokémon Écarlate et Violet':'Escarlate & Violeta','Pokémon Émeraude':'Esmeralda','Pokémon Épée et Bouclier':'Espada & Escudo'},
  };

  // ── Application des traductions ──────────────────────────────
  function applyI18n(lang) {
    const t = T[lang] ?? T['fr'];

    // Labels UI (data-i18n-ui)
    document.querySelectorAll('[data-i18n-ui]').forEach(el => {
      const key = el.dataset.i18nUi;
      if (!t[key]) return;
      // nav.aria → attribut seulement, ne pas écraser le contenu du nav
      if (key === 'nav.aria') { el.setAttribute('aria-label', t[key]); return; }
      // nav.random-title → title + aria-label seulement, ne pas écraser l'icône 🎲
      if (key === 'nav.random-title') { el.setAttribute('title', t[key]); el.setAttribute('aria-label', t[key]); return; }
      let text = t[key];
      if (el.dataset.count !== undefined) text = text.replace('{n}', el.dataset.count);
      if (el.dataset.trainerName !== undefined) text = text.replace('{name}', el.dataset.trainerName);
      if (el.dataset.trainerGame !== undefined) text = text.replace('{game}', el.dataset.trainerGame);
      el.textContent = text;
    });

    // Rareté (data-i18n-rarity) — préserve l'<img> si présente
    document.querySelectorAll('[data-i18n-rarity]').forEach(el => {
      const key = el.dataset.i18nRarity;
      const translated = t['rarity.' + key];
      if (!translated) return;
      const img = el.querySelector('img');
      el.textContent = translated;
      if (img) el.prepend(img);
    });

    // Types (data-type) — cible .type-name si présent
    document.querySelectorAll('[data-type]').forEach(el => {
      const type = el.dataset.type;
      const nameEl = el.querySelector('.type-name') ?? el;
      const translated = (TYPE_I18N[lang] ?? TYPE_I18N['fr'])[type];
      if (translated) nameEl.textContent = translated;
    });

    // Noms de jeux complets (data-game-fr) — trainer cards
    document.querySelectorAll('[data-game-fr]').forEach(el => {
      const gameFr = el.dataset.gameFr;
      const translated = GAME_I18N[lang]?.[gameFr];
      if (translated) {
        const img = el.querySelector('img');
        el.textContent = translated;
        if (img) el.prepend(img);
      }
    });
  }

  const lang = detectLang();
  if (lang !== 'fr') applyI18n(lang);
})();
</script>
