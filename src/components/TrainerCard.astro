---
import { toPokemonSlug } from '../utils/slug';
import pokemonMeta from '../data/pokemon-meta.json';

export interface Props {
  trainer: {
    slug: string;
    name: string;
    class: string;
    game: string;
    place?: string;
    team?: string[];
    rarity_emoji: string;
    rarity_label: string;
    rarity_key: string;
  };
  headingLevel?: 'h2' | 'h3';
}

const { trainer: t, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
const meta = pokemonMeta as Record<string, { sprite?: string; id?: number }>;
---

<article class="trainer-card">
  <a href={`/dresseur/${t.slug}`} aria-label={`${t.class} ${t.name} — ${t.game}`}>
    <p class="trainer-card__class">{t.class}</p>
    <Heading class="trainer-card__name">{t.name}</Heading>
    <div class="trainer-card__meta">
      <span>🎮 {t.game.replace('Pokémon ', '')}</span>
      {t.place && <span>📍 {t.place.replace(/-/g, ' ')}</span>}
      <span class={`rarity rarity--${t.rarity_key}`} style="font-size:0.72rem;padding:3px 10px">
        {t.rarity_emoji} {t.rarity_label}
      </span>
    </div>
    {t.team && t.team.length > 0 && (
      <div class="trainer-card__team" aria-label="Équipe Pokémon">
        {t.team.map(p => {
          const sprite = meta[p]?.sprite ?? null;
          return (
            <a
              href={`/pokemon/${toPokemonSlug(p)}`}
              class="pkm-badge"
              aria-label={`Voir ${p}`}
            >
              {sprite
                ? <img src={sprite} alt={p} width="24" height="24" class="pkm-badge__sprite" loading="lazy" />
                : <span class="pkm-badge__dot" aria-hidden="true">●</span>
              }
              {p}
            </a>
          );
        })}
      </div>
    )}
  </a>
</article>

<style>
.pkm-badge {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.pkm-badge__sprite {
  width: 24px;
  height: 24px;
  image-rendering: pixelated;
  flex-shrink: 0;
}
.pkm-badge__dot {
  font-size: 0.5rem;
  color: var(--soft, #aaa);
  flex-shrink: 0;
}
</style>
