---
import placeNamesRaw from '../data/place-names-i18n.json';
const placeNamesData = placeNamesRaw as Record<string, Record<string, string>>;

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/img/pages/og-default.png',
  schema,
  noindex = false,
} = Astro.props;

const SITE = 'https://ledresseurenmoi.com';
const fullOg = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;
const schemaJson = schema
  ? JSON.stringify(Array.isArray(schema) ? schema : [schema])
  : null;

// ⚠️ Remplacer par ton vrai ca-pub-XXXXXXXXXX depuis Google AdSense
const ADSENSE_ID = 'ca-pub-6295830585093654';
---

<!DOCTYPE html>
<html lang="fr" data-ads-pub={ADSENSE_ID}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  {!noindex && <meta name="robots" content="index,follow,max-image-preview:large" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="fr_FR" />
  <meta property="og:site_name"   content="Le Dresseur en Moi" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={fullOg} />
  <meta property="og:url"         content={canonical} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={fullOg} />

  <!-- Schema.org -->
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}

  <!-- AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6295830585093654" crossorigin="anonymous"></script>

  <!-- Preconnect domaines externes -->
  <link rel="preconnect" href="https://play.pokemonshowdown.com" />
  <link rel="preconnect" href="https://raw.githubusercontent.com" />
  <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

  <!-- Favicon -->
  <link rel="icon" href="/img/pages/favicon.ico" />
  <link rel="apple-touch-icon" href="/img/pages/apple-touch-icon.png" />

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap');
  </style>

</head>
<body>

  <nav class="nav" aria-label="Navigation principale" data-i18n-ui="nav.aria" id="main-nav">
    <div class="nav__inner">
      <a href="/" class="nav__logo" aria-label="Le Dresseur en Moi — Accueil">
        <div class="nav__logo-ball" aria-hidden="true"></div>
        Le Dresseur en Moi
      </a>
      <ul class="nav__links" id="nav-links" role="list">
        <li><a href="/" data-i18n-ui="nav.search">Recherche</a></li>
        <li><a href="/top/legendaires" data-i18n-ui="nav.legendaries">Légendaires</a></li>
        <li><a href="/top/repandus" data-i18n-ui="nav.top-names">Top prénoms</a></li>
        <li><a href="/type/water" data-i18n-ui="nav.types">Types</a></li>
      </ul>
      <!-- Sélecteur de langue -->
      <div class="lang-picker" id="lang-picker">
        <button class="lang-btn" id="lang-btn" aria-haspopup="listbox" aria-expanded="false" title="Changer la langue">
          <span id="lang-current">FR</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <ul class="lang-dropdown" id="lang-dropdown" role="listbox" aria-label="Langue">
          <li role="option" data-lang="fr">🇫🇷 FR</li>
          <li role="option" data-lang="en">🇬🇧 EN</li>
          <li role="option" data-lang="de">🇩🇪 DE</li>
          <li role="option" data-lang="es">🇪🇸 ES</li>
          <li role="option" data-lang="it">🇮🇹 IT</li>
          <li role="option" data-lang="pt-BR">🇧🇷 PT</li>
          <li role="option" data-lang="ja">🇯🇵 JA</li>
          <li role="option" data-lang="ko">🇰🇷 KO</li>
          <li role="option" data-lang="zh-Hans">🇨🇳 ZH</li>
          <li role="option" data-lang="zh-Hant">🇹🇼 ZH</li>
        </ul>
      </div>

      <a href="/dresseur-aleatoire" class="random-btn" title="Dresseur aléatoire" aria-label="Dresseur aléatoire" data-i18n-ui="nav.random-title"><img src="/assets/icons/dice.svg" alt="" width="18" height="18" /></a>
      <button class="nav__burger" id="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav-links">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
  <script is:inline>
    (function() {
      var burger = document.getElementById('nav-burger');
      var links  = document.getElementById('nav-links');
      if (!burger || !links) return;
      burger.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = links.classList.toggle('nav__links--open');
        burger.setAttribute('aria-expanded', String(open));
        burger.classList.toggle('nav__burger--open', open);
      });
      links.addEventListener('click', function(e) {
        if (e.target && e.target.tagName === 'A') {
          links.classList.remove('nav__links--open');
          burger.setAttribute('aria-expanded', 'false');
          burger.classList.remove('nav__burger--open');
        }
      });
      document.addEventListener('click', function(e) {
        if (!burger.contains(e.target) && !links.contains(e.target)) {
          links.classList.remove('nav__links--open');
          burger.setAttribute('aria-expanded', 'false');
          burger.classList.remove('nav__burger--open');
        }
      });
    })();
  </script>

  <!-- ── i18n global ──────────────────────────────────────────── -->
  <script define:vars={{ __placeNames: placeNamesData }}>
    window.__place_names_i18n = __placeNames;
  </script>
  <script>
    import translationsRaw from '../data/translations.json';
    import trainerClassesRaw from '../data/trainer-classes-i18n.json';
    const T  = translationsRaw  as Record<string, Record<string, string> | Record<string, Record<string,string>>>;
    const TC = trainerClassesRaw as Record<string, Record<string, string>>;
    const PLACE_NAMES = (window as any).__place_names_i18n as Record<string, Record<string, string>> ?? {};

    const SUPPORTED = ['fr','en','de','es','ja','it','ko','zh-Hans','zh-Hant','pt-BR'] as const;
    type Lang = typeof SUPPORTED[number];
    const LANG_LABELS: Record<string, string> = {
      fr:'FR', en:'EN', de:'DE', es:'ES', ja:'JA',
      it:'IT', ko:'KO', 'zh-Hans':'ZH', 'zh-Hant':'ZH', 'pt-BR':'PT',
    };

    function detectLang(): Lang {
      const saved = localStorage.getItem('ldresseurenmoi_lang') as Lang | null;
      if (saved && (SUPPORTED as readonly string[]).includes(saved)) return saved;
      for (const l of (navigator.languages ?? [navigator.language])) {
        // Chinois traditionnel
        if (l.startsWith('zh-Hant') || l === 'zh-TW' || l === 'zh-HK' || l === 'zh-MO') return 'zh-Hant';
        // Chinois simplifié
        if (l.startsWith('zh-Hans') || l === 'zh-CN' || l === 'zh-SG' || l === 'zh') return 'zh-Hans';
        // Portugais brésilien
        if (l === 'pt-BR' || l === 'pt') return 'pt-BR';
        const short = l.split('-')[0].toLowerCase() as Lang;
        if ((SUPPORTED as readonly string[]).includes(short)) return short;
      }
      return 'fr';
    }

    function applyLang(lang: Lang) {
      (window as any).__ldresseurenmoi_lang = lang;
      (window as any).__pokenom_T    = T;

      // Label du picker
      const cur = document.getElementById('lang-current');
      if (cur) cur.textContent = LANG_LABELS[lang] ?? lang.toUpperCase();

      // Marquer l'option active
      document.querySelectorAll<HTMLElement>('#lang-dropdown [data-lang]').forEach(el => {
        el.setAttribute('aria-selected', el.dataset.lang === lang ? 'true' : 'false');
        el.classList.toggle('lang-option--active', el.dataset.lang === lang);
      });

      document.documentElement.lang = lang;

      // ── Titre de l'onglet ─────────────────────────────────────
      const ui_for_title = lang === 'fr' ? (T['fr'] as Record<string,string> ?? {}) : (T[lang] as Record<string,string> ?? {});
      const titleEl = document.getElementById('page-title-i18n') as HTMLElement | null;
      if (titleEl) {
        const nameElId  = titleEl.dataset.nameEl;
        const nameFr    = titleEl.dataset.nameFr ?? '';
        const name      = nameElId ? (document.getElementById(nameElId)?.textContent?.trim() ?? nameFr) : nameFr;
        const suffixKey = titleEl.dataset.suffixKey;
        const suffix    = suffixKey ? (ui_for_title[suffixKey] ?? '') : '';
        const count     = titleEl.dataset.count ?? '';
        const countSuffixKey = titleEl.dataset.countSuffix;
        const countSuffix = countSuffixKey ? (ui_for_title[countSuffixKey] ?? '') : '';
        if (suffix) {
          const countPart = count ? ` (${count} ${countSuffix})`.trim() : '';
          document.title = `${name}${countPart} — ${suffix} | Le Dresseur en Moi`;
        }
      } else {
        const staticKey = (document.getElementById('page-title-i18n-static') as HTMLElement | null)?.dataset.key;
        if (staticKey && ui_for_title[staticKey]) document.title = ui_for_title[staticKey];
      }

      if (lang === 'fr') return; // FR est la langue native

      const ui = T[lang] as Record<string, string> | undefined ?? {};

      // Labels UI nav/footer
      document.querySelectorAll<HTMLElement>('[data-i18n-ui]').forEach(el => {
        const key = el.dataset.i18nUi!;
        if (ui[key]) {
          if (el.tagName === 'NAV' && (key === 'nav.aria' || key === 'crumb.aria')) {
            // aria-label uniquement, ne pas toucher le contenu
            el.setAttribute('aria-label', ui[key]);
          } else if (key === 'nav.random-title') {
            // title + aria-label uniquement, ne pas écraser l'icône 🎲
            el.setAttribute('title', ui[key]);
            el.setAttribute('aria-label', ui[key]);
          } else {
            let text = ui[key];
            if (el.dataset.count !== undefined) text = text.replace('{n}', el.dataset.count);
            if (el.dataset.gameCount !== undefined) text = text.replace('{g}', el.dataset.gameCount);
            if (el.dataset.trainerName !== undefined) text = text.replace('{name}', el.dataset.trainerName);
            if (el.dataset.trainerGame !== undefined) text = text.replace('{game}', el.dataset.trainerGame);
            el.textContent = text;
          }
        }
      });

      // Noms de jeux
      const games = T['games'] as Record<string, Record<string, string>>;
      document.querySelectorAll<HTMLElement>('[data-game-fr]').forEach(el => {
        const fr = el.dataset.gameFr!;
        const translated = games[fr]?.[lang];
        if (translated) {
          const name = translated.replace('Pokémon ', '');
          const img = el.querySelector('img');
          if (el.dataset.count !== undefined) {
            el.textContent = `${name} (${el.dataset.count})`;
          } else {
            el.textContent = name;
            if (img) el.prepend(img);
          }
        }
      });

      // Types Pokémon (data-type) — traduit le nom du type
      const TYPE_I18N: Record<string, Record<string, string>> = {
        fr: { fire:'Feu', water:'Eau', grass:'Plante', electric:'Électrik', ice:'Glace', fighting:'Combat', poison:'Poison', ground:'Sol', flying:'Vol', psychic:'Psy', bug:'Insecte', rock:'Roche', ghost:'Spectre', dragon:'Dragon', dark:'Ténèbres', steel:'Acier', fairy:'Fée', normal:'Normal' },
        en: { fire:'Fire', water:'Water', grass:'Grass', electric:'Electric', ice:'Ice', fighting:'Fighting', poison:'Poison', ground:'Ground', flying:'Flying', psychic:'Psychic', bug:'Bug', rock:'Rock', ghost:'Ghost', dragon:'Dragon', dark:'Dark', steel:'Steel', fairy:'Fairy', normal:'Normal' },
        de: { fire:'Feuer', water:'Wasser', grass:'Pflanze', electric:'Elektro', ice:'Eis', fighting:'Kampf', poison:'Gift', ground:'Boden', flying:'Flug', psychic:'Psycho', bug:'Käfer', rock:'Gestein', ghost:'Geist', dragon:'Drache', dark:'Unlicht', steel:'Stahl', fairy:'Fee', normal:'Normal' },
        es: { fire:'Fuego', water:'Agua', grass:'Planta', electric:'Eléctrico', ice:'Hielo', fighting:'Lucha', poison:'Veneno', ground:'Tierra', flying:'Volador', psychic:'Psíquico', bug:'Bicho', rock:'Roca', ghost:'Fantasma', dragon:'Dragón', dark:'Siniestro', steel:'Acero', fairy:'Hada', normal:'Normal' },
        ja: { fire:'ほのお', water:'みず', grass:'くさ', electric:'でんき', ice:'こおり', fighting:'かくとう', poison:'どく', ground:'じめん', flying:'ひこう', psychic:'エスパー', bug:'むし', rock:'いわ', ghost:'ゴースト', dragon:'ドラゴン', dark:'あく', steel:'はがね', fairy:'フェアリー', normal:'ノーマル' },
        it: { fire:'Fuoco', water:'Acqua', grass:'Erba', electric:'Elettro', ice:'Ghiaccio', fighting:'Lotta', poison:'Veleno', ground:'Terra', flying:'Volante', psychic:'Psico', bug:'Coleottero', rock:'Roccia', ghost:'Spettro', dragon:'Drago', dark:'Buio', steel:'Acciaio', fairy:'Folletto', normal:'Normale' },
        ko: { fire:'불꽃', water:'물', grass:'풀', electric:'전기', ice:'얼음', fighting:'격투', poison:'독', ground:'땅', flying:'비행', psychic:'에스퍼', bug:'벌레', rock:'바위', ghost:'고스트', dragon:'드래곤', dark:'악', steel:'강철', fairy:'페어리', normal:'노말' },
        'zh-Hans': { fire:'火', water:'水', grass:'草', electric:'电', ice:'冰', fighting:'格斗', poison:'毒', ground:'地面', flying:'飞行', psychic:'超能力', bug:'虫', rock:'岩石', ghost:'幽灵', dragon:'龙', dark:'恶', steel:'钢', fairy:'妖精', normal:'一般' },
        'zh-Hant': { fire:'火', water:'水', grass:'草', electric:'電', ice:'冰', fighting:'格鬥', poison:'毒', ground:'地面', flying:'飛行', psychic:'超能力', bug:'蟲', rock:'岩石', ghost:'幽靈', dragon:'龍', dark:'惡', steel:'鋼', fairy:'妖精', normal:'一般' },
        'pt-BR': { fire:'Fogo', water:'Água', grass:'Planta', electric:'Elétrico', ice:'Gelo', fighting:'Lutador', poison:'Venenoso', ground:'Terra', flying:'Voador', psychic:'Psíquico', bug:'Inseto', rock:'Pedra', ghost:'Fantasma', dragon:'Dragão', dark:'Sombrio', steel:'Aço', fairy:'Fada', normal:'Normal' },
      };
      document.querySelectorAll<HTMLElement>('[data-type]').forEach(el => {
        const type = el.dataset.type!;
        const nameEl = el.classList.contains('type-name') ? el : (el.querySelector<HTMLElement>('.type-name') ?? el);
        const translated = (TYPE_I18N[lang] ?? TYPE_I18N['fr'])[type];
        if (translated) nameEl.textContent = translated;
      });

      // Génération Pokémon (data-generation) — ex: "I" → "Generation I"
      document.querySelectorAll<HTMLElement>('[data-generation]').forEach(el => {
        const roman = el.dataset.generation!; // ex: "I", "II", ...
        const prefix = ui['gen-label'];
        if (!prefix) return;
        // Langues qui mettent le préfixe avant (la plupart)
        // JA/ZH utilisent 第X世代, KO utilises X세대
        if (lang === 'ja' || lang === 'zh-Hans' || lang === 'zh-Hant') {
          // Convertit le chiffre romain en arabe
          const romanMap: Record<string,number> = {I:1,II:2,III:3,IV:4,V:5,VI:6,VII:7,VIII:8,IX:9};
          const num = romanMap[roman] ?? roman;
          el.textContent = `${prefix}${num}世代`;
        } else if (lang === 'ko') {
          const romanMap: Record<string,number> = {I:1,II:2,III:3,IV:4,V:5,VI:6,VII:7,VIII:8,IX:9};
          const num = romanMap[roman] ?? roman;
          el.textContent = `${num}${prefix}`;
        } else {
          el.textContent = `${prefix} ${roman}`;
        }
      });

      // Labels de rareté
      document.querySelectorAll<HTMLElement>('[data-i18n-rarity]').forEach(el => {
        const key = `rarity.${el.dataset.i18nRarity}`;
        const label = ui[key];
        if (label) {
          const text = el.textContent ?? '';
          const emojiMatch = text.match(/^(\S+\s)/);
          el.textContent = emojiMatch ? `${emojiMatch[1]}${label}` : label;
        }
      });

      // Difficulté taux de capture
      document.querySelectorAll<HTMLElement>('[data-i18n-difficulty]').forEach(el => {
        const key = `difficulty.${el.dataset.i18nDifficulty}`;
        const label = ui[key];
        if (label) el.textContent = ` · ${label}`;
      });

      // ── Meta description traduite ────────────────────────────
      const descI18n = (window as any).__page_desc_i18n as Record<string, string> | undefined;
      if (descI18n?.[lang]) {
        const metaDesc = document.querySelector<HTMLMetaElement>('meta[name="description"]');
        if (metaDesc) metaDesc.setAttribute('content', descI18n[lang]);
        // og:description
        const ogDesc = document.querySelector<HTMLMetaElement>('meta[property="og:description"]');
        if (ogDesc) ogDesc.setAttribute('content', descI18n[lang]);
        // twitter:description
        const twDesc = document.querySelector<HTMLMetaElement>('meta[name="twitter:description"]');
        if (twDesc) twDesc.setAttribute('content', descI18n[lang]);
      }

      // ── Lore textes visibles de la fiche dresseur ─────────────
      const loreI18n = (window as any).__page_lore_i18n as Record<string, { aboutTitle: string; lorePara: string; rarityText: string }> | undefined;
      if (loreI18n?.[lang]) {
        const { aboutTitle, lorePara, rarityText } = loreI18n[lang];
        const h2El = document.getElementById('trainer-about-h2');
        if (h2El && aboutTitle) h2El.textContent = aboutTitle;
        // innerHTML pour préserver <strong> et <a> dans lorePara / rarityText
        const loreEl = document.getElementById('trainer-lore-p');
        if (loreEl && lorePara) {
          loreEl.innerHTML = lorePara;
          // Le lien jeu a data-game-fr → le retranscrire maintenant (applyLang a déjà tourné)
          const gamesMap = T['games'] as Record<string, Record<string, string>>;
          loreEl.querySelectorAll<HTMLElement>('[data-game-fr]').forEach(el => {
            const fr = el.dataset.gameFr!;
            const translated = gamesMap[fr]?.[lang];
            if (translated) el.textContent = translated.replace('Pokémon ', '');
          });
        }
        const rarityEl = document.getElementById('trainer-rarity-p');
        if (rarityEl && rarityText) rarityEl.innerHTML = rarityText;
      }

      // ── Classes de dresseurs ──────────────────────────────────
      document.querySelectorAll<HTMLElement>('[data-trainer-class]').forEach(el => {
        const frClass = el.dataset.trainerClass!;
        const translated = TC[frClass]?.[lang];
        if (translated) el.textContent = translated;
      });

      // ── Prenom page dynamic content ──────────────────────────
      const prenomI18n = (window as any).__prenom_i18n as Record<string, { rarityDesc: string; faqExistsA: string; faqTeamA: string | null }> | undefined;
      if (prenomI18n?.[lang]) {
        const { rarityDesc, faqExistsA, faqTeamA } = prenomI18n[lang];
        const rdEl = document.getElementById('prenom-rarity-desc');
        if (rdEl && rarityDesc) rdEl.textContent = rarityDesc;
        const feEl = document.getElementById('prenom-faq-exists-a');
        if (feEl && faqExistsA) feEl.textContent = faqExistsA;
        const frEl = document.getElementById('prenom-faq-rare-a');
        if (frEl && rarityDesc) frEl.textContent = rarityDesc;
        const ftEl = document.getElementById('prenom-faq-team-a');
        if (ftEl && faqTeamA) ftEl.textContent = faqTeamA;
      }

      // ── Noms Pokémon (badges d'équipe) ────────────────────────
      // data-pkm-names = "en:Meowth|de:Mauzi|ja:ニャース|..."
      document.querySelectorAll<HTMLElement>('[data-pkm-names]').forEach(el => {
        const raw = el.dataset.pkmNames!;
        // Parse the compact pipe-separated format
        const map: Record<string, string> = {};
        raw.split('|').forEach(pair => {
          const idx = pair.indexOf(':');
          if (idx > 0) map[pair.slice(0, idx)] = pair.slice(idx + 1);
        });
        const translated = map[lang] ?? map['en'];
        if (translated) {
          const nameSpan = el.querySelector<HTMLElement>('.pkm-badge__name');
          if (nameSpan) nameSpan.textContent = translated;
          else {
            // fallback: set text of last text node
            const img = el.querySelector('img');
            const dot = el.querySelector('.pkm-badge__dot');
            if (img || dot) {
              // replace text node after img/dot
              for (const node of Array.from(el.childNodes)) {
                if (node.nodeType === Node.TEXT_NODE) { node.textContent = translated; break; }
              }
            } else {
              el.textContent = translated;
            }
          }
        }
      });

      // ── Évolutions (data-evo-name-fr) — préserve la flèche ──────
      document.querySelectorAll<HTMLElement>('[data-evo-name-fr]').forEach(el => {
        const raw = el.dataset.pkmNames;
        if (!raw) return;
        const map: Record<string, string> = {};
        raw.split('|').forEach(pair => { const idx = pair.indexOf(':'); if (idx > 0) map[pair.slice(0, idx)] = pair.slice(idx + 1); });
        const translated = map[lang] ?? map['en'];
        if (!translated) return;
        const isFrom = el.classList.contains('evo-chip--from');
        el.textContent = isFrom ? `← ${translated}` : `${translated} →`;
      });

      // ── Noms de lieux (data-place-slug) ──────────────────────────
      document.querySelectorAll<HTMLElement>('[data-place-slug]').forEach(el => {
        const slug = el.dataset.placeSlug!;
        const translated = PLACE_NAMES[slug]?.[lang];
        if (translated) el.textContent = translated;
      });

      // ── Habitat Pokémon (data-i18n-habitat) ──────────────────────
      const HABITAT_I18N: Record<string, Record<string, string>> = {
        "Bord de l'eau": { en:"Waterfront", de:"Gewässer",   es:"Costa",               ja:"水辺",   it:"Riva dell'acqua", ko:"수변",   'zh-Hans':"水边",   'zh-Hant':"水邊",   'pt-BR':"Beira d'água" },
        'Forêt':         { en:"Forest",     de:"Wald",       es:"Bosque",              ja:"森林",   it:"Foresta",         ko:"숲",     'zh-Hans':"森林",   'zh-Hant':"森林",   'pt-BR':"Floresta" },
        'Grotte':        { en:"Cave",       de:"Höhle",      es:"Cueva",               ja:"洞穴",   it:"Grotta",          ko:"동굴",   'zh-Hans':"洞穴",   'zh-Hant':"洞穴",   'pt-BR':"Caverna" },
        'Mer':           { en:"Sea",        de:"Meer",       es:"Mar",                 ja:"海",    it:"Mare",            ko:"바다",   'zh-Hans':"大海",   'zh-Hant':"大海",   'pt-BR':"Mar" },
        'Montagne':      { en:"Mountain",   de:"Berg",       es:"Montaña",             ja:"山岳",   it:"Montagna",        ko:"산",     'zh-Hans':"山地",   'zh-Hant':"山地",   'pt-BR':"Montanha" },
        'Prairie':       { en:"Grassland",  de:"Grasland",   es:"Pradera",             ja:"草原",   it:"Prato",           ko:"초원",   'zh-Hans':"草原",   'zh-Hant':"草原",   'pt-BR':"Pastagem" },
        'Terrain accidenté': { en:"Rough terrain", de:"Unwegsamkeit", es:"Terreno escarpado", ja:"荒地", it:"Terreno accidentato", ko:"험한 지형", 'zh-Hans':"崎岖地", 'zh-Hant':"崎嶇地", 'pt-BR':"Terreno acidentado" },
        'Urbain':        { en:"Urban",      de:"Urban",      es:"Urbano",              ja:"都市",   it:"Urbano",          ko:"도시",   'zh-Hans':"都市",   'zh-Hant':"都市",   'pt-BR':"Urbano" },
      };
      document.querySelectorAll<HTMLElement>('[data-i18n-habitat]').forEach(el => {
        const frHabitat = el.dataset.i18nHabitat!;
        const translated = HABITAT_I18N[frHabitat]?.[lang];
        if (translated) el.textContent = translated;
      });

      // ── Pas d'éclosion (data-hatch-steps) ────────────────────────
      const hatchUnit = (T[lang] ?? T['fr'])?.['hatch-steps.unit'] ?? 'pas';
      document.querySelectorAll<HTMLElement>('[data-hatch-steps]').forEach(el => {
        const steps = parseInt(el.dataset.hatchSteps!, 10);
        el.textContent = `~${steps.toLocaleString()} ${hatchUnit}`;
      });

      // ── Breadcrumb type (data-i18n-type-crumb) ───────────────────
      const TYPE_LABEL_PREFIX: Record<string, string> = {
        en:'Type', de:'Typ', es:'Tipo', ja:'タイプ', it:'Tipo',
        ko:'타입', 'zh-Hans':'属性', 'zh-Hant':'屬性', 'pt-BR':'Tipo',
      };
      document.querySelectorAll<HTMLElement>('[data-i18n-type-crumb]').forEach(el => {
        const type = el.dataset.i18nTypeCrumb!;
        const typeName = (TYPE_I18N[lang] ?? TYPE_I18N['fr'])[type] ?? type;
        const prefix = TYPE_LABEL_PREFIX[lang] ?? 'Type';
        el.textContent = `${prefix} ${typeName}`;
      });

      // ── Generic innerHTML i18n (window.__page_html_i18n) ──────
      // Format: { elementId: { lang: htmlString } }
      const htmlI18n = (window as any).__page_html_i18n as Record<string, Record<string, string>> | undefined;
      if (htmlI18n) {
        for (const [id, translations] of Object.entries(htmlI18n)) {
          const el = document.getElementById(id);
          if (el && translations[lang]) {
            el.innerHTML = translations[lang];
          }
        }
      }
    }

    // Init
    const lang = detectLang();
    applyLang(lang);

    // ── Picker logic ──────────────────────────────────────────────
    const pickerEl  = document.getElementById('lang-picker')!;
    const btnEl     = document.getElementById('lang-btn')!;
    const dropEl    = document.getElementById('lang-dropdown')!;

    function toggleDropdown(open: boolean) {
      dropEl.classList.toggle('lang-dropdown--open', open);
      btnEl.setAttribute('aria-expanded', String(open));
    }

    btnEl.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleDropdown(dropEl.classList.contains('lang-dropdown--open') ? false : true);
    });

    dropEl.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest<HTMLElement>('[data-lang]');
      if (!target) return;
      const chosen = target.dataset.lang as Lang;
      localStorage.setItem('ldresseurenmoi_lang', chosen);
      toggleDropdown(false);
      // Recharge la page pour ré-appliquer toutes les traductions (y compris React islands)
      location.reload();
    });

    document.addEventListener('click', () => toggleDropdown(false));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') toggleDropdown(false); });
  </script>

  <slot />

  <!-- ── Bannière sticky bas de page ───────────────────────── -->
  <div id="sticky-ad-clip" class="sticky-ad-clip">
  <div id="sticky-ad-bar" class="sticky-ad" aria-label="Publicité" role="complementary">
    <button id="sticky-ad-close" class="sticky-ad__close" aria-label="Fermer la publicité"><img src="/assets/icons/close.svg" alt="" width="12" height="12" /></button>
    <ins
      class="adsbygoogle"
      style="display:block;width:100%;max-height:50px;"
      data-ad-client={ADSENSE_ID}
      data-ad-slot="6643773892"
      data-ad-format="auto"
      data-full-width-responsive="true"
    ></ins>
  </div>
  </div>
  <script is:inline>
    (function() {
      var bar = document.getElementById('sticky-ad-bar');
      var clip = document.getElementById('sticky-ad-clip');
      var closeBtn = document.getElementById('sticky-ad-close');
      if (!bar) return;
      // Push l'unité AdSense
      try {
        (window.adsbygoogle = window.adsbygoogle || []).push({});
      } catch(e) {}
      var hide = function() { (clip || bar).classList.add('sticky-ad--hidden'); };
      // Fermer après 6s
      var t = setTimeout(hide, 6000);
      // Fermer sur clic ×
      closeBtn && closeBtn.addEventListener('click', function() { clearTimeout(t); hide(); });
    })();
  </script>

  <footer class="footer" aria-label="Pied de page">
    <div class="footer__inner">
      <div>
        <div class="footer__brand">Le Dresseur en Moi</div>
        <p><span data-i18n-ui="footer.tagline">Trouve ton dresseur Pokémon.</span><br /><span data-i18n-ui="footer.stats">4 728 dresseurs · 17 jeux officiels.</span></p>
      </div>
      <div>
        <strong style="display:block;margin-bottom:8px;color:var(--text)" data-i18n-ui="footer.explore">Explorer</strong>
        <p><a href="/top/legendaires" data-i18n-ui="footer.legendary">Prénoms légendaires</a></p>
        <p><a href="/top/repandus" data-i18n-ui="footer.popular">Prénoms populaires</a></p>
        <p><a href="/type/water" data-i18n-ui="footer.types">Dresseurs par type</a></p>
      </div>
      <div>
        <strong style="display:block;margin-bottom:8px;color:var(--text)" data-i18n-ui="footer.legal">Légal</strong>
        <p><a href="/mentions-legales" data-i18n-ui="footer.legal-mentions">Mentions légales</a></p>
        <p><a href="/confidentialite" data-i18n-ui="footer.legal-privacy">Confidentialité</a></p>
        <p style="margin-top:8px;font-size:0.72rem;opacity:0.6">
          Pokémon © Nintendo / Game Freak / The Pokémon Company.<br />
          <span data-i18n-ui="footer.fanmade">Site fan-made non officiel.</span>
        </p>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2025 Le Dresseur en Moi</span>
      <span data-i18n-ui="footer.copyright">Données issues des jeux officiels Pokémon</span>
    </div>
  </footer>

</body>
