---
import CookieBanner from '../components/CookieBanner.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-default.png',
  schema,
  noindex = false,
} = Astro.props;

const SITE = 'https://pokenom.fr';
const fullOg = ogImage.startsWith('http') ? ogImage : `${SITE}${ogImage}`;
const schemaJson = schema
  ? JSON.stringify(Array.isArray(schema) ? schema : [schema])
  : null;

// ⚠️ Remplacer par ton vrai ca-pub-XXXXXXXXXX depuis Google AdSense
const ADSENSE_ID = 'ca-pub-6295830585093654';
---

<!DOCTYPE html>
<html lang="fr" data-ads-pub={ADSENSE_ID} data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  {!noindex && <meta name="robots" content="index,follow,max-image-preview:large" />}
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:locale"      content="fr_FR" />
  <meta property="og:site_name"   content="PokéNom" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={fullOg} />
  <meta property="og:url"         content={canonical} />

  <!-- Twitter Card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={fullOg} />

  <!-- Schema.org -->
  {schemaJson && <script type="application/ld+json" set:html={schemaJson} />}

  <!-- AdSense chargé dynamiquement après consentement via CookieBanner -->

  <!-- Preconnect domaines externes -->
  <link rel="preconnect" href="https://play.pokemonshowdown.com" />
  <link rel="preconnect" href="https://raw.githubusercontent.com" />
  <link rel="preconnect" href="https://pagead2.googlesyndication.com" />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap');
  </style>

  <!-- Dark mode : applique le thème avant le premier rendu pour éviter le flash -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved ?? (prefersDark ? 'dark' : 'light');
      document.documentElement.dataset.theme = theme;
    })();
  </script>
</head>
<body>

  <nav class="nav" aria-label="Navigation principale" data-i18n-ui="nav.aria">
    <div class="nav__inner">
      <a href="/" class="nav__logo" aria-label="PokéNom — Accueil">
        <div class="nav__logo-ball" aria-hidden="true"></div>
        PokéNom
      </a>
      <ul class="nav__links" role="list">
        <li><a href="/" data-i18n-ui="nav.search">Recherche</a></li>
        <li><a href="/duel" data-i18n-ui="nav.duel">Duel ⚔️</a></li>
        <li><a href="/top/legendaires" data-i18n-ui="nav.legendaries">Légendaires</a></li>
        <li><a href="/top/repandus" data-i18n-ui="nav.top-names">Top prénoms</a></li>
      </ul>
      <button class="theme-toggle" id="theme-toggle" aria-label="Basculer le thème sombre" title="Thème sombre">
        <span class="theme-toggle__icon">🌙</span>
      </button>
    </div>
  </nav>

  <script>
    const btn = document.getElementById('theme-toggle');
    const icon = btn?.querySelector('.theme-toggle__icon');
    function applyTheme(theme: string) {
      document.documentElement.dataset.theme = theme;
      localStorage.setItem('theme', theme);
      if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
    }
    // Init icon based on current theme
    const current = document.documentElement.dataset.theme ?? 'light';
    if (icon) icon.textContent = current === 'dark' ? '☀️' : '🌙';
    btn?.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      applyTheme(next);
    });
  </script>

  <!-- ── i18n global ──────────────────────────────────────────── -->
  <script>
    import translationsRaw from '../data/translations.json';
    const T = translationsRaw as Record<string, Record<string, string> | Record<string, Record<string,string>>>;

    const SUPPORTED = ['fr','en','de','es','ja'] as const;
    type Lang = typeof SUPPORTED[number];

    function detectLang(): Lang {
      for (const l of (navigator.languages ?? [navigator.language])) {
        const short = l.split('-')[0].toLowerCase() as Lang;
        if (SUPPORTED.includes(short)) return short;
      }
      return 'fr';
    }

    const lang = detectLang();

    // Expose globalement pour les scripts de pages spécifiques
    (window as any).__pokenom_lang = lang;
    (window as any).__pokenom_T    = T;

    if (lang !== 'fr') {
      const ui = T[lang] as Record<string, string>;
      document.querySelectorAll<HTMLElement>('[data-i18n-ui]').forEach(el => {
        const key = el.dataset.i18nUi!;
        if (ui[key]) {
          // Pour aria-label sur la nav
          if (el.tagName === 'NAV' && key === 'nav.aria') {
            el.setAttribute('aria-label', ui[key]);
          } else {
            el.textContent = ui[key];
          }
        }
      });

      // Noms de jeux (data-game-fr sur certains éléments)
      const games = T['games'] as Record<string, Record<string, string>>;
      document.querySelectorAll<HTMLElement>('[data-game-fr]').forEach(el => {
        const fr = el.dataset.gameFr!;
        const translated = games[fr]?.[lang];
        if (translated) el.textContent = translated.replace('Pokémon ', '');
      });
    }
  </script>

  <slot />

  <CookieBanner />

  <footer class="footer" aria-label="Pied de page">
    <div class="footer__inner">
      <div>
        <div class="footer__brand">PokéNom</div>
        <p><span data-i18n-ui="footer.tagline">Trouve ton dresseur Pokémon.</span><br /><span data-i18n-ui="footer.stats">4 728 dresseurs · 17 jeux officiels.</span></p>
      </div>
      <div>
        <strong style="display:block;margin-bottom:8px;color:var(--text)" data-i18n-ui="footer.explore">Explorer</strong>
        <p><a href="/top/legendaires" data-i18n-ui="footer.legendary">Prénoms légendaires</a></p>
        <p><a href="/top/repandus" data-i18n-ui="footer.popular">Prénoms populaires</a></p>
      </div>
      <div>
        <strong style="display:block;margin-bottom:8px;color:var(--text)" data-i18n-ui="footer.legal">Légal</strong>
        <p><a href="/mentions-legales">Mentions légales</a></p>
        <p><a href="/confidentialite">Confidentialité</a></p>
        <p style="margin-top:8px;font-size:0.72rem;opacity:0.6">
          Pokémon © Nintendo / Game Freak / The Pokémon Company.<br />
          Site fan-made non officiel.
        </p>
      </div>
    </div>
    <div class="footer__bottom">
      <span>© 2025 PokéNom</span>
      <span data-i18n-ui="footer.copyright">Données issues des jeux officiels Pokémon</span>
    </div>
  </footer>

</body>
</html>

<style is:global>
/* Import styles globaux */
</style>
