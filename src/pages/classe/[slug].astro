---
import Base from '../../layouts/Base.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import trainersRaw from '../../data/trainers.json';
import pokemonMetaRaw from '../../data/pokemon-meta.json';
import { toPokemonSlug } from '../../utils/slug';
import '../../styles/global.css';
import I18nScript from '../../components/I18nScript.astro';

const pkmMeta = pokemonMetaRaw as Record<string, { names_intl?: Record<string, string> }>;
function pkmNamesAttr(frName: string): string | undefined {
  const intl = pkmMeta[frName]?.names_intl;
  if (!intl) return undefined;
  return Object.entries(intl).map(([l, n]) => `${l}:${n}`).join('|');
}

export async function getStaticPaths() {
  const trainers = trainersRaw as any[];
  const bySlug = new Map<string, { name: string; trainers: any[] }>();
  for (const t of trainers) {
    if (!bySlug.has(t.class_slug)) bySlug.set(t.class_slug, { name: t.class, trainers: [] });
    bySlug.get(t.class_slug)!.trainers.push(t);
  }
  return [...bySlug.entries()].map(([slug, data]) => ({
    params: { slug },
    props: { slug, className: data.name, trainers: data.trainers },
  }));
}

const { className, trainers } = Astro.props as { slug: string; className: string; trainers: any[] };
const count = trainers.length;
const games = [...new Set(trainers.map((t: any) => t.game))];
const pkm = [...new Set(trainers.flatMap((t: any) => t.team ?? []))].slice(0, 16);

const title = `${className} — ${count} dresseurs Pokémon | Le Dresseur en Moi`;
const description = `${count} dresseurs de la classe ${className} dans les jeux Pokémon. Retrouvez leurs équipes et leurs prénoms.`;
---
<Base title={title} description={description} canonical={`https://ledresseurenmoi.com/classe/${Astro.params.slug}`}>
  <main id="main" class="container">
    <span id="page-title-i18n" style="display:none" data-name-fr={className} data-suffix-key="title.suffix.class" />
    <Breadcrumb crumbs={[{ label: 'Accueil', href: '/' }, { label: className }]} />
    <header class="page-header">
      <div class="game-badge"><img src="/assets/icons/tag.svg" alt="" width="14" height="14" class="badge-icon" /> Classe</div>
      <h1>{className}</h1>
      <p class="page-sub">{count} dresseur{count>1?'s':''} dans {games.length} jeu{games.length>1?'x':''}</p>
    </header>
    <AdSlot slot="3801988131" format="auto" />
    {pkm.length > 0 && (
      <section class="section-block">
        <h2>Pokémon favoris</h2>
        <div class="related-chips">
          {pkm.map((p: string) => {
            const names = pkmNamesAttr(p);
            return <a href={`/pokemon/${toPokemonSlug(p)}`} class="pkm-link" data-pkm-names={names || undefined}>{p}</a>;
          })}
        </div>
      </section>
    )}
    <section class="section-block">
      <h2>Tous les {className}s</h2>
      <div class="cards-grid" style="margin-top:16px">
        {trainers.slice(0,6).map((t: any) => <TrainerCard trainer={t} />)}
      </div>
      {count > 6 && (
        <>
          <AdSlot slot="2658324637" format="fluid" layout="in-article" />
          <div class="cards-grid" style="margin-top:16px">
            {trainers.slice(6).map((t: any) => <TrainerCard trainer={t} />)}
          </div>
        </>
      )}
    </section>
    <AdSlot slot="1175824798" format="auto" />
  </main>
  <I18nScript />
</Base>
<style>
.page-header { padding:36px 0 28px; border-bottom:1.5px solid var(--border); margin-bottom:32px; }
.game-badge { font-size:0.7rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercas