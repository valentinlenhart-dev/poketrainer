---
import Base from '../layouts/Base.astro';
import '../styles/global.css';
---

<Base
  title="Contact | Le Dresseur en Moi"
  description="Contactez l'équipe du Dresseur en Moi pour toute question ou suggestion."
  canonical="https://ledresseurenmoi.com/contact"
  noindex={true}
>
  <main id="main" class="container contact-page">
    <h1 data-i18n-ui="contact.title">Nous contacter</h1>
    <p class="contact-sub" data-i18n-ui="contact.sub">
      Une question, une suggestion, une erreur à signaler ? Écrivez-nous.
    </p>

    <form
      id="contact-form"
      action="https://formspree.io/f/mreddqko"
      method="POST"
      class="contact-form"
    >
      <div class="form-group">
        <label for="contact-name" data-i18n-ui="contact.name">Nom</label>
        <input
          id="contact-name"
          type="text"
          name="name"
          required
          maxlength="80"
          data-i18n-placeholder="contact.name-placeholder"
          placeholder="Votre nom"
        />
      </div>

      <div class="form-group">
        <label for="contact-email" data-i18n-ui="contact.email">Email</label>
        <input
          id="contact-email"
          type="email"
          name="email"
          required
          maxlength="120"
          data-i18n-placeholder="contact.email-placeholder"
          placeholder="votre@email.com"
        />
      </div>

      <div class="form-group">
        <label for="contact-msg" data-i18n-ui="contact.message">Message</label>
        <textarea
          id="contact-msg"
          name="message"
          required
          rows="6"
          maxlength="2000"
          data-i18n-placeholder="contact.message-placeholder"
          placeholder="Votre message…"
        ></textarea>
      </div>

      <!-- Honeypot anti-spam -->
      <input type="text" name="_gotcha" style="display:none" />

      <button type="submit" class="contact-btn" data-i18n-ui="contact.send">
        <img src="/assets/icons/mail.svg" alt="" width="16" height="16" style="vertical-align:middle;margin-right:6px;" />Envoyer
      </button>

      <p id="contact-success" class="contact-success" style="display:none" data-i18n-ui="contact.success">
        <img src="/assets/icons/check.svg" alt="" width="16" height="16" style="vertical-align:middle;margin-right:4px;" />Message envoyé ! Merci, nous vous répondrons rapidement.
      </p>
      <p id="contact-error" class="contact-error" style="display:none" data-i18n-ui="contact.error">
        <img src="/assets/icons/close.svg" alt="" width="14" height="14" style="vertical-align:middle;margin-right:4px;" />Une erreur est survenue. Veuillez réessayer.
      </p>
    </form>
  </main>
</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  const error   = document.getElementById('contact-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' },
      });
      if (res.ok) {
        form.reset();
        if (success) success.style.display = '';
        if (error)   error.style.display   = 'none';
      } else {
        throw new Error('server error');
      }
    } catch {
      if (error)   error.style.display   = '';
      if (success) success.style.display = 'none';
      btn.disabled = false;
    }
  });
</script>

<style>
.contact-page {
  max-width: 560px;
  padding-top: 48px;
  padding-bottom: 80px;
}
.contact-page h1 {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  margin-bottom: 10px;
}
.contact-sub {
  color: var(--text-mid);
  font-size: 0.95rem;
  margin-bottom: 36px;
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.form-group label {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--text);
}
.form-group input,
.form-group textarea {
  padding: 11px 14px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  background: var(--bg);
  font-size: 0.95rem;
  color: var(--text);
  outline: none;
  transition: border-color .15s;
  resize: vertical;
  font-family: inherit;
}
.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--red);
}
.contact-btn {
  align-self: flex-start;
  padding: 12px 28px;
  background: var(--red);
  color: #fff;
  border: none;
  border-radius: var(--radius);
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: background .15s, transform .1s;
}
.contact-btn:hover  { background: var(--red-dark); transform: translateY(-1px); }
.contact-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }
.contact-success { color: #2e7d32; font-weight: 600; font-size: 0.95rem; }
.contact-error   { color: var(--red); font-weight: 600; font-size: 0.95rem; }
</style>
