---
import trainersRaw from '../../data/trainers.json';
import '../../styles/global.css';

const slugs = (trainersRaw as any[]).map(t => t.slug);
const slugsJson = JSON.stringify(slugs);

const ADSENSE_ID = 'ca-pub-6295830585093654';
const AD_SLOT    = '2896100570';
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dresseur aléatoire — PokéNom</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh;
      background: var(--bg, #fff);
      font-family: 'Inter', system-ui, sans-serif;
    }

    .modal-card {
      background: var(--bg2, #f5f5f5);
      border: 1.5px solid var(--border, #e5e7eb);
      border-radius: 12px;
      box-shadow: 0 20px 60px rgba(0,0,0,.15);
      width: min(400px, 92vw);
      padding: 36px 28px 28px;
      display: flex; flex-direction: column; align-items: center; gap: 20px;
      animation: slide-up 0.3s ease;
    }
    @keyframes slide-up {
      from { transform: translateY(20px); opacity: 0; }
      to   { transform: translateY(0);    opacity: 1; }
    }

    /* Pokéball CSS */
    .pokeball {
      width: 72px; height: 72px; border-radius: 50%;
      border: 4px solid #1a1a1a;
      overflow: hidden; position: relative;
      animation: spin 0.7s linear infinite; flex-shrink: 0;
    }
    @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
    .pb-top    { position:absolute; inset:0 0 50% 0; background:#dc2626; }
    .pb-bottom { position:absolute; inset:50% 0 0 0; background:#fff; }
    .pb-band   { position:absolute; top:calc(50% - 3px); left:-4px; right:-4px; height:6px; background:#1a1a1a; z-index:2; }
    .pb-btn    { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:20px; height:20px; border-radius:50%; background:#fff; border:3px solid #1a1a1a; z-index:3; }

    h1 {
      font-size: 1.05rem; font-weight: 800; color: var(--text, #111);
      text-align: center; letter-spacing: -0.01em;
    }
    #msg {
      font-size: 0.88rem; color: var(--text-soft, #666);
      text-align: center; min-height: 1.4em;
      transition: opacity 0.3s;
    }

    /* Progress bar */
    .progress-wrap {
      width: 100%; height: 4px;
      background: var(--border, #e5e7eb); border-radius: 999px; overflow: hidden;
    }
    #progress-bar {
      height: 100%; width: 0%;
      background: #dc2626; border-radius: 999px;
      transition: width 0.05s linear;
    }

    /* Ad container */
    .ad-wrap {
      width: 100%; min-height: 90px;
      background: var(--bg, #f9f9f9);
      border: 1px dashed var(--border, #d1d5db);
      border-radius: 8px;
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }

    /* Dark mode support */
    [data-theme="dark"] body        { background: #0f0f0f; }
    [data-theme="dark"] .modal-card { background: #1a1a1a; border-color: #2d2d2d; }
    [data-theme="dark"] .pb-band,
    [data-theme="dark"] .pokeball   { border-color: #e5e5e5; }
    [data-theme="dark"] .pb-btn     { border-color: #e5e5e5; }
    [data-theme="dark"] h1          { color: #f0f0f0; }
    [data-theme="dark"] #msg        { color: #999; }
    [data-theme="dark"] .ad-wrap    { background: #111; border-color: #333; }
  </style>
</head>
<body>
  <!-- Appliquer le thème sauvegardé avant le rendu -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('theme');
      var d = window.matchMedia('(prefers-color-scheme: dark)').matches;
      document.documentElement.dataset.theme = t ?? (d ? 'dark' : 'light');
    })();
  </script>

  <div class="modal-card" role="status" aria-live="polite">
    <div class="pokeball" aria-hidden="true">
      <div class="pb-top"></div>
      <div class="pb-bottom"></div>
      <div class="pb-band"></div>
      <div class="pb-btn"></div>
    </div>

    <h1>🎲 Dresseur surprise</h1>
    <p id="msg">Sélection en cours…</p>

    <div class="progress-wrap">
      <div id="progress-bar"></div>
    </div>

    <!-- AdSense -->
    <div class="ad-wrap" id="ad-wrap"></div>
  </div>

  <!-- AdSense script (chargé si consentement) -->
  <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_ID}`} crossorigin="anonymous"></script>

  <script define:vars={{ slugsJson, AD_SLOT, ADSENSE_ID }}>
    const DURATION = 2000;
    const MESSAGES = [
      'Sélection en cours…',
      '🔍 Parcours des archives…',
      '🎮 Chargement de l\'équipe…',
      '✅ Dresseur trouvé !',
    ];

    const msgEl  = document.getElementById('msg');
    const barEl  = document.getElementById('progress-bar');
    const adWrap = document.getElementById('ad-wrap');
    const start  = performance.now();

    // Inject ad
    try {
      const ins = document.createElement('ins');
      ins.className = 'adsbygoogle';
      ins.style.cssText = 'display:block;width:100%;min-height:90px;';
      ins.setAttribute('data-ad-client', ADSENSE_ID);
      ins.setAttribute('data-ad-slot', AD_SLOT);
      ins.setAttribute('data-ad-format', 'auto');
      ins.setAttribute('data-full-width-responsive', 'true');
      adWrap.appendChild(ins);
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    } catch(e) {}

    // Progress bar
    function tick(now) {
      const pct = Math.min(((now - start) / DURATION) * 100, 100);
      barEl.style.width = pct + '%';
      if (pct < 100) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    // Messages rotatifs
    const step = DURATION / MESSAGES.length;
    MESSAGES.forEach(function(m, i) {
      setTimeout(function() { if (msgEl) msgEl.textContent = m; }, i * step);
    });

    // Navigation
    const slugs = JSON.parse(slugsJson);
    const pick  = slugs[Math.floor(Math.random() * slugs.length)];
    setTimeout(function() {
      window.location.replace('/dresseur/' + pick);
    }, DURATION);
  </script>
</body>
</html>
