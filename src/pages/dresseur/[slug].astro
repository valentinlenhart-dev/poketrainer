---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import trainersRaw from '../../data/trainers.json';
import pokemonMetaRaw from '../../data/pokemon-meta.json';
import classSpritesRaw from '../../data/trainer-class-sprites.json';
import { toPokemonSlug, placeLabel } from '../../utils/slug';
import I18nScript from '../../components/I18nScript.astro';
import '../../styles/global.css';

const pokemonMeta   = pokemonMetaRaw as Record<string, any>;
const classSprites  = classSpritesRaw as Record<string, string>;

const TYPE_COLORS: Record<string, string> = {
  fire:'#f08030', water:'#6890f0', grass:'#78c850', electric:'#f8d030',
  ice:'#98d8d8', fighting:'#c03028', poison:'#a040a0', ground:'#e0c068',
  flying:'#a890f0', psychic:'#f85888', bug:'#a8b820', rock:'#b8a038',
  ghost:'#705898', dragon:'#7038f8', dark:'#705848', steel:'#b8b8d0',
  fairy:'#ee99ac', normal:'#a8a878',
};
const TYPE_FR: Record<string, string> = {
  fire:'Feu', water:'Eau', grass:'Plante', electric:'Électrik',
  ice:'Glace', fighting:'Combat', poison:'Poison', ground:'Sol',
  flying:'Vol', psychic:'Psy', bug:'Insecte', rock:'Roche',
  ghost:'Spectre', dragon:'Dragon', dark:'Ténèbres', steel:'Acier',
  fairy:'Fée', normal:'Normal',
};

export async function getStaticPaths() {
  const trainers = trainersRaw as any[];
  return trainers.map(t => ({
    params: { slug: t.slug },
    props: { trainer: t },
  }));
}

const { trainer: t } = Astro.props as { trainer: any };

const gameName    = t.game.replace('Pokémon ', '');
const placeText   = t.place ? placeLabel(t.place) : null;
const teamText    = (t.team ?? []).join(', ');
const classSprite = classSprites[t.class] ?? null;

// Dresseurs proches : même lieu d'abord, puis même jeu
const allTrainers = trainersRaw as any[];
const nearbyPlace = t.place
  ? allTrainers.filter(x => x.slug !== t.slug && x.place === t.place).slice(0, 4)
  : [];
const nearbyGame  = allTrainers
  .filter(x => x.slug !== t.slug && x.game === t.game && !nearbyPlace.find(n => n.slug === x.slug))
  .slice(0, 4 - nearbyPlace.length > 0 ? 4 - nearbyPlace.length : 4);
const nearby = [...nearbyPlace, ...nearbyGame].slice(0, 6);

const title = `${t.class} ${t.name} — ${gameName} | PokéNom`;
const description = placeText
  ? `${t.class} ${t.name} est un dresseur Pokémon rencontré ${placeText} dans ${t.game}. Son équipe : ${teamText || 'inconnue'}.`
  : `${t.class} ${t.name} est un dresseur Pokémon de ${t.game}. Son équipe : ${teamText || 'inconnue'}.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": `${t.class} ${t.name}`,
  "jobTitle": t.class,
  "description": description,
  "url": `https://pokenom.fr/dresseur/${t.slug}`,
  "knowsAbout": t.team ?? [],
};
---

<!-- Descriptions multilingues (mises à jour côté client via Base.astro applyLang) -->
<script define:vars={{ trainerName: t.name, trainerClass: t.class, trainerGame: t.game, trainerPlace: placeText, trainerTeam: teamText }}>
  // define:vars = JS pur (pas de TypeScript)
  const templates = {
    fr: (c,n,g,p,tm) => p
      ? `${c} ${n} est un dresseur Pokémon rencontré ${p} dans ${g}. Son équipe : ${tm||'inconnue'}.`
      : `${c} ${n} est un dresseur Pokémon de ${g}. Son équipe : ${tm||'inconnue'}.`,
    en: (c,n,g,p,tm) => p
      ? `${c} ${n} is a Pokémon Trainer encountered ${p} in ${g}. Team: ${tm||'unknown'}.`
      : `${c} ${n} is a Pokémon Trainer from ${g}. Team: ${tm||'unknown'}.`,
    de: (c,n,g,p,tm) => p
      ? `${c} ${n} ist ein Pokémon-Trainer, dem du ${p} in ${g} begegnest. Team: ${tm||'unbekannt'}.`
      : `${c} ${n} ist ein Pokémon-Trainer aus ${g}. Team: ${tm||'unbekannt'}.`,
    es: (c,n,g,p,tm) => p
      ? `${c} ${n} es un Entrenador Pokémon que se encuentra ${p} en ${g}. Equipo: ${tm||'desconocido'}.`
      : `${c} ${n} es un Entrenador Pokémon de ${g}. Equipo: ${tm||'desconocido'}.`,
    it: (c,n,g,p,tm) => p
      ? `${c} ${n} è un Allenatore Pokémon incontrato ${p} in ${g}. Squadra: ${tm||'sconosciuta'}.`
      : `${c} ${n} è un Allenatore Pokémon di ${g}. Squadra: ${tm||'sconosciuta'}.`,
    'pt-BR': (c,n,g,p,tm) => p
      ? `${c} ${n} é um Treinador Pokémon encontrado ${p} em ${g}. Time: ${tm||'desconhecido'}.`
      : `${c} ${n} é um Treinador Pokémon de ${g}. Time: ${tm||'desconhecido'}.`,
    ko: (c,n,g,p,tm) => `${g}의 포켓몬 트레이너 ${n}. 파티: ${tm||'알 수 없음'}.`,
    ja: (c,n,g,p,tm) => `${g}のポケモントレーナー、${n}。パーティ: ${tm||'不明'}.`,
    'zh-Hans': (c,n,g,p,tm) => `${g}中的宝可梦训练师${n}。队伍: ${tm||'未知'}.`,
    'zh-Hant': (c,n,g,p,tm) => `${g}中的寶可夢訓練師${n}。隊伍: ${tm||'未知'}.`,
  };

  const desc = {};
  for (const [lang, fn] of Object.entries(templates)) {
    desc[lang] = fn(trainerClass, trainerName, trainerGame, trainerPlace, trainerTeam);
  }
  window.__page_desc_i18n = desc;
</script>

<Base
  title={title}
  description={description}
  canonical={`https://pokenom.fr/dresseur/${t.slug}`}
  schema={schema}
>
  <main id="main" class="container">
    <Breadcrumb crumbs={[
      { label: 'Accueil', href: '/' },
      { label: t.name, href: `/prenom/${t.name_slug}` },
      { label: `${t.class} ${t.name}` },
    ]} />

    <article class="trainer-page">

      <!-- En-tête dresseur -->
      <header class="trainer-page__header">
        <div class="trainer-page__class-row">
          {classSprite && (
            <img src={classSprite} alt={t.class} width="56" height="56"
              class="trainer-page__class-sprite"
              onerror="this.style.display='none'" loading="eager" />
          )}
          <div>
            <div class="trainer-page__class">{t.class}</div>
            <h1 class="trainer-page__name">{t.name}</h1>
          </div>
        </div>

        <div class="trainer-page__meta">
          <div class="meta-item">
            <span class="meta-item__icon"><img src="/assets/meta/game.svg" alt="" width="18" height="18" /></span>
            <a href={`/jeu/${t.game_slug}`} data-game-fr={t.game}>{gameName}</a>
          </div>
          {placeText && (
            <div class="meta-item">
              <span class="meta-item__icon"><img src="/assets/meta/place.svg" alt="" width="18" height="18" /></span>
              <a href={`/lieu/${t.place_slug}`}>{placeText}</a>
            </div>
          )}
          <div class="meta-item">
            <span class={`rarity rarity--${t.rarity_key}`} data-i18n-rarity={t.rarity_key}>
              <img src={`/assets/rarity/${t.rarity_key}.svg`} alt="" width="14" height="14" style="vertical-align:middle;margin-right:4px;" /> {t.rarity_label}
            </span>
          </div>
        </div>
      </header>

      <!-- Pub in-article après l'en-tête -->
      <AdSlot slot="4268967971" format="fluid" layout="in-article" />

      <!-- Équipe Pokémon -->
      {(t.team ?? []).length > 0 && (
        <section class="team-section" aria-label="Équipe Pokémon">
          <h2 data-i18n-ui="trainer-team">Équipe Pokémon</h2>
          <ul class="team-list" role="list">
            {t.team.map((pkm: string) => {
              const pSlug  = toPokemonSlug(pkm);
              const pMeta  = pokemonMeta[pkm] ?? null;
              const sprite = pMeta?.sprite ?? null;
              const types  = (pMeta?.types ?? []) as string[];
              const nameEn = pMeta?.name_en ?? '';
              return (
                <li>
                  <div class="team-pkm">
                    <a href={`/pokemon/${pSlug}`} class="team-pkm__overlay" aria-label={`Voir ${pkm}`}></a>
                    <div class="team-pkm__visual">
                      {sprite
                        ? <img src={sprite} alt={pkm} width="48" height="48" class="team-pkm__sprite" loading="lazy" />
                        : <span class="team-pkm__ball" aria-hidden="true">⚪</span>
                      }
                    </div>
                    <div class="team-pkm__info">
                      <span class="team-pkm__name">{pkm}</span>
                      {nameEn && nameEn !== pkm && <span class="team-pkm__en">{nameEn}</span>}
                      {types.length > 0 && (
                        <div class="team-pkm__types">
                          {types.map((type: string) => (
                            <a href={`/type/${type}`} class="team-type-badge" style={`background:${TYPE_COLORS[type] ?? '#888'}`} data-type={type}>
                              <span class="type-name">{TYPE_FR[type] ?? type}</span>
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                    <span class="team-pkm__arrow">→</span>
                  </div>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      <!-- Description naturelle (pour LLM + SEO) -->
      <section class="trainer-page__lore">
        <h2>À propos de {t.class} {t.name}</h2>
        <p>
          <strong>{t.class} {t.name}</strong> est un dresseur Pokémon
          {placeText ? ` que l'on rencontre ${placeText}` : ''} dans
          <a href={`/jeu/${t.game_slug}`}>{t.game}</a>.
          {(t.team ?? []).length > 0 && (
            ` Son équipe est composée de ${teamText}.`
          )}
        </p>
        <p>
          Le prénom <a href={`/prenom/${t.name_slug}`}>{t.name}</a> est
          {t.rarity_key === 'legendaire'
            ? ` légendaire dans Pokémon — c'est le seul dresseur à le porter !`
            : t.rarity_key === 'rare'
            ? ` rare dans l'univers Pokémon, avec seulement ${t.name_count} dresseurs.`
            : ` porté par ${t.name_count} dresseurs dans la base.`
          }
        </p>
      </section>

      <!-- Partager -->
      <div class="share-row">
        <button class="share-btn" id="share-btn" data-url={`https://pokenom.fr/dresseur/${t.slug}`} data-title={`${t.class} ${t.name} — PokéNom`} data-text={description}>
          <span class="share-btn__icon">🔗</span>
          <span class="share-btn__label" data-i18n-ui="share.btn">Partager ce dresseur</span>
        </button>
        <span class="share-confirm" id="share-confirm" aria-live="polite"></span>
      </div>

      <!-- Liens connexes -->
      <aside class="trainer-page__related">
        <h2 data-i18n-ui="trainer-explore">Explorer</h2>
        <div class="related-links">
          <a href={`/prenom/${t.name_slug}`} class="related-link">
            👤 Tous les dresseurs nommés {t.name}
          </a>
          <a href={`/jeu/${t.game_slug}`} class="related-link">
            <img src="/assets/meta/game.svg" alt="" width="14" height="14" style="vertical-align:middle;margin-right:4px;" /> Tous les dresseurs de {gameName}
          </a>
          {t.place && (
            <a href={`/lieu/${t.place_slug}`} class="related-link">
              <img src="/assets/meta/place.svg" alt="" width="14" height="14" style="vertical-align:middle;margin-right:4px;" /> Dresseurs au même endroit
            </a>
          )}
          <a href="/" class="related-link">
            🏠 Accueil PokéNom
          </a>
        </div>
      </aside>

      <!-- Dresseurs proches -->
      {nearby.length > 0 && (
        <section class="nearby-section">
          <h2>Dresseurs similaires</h2>
          <div class="cards-grid">
            {nearby.map((n: any) => (
              <TrainerCard trainer={n} />
            ))}
          </div>
        </section>
      )}

    </article>
  </main>
</Base>

<I18nScript />

<script>
  const btn = document.getElementById('share-btn') as HTMLButtonElement | null;
  const confirm = document.getElementById('share-confirm');
  if (btn) {
    btn.addEventListener('click', async () => {
      const url   = btn.dataset.url   ?? location.href;
      const title = btn.dataset.title ?? document.title;
      const text  = btn.dataset.text  ?? '';
      // Labels traduits (si dispo)
      const lang = (window as any).__pokenom_lang ?? 'fr';
      const T: Record<string,Record<string,string>> = (window as any).__pokenom_T ?? {};
      const ui = (T[lang] ?? {}) as Record<string, string>;
      const copied  = ui['share.copied']  ?? 'Lien copié !';
      const shared  = ui['share.shared']  ?? 'Partagé !';
      const shareErr = ui['share.error'] ?? 'Impossible de partager.';

      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          if (confirm) { confirm.textContent = shared; setTimeout(()=>{ if(confirm) confirm.textContent=''; },3000); }
        } catch {}
      } else if (navigator.clipboard) {
        try {
          await navigator.clipboard.writeText(url);
          if (confirm) { confirm.textContent = copied; setTimeout(()=>{ if(confirm) confirm.textContent=''; },3000); }
        } catch {
          if (confirm) { confirm.textContent = shareErr; setTimeout(()=>{ if(confirm) confirm.textContent=''; },3000); }
        }
      }
    });
  }
</script>

<style>
.trainer-page { padding: 32px 0 64px; }

.trainer-page__header {
  margin-bottom: 32px;
}
.trainer-page__class-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 16px;
}
.trainer-page__class-sprite {
  width: 56px; height: 56px;
  image-rendering: pixelated;
  flex-shrink: 0;
}
.trainer-page__class {
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--red); margin-bottom: 4px;
}
.trainer-page__name {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800; line-height: 1.1;
  color: var(--text);
}
.trainer-page__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.9rem;
  color: var(--text-mid);
}
.meta-item__icon { flex-shrink: 0; }
.meta-item a { color: var(--text-mid); }
.meta-item a:hover { color: var(--red); }

/* Équipe */
.team-section { margin: 36px 0; }
.team-section h2 { margin-bottom: 16px; }
.team-list {
  list-style: none;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
}
.team-pkm {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 14px;
  color: inherit;
  transition: border-color 0.15s, transform 0.15s;
  position: relative;
}
.team-pkm:has(.team-pkm__overlay:hover) {
  border-color: var(--border-focus);
  transform: translateY(-1px);
}
.team-pkm__overlay {
  position: absolute;
  inset: 0;
  z-index: 0;
  border-radius: var(--radius-sm);
}
.team-pkm__visual,
.team-pkm__info,
.team-pkm__arrow {
  position: relative;
  z-index: 1;
}
.team-type-badge {
  position: relative;
  z-index: 2;
}
.team-pkm__visual {
  width: 48px; height: 48px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.team-pkm__sprite { image-rendering: pixelated; }
.team-pkm__ball { font-size: 1.6rem; }
.team-pkm__info {
  display: flex; flex-direction: column; gap: 3px;
  min-width: 0;
}
.team-pkm__name { font-weight: 700; font-size: 0.95rem; color: var(--text); }
.team-pkm__en   { font-size: 0.72rem; color: var(--text-soft); }
.team-pkm__types { display: flex; gap: 4px; flex-wrap: wrap; margin-top: 2px; }
.team-type-badge {
  font-size: 0.68rem; font-weight: 600;
  color: #fff; padding: 1px 7px;
  border-radius: 999px;
  text-decoration: none;
}
.team-type-badge:hover { opacity: 0.8; text-decoration: none; }
.team-pkm__arrow {
  margin-left: auto;
  color: var(--text-soft);
  font-size: 0.85rem;
  flex-shrink: 0;
}

/* Lore */
.trainer-page__lore {
  margin: 36px 0;
  padding: 24px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
}
.trainer-page__lore h2 { margin-bottom: 14px; }
.trainer-page__lore p + p { margin-top: 10px; }

/* Liens connexes */
.trainer-page__related { margin: 36px 0; }
.trainer-page__related h2 { margin-bottom: 14px; }
.related-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.related-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
  color: var(--text-mid);
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s;
}
.related-link:hover {
  border-color: var(--red);
  color: var(--red);
  text-decoration: none;
}

/* Partager */
.share-row { margin: 24px 0; display:flex; align-items:center; gap:12px; }
.share-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: var(--red);
  color: #fff;
  border: none;
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-weight: 700;
  font-family: var(--font);
  cursor: pointer;
  transition: opacity 0.15s, transform 0.1s;
}
.share-btn:hover { opacity: 0.88; transform: translateY(-1px); }
.share-btn__icon { font-size: 1rem; }
.share-confirm { font-size: 0.85rem; color: var(--text-soft); }

/* Dresseurs proches */
.nearby-section { margin: 36px 0; }
.nearby-section h2 { margin-bottom: 16px; }

@media (max-width: 640px) {
  .team-list { grid-template-columns: 1fr; }
  .trainer-page__class-row { gap: 10px; }
}
</style>