---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import trainersRaw from '../data/trainers.json';
import '../styles/global.css';

// Passer les données au script client via un data attribute
const trainersJson = JSON.stringify(trainersRaw);

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "PokéNom Duel",
  "description": "Mode duel : deux joueurs entrent leurs prénoms et découvrent lequel a le plus de dresseurs Pokémon.",
  "url": "https://pokenom.fr/duel",
  "applicationCategory": "GameApplication",
};
---

<Base
  title="Mode Duel — Qui a le meilleur prénom Pokémon ? | PokéNom"
  description="Affrontez vos amis ! Entrez 3 prénoms chacun, le score dépend du nombre de dresseurs Pokémon trouvés. Prénom légendaire = bonus ×2 !"
  canonical="https://pokenom.fr/duel"
  schema={schema}
>
  <main id="main">
    <div class="container">

      <header class="duel-header">
        <h1>⚔️ Mode Duel</h1>
        <p class="duel-sub">
          Chaque joueur entre 3 prénoms. Le score dépend du nombre de dresseurs Pokémon trouvés.
          Prénom légendaire (1 seul dresseur) = <strong>bonus ×2 !</strong>
        </p>
      </header>

      <AdSlot slot="1583018907" format="auto" />

      <div class="duel-arena" id="duel-arena">

        <!-- Joueur 1 -->
        <div class="duel-side" id="side-p1">
          <div class="player-head">
            <div class="player-dot p1"></div>
            <h2>Joueur 1</h2>
          </div>
          <div class="duel-inputs" data-player="1">
            <input type="text" class="duel-input" placeholder="Prénom 1" maxlength="40" />
            <input type="text" class="duel-input" placeholder="Prénom 2" maxlength="40" />
            <input type="text" class="duel-input" placeholder="Prénom 3" maxlength="40" />
          </div>
          <div class="duel-score hidden" id="score-p1">
            <span class="score-num" id="score-num-p1">0</span>
            <span class="score-label">points</span>
          </div>
        </div>

        <!-- Centre -->
        <div class="duel-center">
          <div class="vs-ball" aria-hidden="true">
            <div class="vs-ball__top"></div>
            <div class="vs-ball__mid"></div>
            <div class="vs-ball__bot"></div>
          </div>
          <span class="vs-text">VS</span>
          <button id="duel-btn" class="btn-duel">⚡ Lancer !</button>
          <button id="duel-reset" class="btn-reset hidden">↺ Rejouer</button>
        </div>

        <!-- Joueur 2 -->
        <div class="duel-side" id="side-p2">
          <div class="player-head">
            <div class="player-dot p2"></div>
            <h2>Joueur 2</h2>
          </div>
          <div class="duel-inputs" data-player="2">
            <input type="text" class="duel-input" placeholder="Prénom 1" maxlength="40" />
            <input type="text" class="duel-input" placeholder="Prénom 2" maxlength="40" />
            <input type="text" class="duel-input" placeholder="Prénom 3" maxlength="40" />
          </div>
          <div class="duel-score hidden" id="score-p2">
            <span class="score-num" id="score-num-p2">0</span>
            <span class="score-label">points</span>
          </div>
        </div>
      </div>

      <!-- Résultat -->
      <div id="duel-result" class="duel-result hidden"></div>

      <!-- Règles -->
      <section class="duel-rules">
        <h3>Règles du scoring</h3>
        <ul>
          <li>🏆 Prénom <strong>unique</strong> (1 seul dresseur dans toute la saga) → score <strong>×2</strong></li>
          <li>👀 Prénom <strong>répandu</strong> → 1 point par dresseur trouvé</li>
          <li>✨ Aucun dresseur → 0 point (mais tu es unique au monde !)</li>
        </ul>
      </section>

      <AdSlot slot="3971406302" format="auto" />

    </div>
  </main>

  <!-- Données injectées -->
  <script type="application/json" id="trainers-data" set:html={trainersJson}></script>

  <script>
    // ── Données ──────────────────────────────────────────────────
    const raw = document.getElementById('trainers-data')?.textContent ?? '[]';
    const TRAINERS = JSON.parse(raw);

    // ── Normalisation ────────────────────────────────────────────
    function normalize(s) {
      return s.toLowerCase()
        .normalize('NFD').replace(/[̀-ͯ]/g, '')
        .replace(/[^a-z0-9\s]/g, ' ').trim();
    }

    function toSlug(s) {
      return normalize(s).replace(/\s+/g, '-');
    }

    // ── Scoring ──────────────────────────────────────────────────
    function scoreNames(names) {
      let total = 0;
      const details = [];
      for (const raw of names) {
        const name = raw.trim();
        if (!name) { details.push({ name, count: 0, points: 0, bonus: false, trainers: [] }); continue; }
        const nq = normalize(name);
        const matches = TRAINERS.filter(t =>
          normalize(t.name_normalized ?? t.name).includes(nq)
        );
        const count = matches.length;
        const bonus = count === 1;
        const points = count === 0 ? 0 : bonus ? 2 : count;
        total += points;
        details.push({
          name, count, points, bonus,
          trainers: matches.slice(0, 3).map(t => ({
            name: t.name, class: t.class, game: t.game, slug: t.slug
          }))
        });
      }
      return { total, details };
    }

    // ── DOM ──────────────────────────────────────────────────────
    const btn      = document.getElementById('duel-btn');
    const resetBtn = document.getElementById('duel-reset');
    const resultEl = document.getElementById('duel-result');
    const scoreP1  = document.getElementById('duel-score') ?? document.getElementById('score-p1');
    const scoreP2  = document.getElementById('score-p2');

    const FUN = {
      p1: ['🎉 Victoire éclatante ! Digne d\'un Champion !', '⚡ Incroyable ! Hall of Fame assuré !', '🏆 Maître Pokémon absolu !'],
      p2: ['🎉 Belle victoire ! Un vrai talent !', '🌟 Impressionnant ! Ce prénom règne !', '🏆 Champion ultime !'],
      tie: ['🤝 Match nul ! Deux champions !', '⚖️ Égalité parfaite !', '🎭 L\'harmonie règne sur Pokéland !'],
    };
    function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    function getInputs(player) {
      return [...document.querySelector(`[data-player="${player}"]`).querySelectorAll('.duel-input')]
        .map(i => i.value);
    }

    function renderDetail(detail) {
      return detail.map(d => `
        <div class="detail-row ${d.bonus ? 'bonus' : ''} ${d.count === 0 ? 'zero' : ''}">
          <div class="detail-left">
            <span class="detail-name">${d.name || '—'}</span>
            ${d.bonus ? '<span class="detail-bonus">×2 Légendaire !</span>' : ''}
          </div>
          <div class="detail-right">
            <span class="detail-count">${d.count} dresseur${d.count !== 1 ? 's' : ''}</span>
            <span class="detail-pts ${d.points > 0 ? 'pos' : ''}">${d.points > 0 ? '+' : ''}${d.points} pt${d.points !== 1 ? 's' : ''}</span>
          </div>
          ${d.trainers.length > 0 ? `
          <div class="detail-trainers">
            ${d.trainers.map(t => `<a href="/dresseur/${t.slug}" class="mini-trainer">${t.class} ${t.name} · ${t.game.replace('Pokémon ','')}</a>`).join('')}
          </div>` : ''}
        </div>
      `).join('');
    }

    btn?.addEventListener('click', () => {
      const p1 = scoreNames(getInputs(1));
      const p2 = scoreNames(getInputs(2));

      // Afficher scores
      document.getElementById('score-num-p1').textContent = p1.total;
      document.getElementById('score-num-p2').textContent = p2.total;
      document.getElementById('score-p1').classList.remove('hidden');
      document.getElementById('score-p2').classList.remove('hidden');

      // Gagnant
      let winner, msg;
      if      (p1.total > p2.total) { winner = 'p1'; msg = pick(FUN.p1); }
      else if (p2.total > p1.total) { winner = 'p2'; msg = pick(FUN.p2); }
      else                           { winner = 'tie'; msg = pick(FUN.tie); }

      document.getElementById('side-p1').classList.toggle('winner', winner === 'p1');
      document.getElementById('side-p2').classList.toggle('winner', winner === 'p2');

      resultEl.innerHTML = `
        <div class="result-banner ${winner}">
          <div class="result-msg">${msg}</div>
          <div class="result-score">${p1.total} — ${p2.total}</div>
        </div>
        <div class="result-details">
          <div class="result-col">
            <h3>Joueur 1</h3>
            ${renderDetail(p1.details)}
            <div class="result-total">Total : <strong>${p1.total} pts</strong></div>
          </div>
          <div class="result-col">
            <h3>Joueur 2</h3>
            ${renderDetail(p2.details)}
            <div class="result-total">Total : <strong>${p2.total} pts</strong></div>
          </div>
        </div>
      `;
      resultEl.classList.remove('hidden');
      btn.classList.add('hidden');
      resetBtn.classList.remove('hidden');
      resultEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    resetBtn?.addEventListener('click', () => {
      document.querySelectorAll('.duel-input').forEach(i => i.value = '');
      document.getElementById('score-p1').classList.add('hidden');
      document.getElementById('score-p2').classList.add('hidden');
      document.getElementById('side-p1').classList.remove('winner');
      document.getElementById('side-p2').classList.remove('winner');
      resultEl.classList.add('hidden');
      resultEl.innerHTML = '';
      btn.classList.remove('hidden');
      resetBtn.classList.add('hidden');
    });
  </script>
</Base>

<style>
/* ── Header ───────────────────────────────────────────────── */
.duel-header { padding: 40px 0 28px; text-align: center; }
.duel-sub { color: var(--soft); font-size: 1rem; margin-top: 12px; max-width: 520px; margin-inline: auto; }

/* ── Arena ────────────────────────────────────────────────── */
.duel-arena {
  display: grid;
  grid-template-columns: 1fr 120px 1fr;
  gap: 24px;
  align-items: start;
  margin: 32px 0;
}
@media (max-width: 700px) {
  .duel-arena { grid-template-columns: 1fr; }
  .duel-center { order: -1; flex-direction: row; justify-content: center; gap: 16px; }
}

.duel-side {
  background: var(--bg2);
  border: 2px solid var(--border);
  border-radius: var(--radius);
  padding: 24px;
  transition: border-color 0.3s, box-shadow 0.3s;
}
.duel-side.winner {
  border-color: var(--red);
  box-shadow: 0 0 0 4px rgba(227,53,13,0.12);
}

.player-head { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
.player-dot { width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0; }
.player-dot.p1 { background: var(--red); }
.player-dot.p2 { background: #3b82f6; }
.player-head h2 { font-size: 1.1rem; margin: 0; }

.duel-inputs { display: flex; flex-direction: column; gap: 10px; }
.duel-input {
  width: 100%; padding: 12px 16px; font-size: 0.95rem;
  border: 1.5px solid var(--border); border-radius: var(--radius-sm);
  background: var(--bg); outline: none; transition: border-color 0.15s;
}
.duel-input:focus { border-color: var(--red); }

.duel-score {
  margin-top: 20px; padding: 16px;
  background: var(--cream); border-radius: var(--radius-sm);
  text-align: center;
}
.score-num { font-size: 2.4rem; font-weight: 900; color: var(--red); display: block; }
.score-label { font-size: 0.8rem; color: var(--soft); }
.hidden { display: none !important; }

/* ── Centre ───────────────────────────────────────────────── */
.duel-center {
  display: flex; flex-direction: column;
  align-items: center; gap: 16px; padding-top: 48px;
}
.vs-ball {
  width: 60px; height: 60px; border-radius: 50%; overflow: hidden;
  border: 3px solid var(--dark); box-shadow: var(--shadow);
}
.vs-ball__top { background: var(--red); height: 45%; }
.vs-ball__mid { background: #fff; height: 10%; }
.vs-ball__bot { background: #f0f0f0; height: 45%; }
.vs-text { font-size: 1.4rem; font-weight: 900; color: var(--soft); }

.btn-duel {
  width: 100%; padding: 14px 8px; font-size: 0.95rem; font-weight: 800;
  background: var(--red); color: #fff; border: none;
  border-radius: var(--radius); cursor: pointer;
  transition: background 0.15s, transform 0.15s;
  white-space: nowrap;
}
.btn-duel:hover { background: var(--red-dark); transform: translateY(-1px); }
.btn-reset {
  width: 100%; padding: 10px; font-size: 0.85rem; font-weight: 700;
  background: none; color: var(--soft); border: 1.5px solid var(--border);
  border-radius: var(--radius); cursor: pointer; transition: border-color 0.15s;
}
.btn-reset:hover { border-color: var(--red); color: var(--red); }

/* ── Résultat ─────────────────────────────────────────────── */
.duel-result { margin: 24px 0 40px; }

.result-banner {
  text-align: center; padding: 28px 24px;
  border-radius: var(--radius); margin-bottom: 24px;
  background: linear-gradient(135deg, var(--dark), #2d1b3d);
  color: #fff;
}
.result-banner.tie { background: linear-gradient(135deg, #3d405b, #6b6f8a); }
.result-msg { font-size: 1.4rem; font-weight: 800; margin-bottom: 10px; }
.result-score { font-size: 2rem; font-weight: 900; color: var(--yellow); }

.result-details { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
@media (max-width: 600px) { .result-details { grid-template-columns: 1fr; } }
.result-col { background: var(--bg2); border: 1.5px solid var(--border); border-radius: var(--radius); padding: 20px; }
.result-col h3 { margin-bottom: 16px; font-size: 1rem; }
.result-total { margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border); font-size: 0.9rem; text-align: right; }

.detail-row { padding: 10px 0; border-bottom: 1px solid var(--border); }
.detail-row:last-of-type { border-bottom: none; }
.detail-row.bonus { background: #fff8dc; border-radius: var(--radius-sm); padding: 10px 12px; margin: 4px 0; }
.detail-row.zero { opacity: 0.55; }
.detail-left { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
.detail-right { display: flex; justify-content: space-between; font-size: 0.82rem; color: var(--soft); margin-bottom: 6px; }
.detail-name { font-weight: 700; font-size: 0.95rem; }
.detail-bonus { font-size: 0.7rem; font-weight: 800; color: #a07800; background: #ffd700; padding: 2px 8px; border-radius: 999px; }
.detail-pts { font-weight: 800; }
.detail-pts.pos { color: var(--red); }
.detail-trainers { display: flex; flex-direction: column; gap: 4px; }
.mini-trainer {
  font-size: 0.75rem; color: var(--soft);
  padding: 3px 8px; background: var(--bg); border-radius: var(--radius-sm);
  transition: color 0.15s;
}
.mini-trainer:hover { color: var(--red); text-decoration: none; }

/* ── Règles ───────────────────────────────────────────────── */
.duel-rules {
  background: var(--cream); border-radius: var(--radius);
  padding: 24px 28px; margin: 24px 0;
}
.duel-rules h3 { margin-bottom: 12px; font-size: 1rem; }
.duel-rules ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
.duel-rules li { font-size: 0.9rem; color: var(--mid); }
</style>
