---
import Base from '../layouts/Base.astro';
import Search from '../components/Search.tsx';
import trainersRaw from '../data/trainers.json';
import '../styles/global.css';

const trainers = trainersRaw as any[];

// Top prénoms pour la section "Explorer"
const nameCount = new Map<string, number>();
for (const t of trainers) {
  nameCount.set(t.name, (nameCount.get(t.name) || 0) + 1);
}
const topNames = [...nameCount.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([name, count]) => ({ name, count, slug: name.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g,'') }));

const legendaryNames = [...nameCount.entries()]
  .filter(([, c]) => c === 1)
  .slice(0, 8)
  .map(([name]) => ({ name, slug: name.toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g,'') }));

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "PokéNom",
  "url": "https://pokenom.fr",
  "description": "Découvre si ton prénom existe chez un dresseur Pokémon.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://pokenom.fr/prenom/{search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<Base
  title="PokéNom — Trouve ton dresseur Pokémon"
  description="Tape ton prénom et découvre si un dresseur Pokémon le porte. 4 728 dresseurs issus de 17 jeux officiels. Légendaire, rare ou partout ?"
  schema={schema}
>
  <main id="main">

    <!-- HERO -->
    <section class="hero section">
      <div class="container">
        <div class="hero__inner">
          <div class="hero__text">
            <p class="hero__eyebrow">⚡ 4 728 dresseurs · 17 jeux</p>
            <h1>Quel dresseur <em>Pokémon</em> porte ton prénom ?</h1>
            <p class="hero__sub">
              Tape ton prénom et découvre ton alter ego dans l'univers Pokémon —
              et à quel point c'est <strong>rare</strong>.
            </p>
          </div>
          <div class="hero__ball" aria-hidden="true">
            <div class="pokeball">
              <div class="pokeball__top"></div>
              <div class="pokeball__center"></div>
              <div class="pokeball__bottom"></div>
            </div>
          </div>
        </div>

        <!-- Island interactif : hydraté côté client uniquement -->
        <Search client:load trainers={trainers} />
      </div>
    </section>

    <!-- PRÉNOMS LÉGENDAIRES -->
    <section class="section" style="background:var(--cream)">
      <div class="container">
        <h2>🏆 Prénoms légendaires</h2>
        <p style="color:var(--soft);margin:8px 0 24px">
          Un seul dresseur dans tout l'univers Pokémon porte ces prénoms.
        </p>
        <div class="chips-row">
          {legendaryNames.map(n => (
            <a href={`/prenom/${n.slug}`} class="name-chip name-chip--legendary">
              {n.name}
            </a>
          ))}
          <a href="/top/legendaires" class="name-chip name-chip--more">Voir tous →</a>
        </div>
      </div>
    </section>

    <!-- PRÉNOMS POPULAIRES -->
    <section class="section">
      <div class="container">
        <h2>🔥 Prénoms les plus communs</h2>
        <p style="color:var(--soft);margin:8px 0 24px">
          Ces prénoms ont le plus de dresseurs dans la base.
        </p>
        <div class="chips-row">
          {topNames.map(n => (
            <a href={`/prenom/${n.slug}`} class="name-chip">
              {n.name}
              <span class="name-chip__count">{n.count}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="section" style="background:var(--dark);color:#fff">
      <div class="container">
        <h2 style="color:#fff">La base en chiffres</h2>
        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-card__num">4 728</span>
            <span class="stat-card__label">dresseurs</span>
          </div>
          <div class="stat-card">
            <span class="stat-card__num">1 790</span>
            <span class="stat-card__label">prénoms distincts</span>
          </div>
          <div class="stat-card">
            <span class="stat-card__num">729</span>
            <span class="stat-card__label">prénoms légendaires</span>
          </div>
          <div class="stat-card">
            <span class="stat-card__num">17</span>
            <span class="stat-card__label">jeux couverts</span>
          </div>
        </div>
      </div>
    </section>

  </main>
</Base>

<style>
/* Hero */
.hero { background: linear-gradient(135deg, var(--dark) 0%, #2d1b3d 100%); color: #fff; padding: 72px 0 80px; }
.hero h1 { color: #fff; }
.hero h1 em { color: var(--yellow); font-style: normal; }
.hero__inner { display: flex; align-items: center; justify-content: space-between; gap: 48px; margin-bottom: 48px; }
.hero__eyebrow { font-size: 0.82rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--yellow); margin-bottom: 16px; }
.hero__sub { font-size: 1.1rem; color: rgba(255,255,255,0.75); margin-top: 16px; max-width: 480px; }
.hero__ball { flex-shrink: 0; }

/* Pokéball CSS */
.pokeball { width: 120px; height: 120px; border-radius: 50%; overflow: hidden; border: 4px solid rgba(255,255,255,0.3); box-shadow: 0 0 40px rgba(255,203,5,0.2); position: relative; animation: float 4s ease-in-out infinite; }
.pokeball__top    { background: var(--red); height: 50%; }
.pokeball__center { background: #fff; height: 8px; position: relative; z-index: 2; display: flex; align-items: center; justify-content: center; }
.pokeball__center::after { content: ''; width: 24px; height: 24px; background: #fff; border: 4px solid var(--dark); border-radius: 50%; position: absolute; box-shadow: 0 0 0 4px rgba(255,255,255,0.5); }
.pokeball__bottom { background: #f0f0f0; height: 42%; }
@keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }

/* Search island styles */
:global(.search-island) { max-width: 620px; }
:global(.search-form)   { display: flex; flex-direction: column; gap: 12px; }
:global(.search-input-wrap) { display: flex; gap: 10px; }
:global(.search-input) {
  flex: 1; padding: 16px 20px; font-size: 1.05rem;
  border: 2px solid rgba(255,255,255,0.2); border-radius: var(--radius);
  background: rgba(255,255,255,0.1); color: #fff; outline: none;
  transition: border-color 0.2s;
}
:global(.search-input::placeholder) { color: rgba(255,255,255,0.45); }
:global(.search-input:focus) { border-color: var(--yellow); background: rgba(255,255,255,0.15); }
:global(.search-btn) {
  padding: 16px 24px; font-size: 0.95rem; font-weight: 700;
  background: var(--red); color: #fff; border: none;
  border-radius: var(--radius); cursor: pointer; white-space: nowrap;
  transition: background 0.2s, transform 0.15s;
}
:global(.search-btn:hover) { background: var(--red-dark); transform: translateY(-1px); }
:global(.search-hints) { display: flex; flex-wrap: wrap; gap: 8px; }
:global(.hint-chip) {
  background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.85);
  border: 1px solid rgba(255,255,255,0.2); border-radius: 999px;
  padding: 5px 14px; font-size: 0.82rem; cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
:global(.hint-chip:hover) { background: rgba(255,255,255,0.22); color: #fff; }

/* Results */
:global(.search-results) { margin-top: 28px; }
:global(.results-header) { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 16px; }
:global(.results-count)  { color: rgba(255,255,255,0.8); font-size: 0.9rem; }
:global(.see-page-link)  { color: var(--yellow); font-size: 0.85rem; font-weight: 700; }
:global(.results-list)   { list-style: none; display: flex; flex-direction: column; gap: 8px; }
:global(.result-item) {
  display: flex; align-items: center; gap: 16px;
  background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius-sm); padding: 14px 18px;
  color: #fff; transition: background 0.15s;
}
:global(.result-item:hover) { background: rgba(255,255,255,0.14); text-decoration: none; }
:global(.result-item__left)  { flex: 1; display: flex; flex-direction: column; gap: 2px; }
:global(.result-item__right) { flex: 1; display: flex; flex-direction: column; gap: 2px; align-items: flex-end; }
:global(.result-class) { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--yellow); font-weight: 700; }
:global(.result-name)  { font-size: 1rem; font-weight: 800; }
:global(.result-game)  { font-size: 0.8rem; color: rgba(255,255,255,0.6); }
:global(.result-team)  { font-size: 0.75rem; color: rgba(255,255,255,0.45); }
:global(.result-arrow) { color: rgba(255,255,255,0.35); flex-shrink: 0; }
:global(.see-all-link) {
  display: block; text-align: center; padding: 14px;
  background: rgba(255,203,5,0.15); border: 1px solid var(--yellow);
  border-radius: var(--radius-sm); color: var(--yellow); font-weight: 700; font-size: 0.9rem;
}
:global(.see-all-link:hover) { background: rgba(255,203,5,0.25); text-decoration: none; }

/* Explorer */
.chips-row { display: flex; flex-wrap: wrap; gap: 10px; }
.name-chip {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 8px 18px; border-radius: 999px;
  background: var(--bg2); border: 1.5px solid var(--border);
  font-size: 0.88rem; font-weight: 600; color: var(--dark);
  transition: border-color 0.15s, transform 0.15s;
}
.name-chip:hover { border-color: var(--red); transform: translateY(-1px); text-decoration: none; }
.name-chip--legendary { border-color: #ffd700; background: #fff8dc; color: #a07800; }
.name-chip--more { background: var(--red); color: #fff; border-color: var(--red); }
.name-chip__count { background: var(--red); color: #fff; border-radius: 999px; padding: 1px 7px; font-size: 0.7rem; }

/* Stats */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 20px; margin-top: 32px; }
.stat-card { text-align: center; padding: 24px; background: rgba(255,255,255,0.06); border-radius: var(--radius); border: 1px solid rgba(255,255,255,0.08); }
.stat-card__num   { display: block; font-size: 2.4rem; font-weight: 900; color: var(--yellow); }
.stat-card__label { display: block; font-size: 0.82rem; color: rgba(255,255,255,0.55); margin-top: 4px; }

/* Utilities */
.sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);border:0; }

@media (max-width: 640px) {
  .hero__inner { flex-direction: column; gap: 32px; }
  .hero__ball { display: none; }
  :global(.search-input-wrap) { flex-direction: column; }
}
</style>
