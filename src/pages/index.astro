---
import Base from '../layouts/Base.astro';
import Search from '../components/Search.tsx';
import trainersRaw from '../data/trainers.json';
import '../styles/global.css';

const trainers = trainersRaw as any[];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "PokéNom",
  "url": "https://pokenom.fr",
  "description": "Découvre si ton prénom existe chez un dresseur Pokémon.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://pokenom.fr/prenom/{search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<Base
  title="PokéNom — Trouve ton dresseur Pokémon"
  description="Tape ton prénom et découvre si un dresseur Pokémon le porte. 4 728 dresseurs issus de 17 jeux officiels."
  schema={schema}
>
  <main id="main" class="home-main">

    <div class="home-center">
      <!-- Logo / titre -->
      <div class="home-brand">
        <div class="home-brand__ball" aria-hidden="true"></div>
        <span class="home-brand__name">PokéNom</span>
      </div>
      <p class="home-tagline">Ton prénom existe-t-il chez un dresseur Pokémon ?</p>

      <!-- Recherche -->
      <Search client:load trainers={trainers} />
    </div>

    <!-- Section discrète en bas -->
    <footer class="home-footer">
      <a href="/top/legendaires" class="home-link">🏆 Prénoms légendaires</a>
      <a href="/top/repandus"    class="home-link">🔥 Prénoms populaires</a>
      <span class="home-footer__sep">·</span>
      <span class="home-footer__info">4 728 dresseurs · 17 jeux</span>
    </footer>

  </main>
</Base>

<style>
/* Page entière centrée verticalement */
.home-main {
  min-height: calc(100vh - var(--nav-h));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 24px 80px;
}

/* Bloc central */
.home-center {
  width: 100%;
  max-width: 580px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20px;
}

/* Brand */
.home-brand {
  display: flex;
  align-items: center;
  gap: 10px;
}
.home-brand__ball {
  width: 28px; height: 28px; border-radius: 50%;
  background: linear-gradient(180deg, var(--red) 50%, #fff 50%);
  border: 2.5px solid var(--text);
  flex-shrink: 0;
}
.home-brand__name {
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--text);
  letter-spacing: -0.03em;
}

/* Tagline */
.home-tagline {
  font-size: 1rem;
  color: var(--text-soft);
  text-align: center;
  margin-top: -8px;
}

/* Search island override — styles légers sur fond clair */
:global(.search-island) { width: 100%; }
:global(.search-form)   { display: flex; flex-direction: column; gap: 10px; }

:global(.search-input-wrap) {
  display: flex;
  position: relative; /* contexte pour le dropdown autocomplete */
  background: var(--bg2);
  border: 1.5px solid var(--border);
  border-radius: 999px;
  /* overflow:visible — le dropdown autocomplete doit déborder */
  transition: border-color 0.2s, box-shadow 0.2s;
  box-shadow: var(--shadow-sm);
}
:global(.search-input-wrap:focus-within) {
  border-color: var(--border-focus);
  box-shadow: 0 0 0 3px rgba(192,191,232,0.35);
}

:global(.search-input) {
  flex: 1;
  padding: 14px 20px;
  font-size: 1rem;
  border: none;
  background: transparent;
  color: var(--text);
  outline: none;
  border-radius: 999px 0 0 999px; /* arrondi gauche car overflow:visible sur le parent */
}
:global(.search-input::placeholder) { color: var(--text-soft); }

:global(.search-btn) {
  padding: 10px 20px;
  margin: 5px;
  font-size: 0.88rem;
  font-weight: 700;
  background: var(--red);
  color: #fff;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.15s;
  flex-shrink: 0;
}
:global(.search-btn:hover) { background: var(--red-dark); }

/* Hints */
:global(.search-hints) {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6px;
}
:global(.hint-chip) {
  background: transparent;
  color: var(--text-soft);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 4px 13px;
  font-size: 0.8rem;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
  font-family: var(--font);
}
:global(.hint-chip:hover) {
  border-color: var(--border-focus);
  color: var(--text);
  background: var(--bg);
}

/* Results */
:global(.search-results) { width: 100%; margin-top: 16px; }
:global(.results-header) {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}
:global(.results-count)  { color: var(--text-mid); font-size: 0.88rem; }
:global(.see-page-link)  { color: var(--red); font-size: 0.82rem; font-weight: 600; margin-left: auto; }

:global(.results-list)   { list-style: none; display: flex; flex-direction: column; gap: 6px; }
:global(.result-item) {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12px 16px;
  color: var(--text);
  transition: border-color 0.15s, box-shadow 0.15s;
}
:global(.result-item:hover) {
  border-color: var(--border-focus);
  box-shadow: var(--shadow-sm);
  text-decoration: none;
}
:global(.result-item__left)  { flex: 1; display: flex; flex-direction: column; gap: 1px; }
:global(.result-item__right) { display: flex; flex-direction: column; gap: 1px; align-items: flex-end; }
:global(.result-class) { font-size: 0.67rem; text-transform: uppercase; letter-spacing: 0.09em; color: var(--red); font-weight: 700; }
:global(.result-name)  { font-size: 0.95rem; font-weight: 700; color: var(--text); }
:global(.result-game)  { font-size: 0.78rem; color: var(--text-soft); }
:global(.result-team)  { font-size: 0.72rem; color: var(--text-soft); }
:global(.result-arrow) { color: var(--border-focus); font-size: 0.85rem; flex-shrink: 0; }

:global(.see-all-link) {
  display: block;
  text-align: center;
  padding: 11px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--red);
  font-weight: 600;
  font-size: 0.88rem;
  transition: border-color 0.15s, background 0.15s;
}
:global(.see-all-link:hover) { border-color: var(--border-focus); background: var(--red-soft); text-decoration: none; }

/* Autocomplete */
:global(.autocomplete-list) {
  position: absolute;
  top: calc(100% + 6px);
  left: 0; right: 0;
  background: var(--bg2);
  border: 1.5px solid var(--border-focus);
  border-radius: var(--radius);
  box-shadow: var(--shadow-md, 0 8px 24px rgba(0,0,0,.12));
  list-style: none;
  z-index: 100;
  overflow: hidden;
  max-height: 280px;
  overflow-y: auto;
}
:global(.autocomplete-item) {
  padding: 10px 20px;
  font-size: 0.95rem;
  color: var(--text);
  cursor: pointer;
  transition: background 0.1s;
}
:global(.autocomplete-item:hover),
:global(.autocomplete-item--active) {
  background: var(--red-soft, rgba(220,38,38,.07));
  color: var(--red);
}
:global(.autocomplete-match) {
  font-weight: 700;
  color: var(--red);
}

/* Footer discret */
.home-footer {
  position: fixed;
  bottom: 24px;
  display: flex;
  align-items: center;
  gap: 14px;
  font-size: 0.8rem;
  color: var(--text-soft);
}
.home-link {
  color: var(--text-soft);
  transition: color 0.15s;
}
.home-link:hover { color: var(--text); text-decoration: none; }
.home-footer__sep { opacity: 0.3; }
.home-footer__info { opacity: 0.55; }

:global(.sr-only) { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0); }

@media (max-width: 640px) {
  .home-main { justify-content: flex-start; padding-top: 60px; }
  .home-footer { position: static; margin-top: 40px; flex-wrap: wrap; justify-content: center; }
  :global(.search-input-wrap) { border-radius: var(--radius); }
  :global(.search-input) { border-radius: var(--radius) 0 0 var(--radius); }
  :global(.search-btn) { border-radius: var(--radius-xs); }
}
</style>
