---
import Base from '../../layouts/Base.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import trainersRaw from '../../data/trainers.json';
import { placeLabel } from '../../utils/slug';
import '../../styles/global.css';

export async function getStaticPaths() {
  const trainers = (trainersRaw as any[]).filter(t => t.place_slug);
  const bySlug = new Map<string, { name: string; trainers: any[] }>();
  for (const t of trainers) {
    if (!bySlug.has(t.place_slug)) bySlug.set(t.place_slug, { name: t.place, trainers: [] });
    bySlug.get(t.place_slug)!.trainers.push(t);
  }
  return [...bySlug.entries()].map(([slug, data]) => ({
    params: { slug },
    props: { slug, placeName: data.name, trainers: data.trainers },
  }));
}

const { placeName, trainers } = Astro.props as { slug: string; placeName: string; trainers: any[] };
const displayPlace = placeLabel(placeName);
const count = trainers.length;
const games = [...new Set(trainers.map((t: any) => t.game))];

const title = `Dresseurs à ${displayPlace} — ${count} dresseurs | PokéNom`;
const description = `${count} dresseur${count>1?'s':''} sur ${displayPlace} dans ${games.join(', ')}. Retrouvez leurs prénoms et leurs équipes Pokémon.`;
---
<Base title={title} description={description} canonical={`https://pokenom.fr/lieu/${Astro.params.slug}`}>
  <main id="main" class="container">
    <Breadcrumb crumbs={[{ label: 'Accueil', href: '/' }, { label: displayPlace }]} />
    <header class="page-header">
      <div class="game-badge">📍 Lieu</div>
      <h1>{displayPlace}</h1>
      <p class="page-sub">{count} dresseur{count>1?'s':''} · {games.map((g: string) => g.replace('Pokémon ','')).join(', ')}</p>
    </header>
    <AdSlot slot="5466423598" format="auto" />
    <section class="section-block">
      <h2>Dresseurs rencontrés ici</h2>
      <div class="cards-grid" style="margin-top:16px">
        {trainers.slice(0,6).map((t: any) => <TrainerCard trainer={t} />)}
      </div>
      {count > 6 && (
        <>
          <AdSlot slot="2840260251" format="fluid" layout="in-article" />
          <div class="cards-grid" style="margin-top:16px">
            {trainers.slice(6).map((t: any) => <TrainerCard trainer={t} />)}
          </div>
        </>
      )}
    </section>
    <AdSlot slot="1708205042" format="auto" />
  </main>
</Base>
<style>
.page-header { padding:36px 0 28px; border-bottom:1.5px solid var(--border); margin-bottom:32px; }
.game-badge { font-size:0.7rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--red); margin-bottom:8px; }
.page-sub { color:var(--soft); margin-top:8px; }
.section-block { margin:32px 0; }
.section-block h2 { margin-bottom:14px; }
</style>
