---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import { toPokemonSlug } from '../../utils/slug';
import '../../styles/global.css';

// ── Traductions UI + jeux ──
let translationsRaw: Record<string, any> = {};
try {
  const mod = await import('../../data/translations.json');
  translationsRaw = mod.default as Record<string, any>;
} catch {}
const gamesMap: Record<string, Record<string, string>> = (translationsRaw['games'] ?? {}) as Record<string, Record<string, string>>;

// ── Données items-meta.json (optionnel — lance fetch-items.py pour l'obtenir) ──
let itemsMeta: Record<string, any> = {};
try {
  const mod = await import('../../data/items-meta.json');
  itemsMeta = mod.default as Record<string, any>;
} catch { /* fichier optionnel */ }

// ── items-i18n.json (toujours présent) ──
let itemsI18n: Record<string, Record<string, string>> = {};
try {
  const mod = await import('../../data/items-i18n.json');
  itemsI18n = mod.default as Record<string, Record<string, string>>;
} catch { /* fichier optionnel */ }

// ── pokemon-meta.json (pour les sprites des porteurs) ──
let pokemonMeta: Record<string, any> = {};
try {
  const mod = await import('../../data/pokemon-meta.json');
  pokemonMeta = mod.default as Record<string, any>;
} catch { /* fichier optionnel */ }

export async function getStaticPaths() {
  // Charge les deux sources de slugs
  let metaSlugs: Set<string> = new Set();
  let i18nSlugs: Set<string> = new Set();

  try {
    const mod = await import('../../data/items-meta.json');
    metaSlugs = new Set(Object.keys(mod.default as Record<string, any>));
  } catch {}

  try {
    const mod = await import('../../data/items-i18n.json');
    i18nSlugs = new Set(Object.keys(mod.default as Record<string, any>));
  } catch {}

  const allSlugs = new Set([...metaSlugs, ...i18nSlugs]);

  return [...allSlugs].map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params as { slug: string };

// ── Données de l'objet ──
const meta = itemsMeta[slug] ?? null;
const i18n  = itemsI18n[slug]  ?? null;

// Nom (fr en priorité, sinon slug humanisé)
const nameFr = meta?.names?.fr ?? i18n?.fr ?? slug.replace(/-/g, ' ');
const namesI18nData = meta?.names ?? (i18n ? { fr: i18n.fr, en: i18n.en, de: i18n.de, es: i18n.es, ja: i18n.ja } : null);

// Sprite
const spriteUrl = (meta?.sprite ?? null) as string | null;

// Infos générales
const cost        = meta?.cost     as number | null ?? null;
const category    = (meta?.category ?? '') as string;
const attributes  = (meta?.attributes ?? []) as string[];
const effectEn    = (meta?.effect_en      ?? '') as string;
const effectLongEn = (meta?.effect_long_en ?? '') as string;
const flingPower  = meta?.fling_power  as number | null ?? null;
const flingEffect = (meta?.fling_effect_en ?? null) as string | null;
const generations = (meta?.generations ?? []) as string[];
const heldBy      = (meta?.held_by ?? []) as { slug: string; rarity: number }[];

// Descriptions par langue/jeu (flavors)
const flavors = (meta?.flavors ?? {}) as Record<string, Record<string, string>>;

// Catégorie lisible
const CATEGORY_FR: Record<string, string> = {
  'held-items':               'Objet tenu',
  'choice':                   'Choix',
  'bad-held-items':           'Objet tenu négatif',
  'type-enhancement':         'Boost de type',
  'plates':                   'Plaques',
  'memories':                 'Mémoires',
  'jewels':                   'Joyaux',
  'mega-stones':              'Méga-Gemmes',
  'z-crystals':               'Z-Cristaux',
  'berries':                  'Baies',
  'in-a-pinch-berries':       'Baies de secours',
  'picky-healing-berries':    'Baies de soin',
  'type-protection-berries':  'Baies de protection',
  'effort-drop':              "Réducteur d'EV",
  'species-specific':         "Spécifique à l'espèce",
  'loot':                     'Butin',
  'collectibles':             'Objet à vendre',
  'medicine':                 'Médecine',
  'baked-goods':              'Pâtisseries',
  'all-mail':                 'Courrier',
  'stat-boosts':              'Boost de statistique',
  'scarves':                  'Écharpes',
  'flutes':                   'Flûtes',
  'other':                    'Autre',
};
const categoryLabel = CATEGORY_FR[category] ?? category.replace(/-/g, ' ');

// Générations lisibles (I, II, III...)
const GEN_LABEL: Record<string, string> = {
  i:'I', ii:'II', iii:'III', iv:'IV', v:'V', vi:'VI', vii:'VII', viii:'VIII', ix:'IX',
};

// Map slug anglais Pokémon → nom français
const slugToFrPokemon: Record<string, string> = {};
for (const [frName, d] of Object.entries(pokemonMeta as Record<string, any>)) {
  if (d?.slug) slugToFrPokemon[d.slug] = frName;
}

// Helper noms Pokémon multilingues (pour data-pkm-names)
function pkmNamesAttr(frName: string): string | undefined {
  const intl = (pokemonMeta[frName] as any)?.names_intl;
  if (!intl) return undefined;
  return Object.entries(intl as Record<string, string>).map(([l, n]) => `${l}:${n}`).join('|');
}

// Sprite Pokémon helper
const SPRITE_BASE_PKM = 'https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon';

// Données i18n à injecter pour le client JS
const itemI18nPayload = {
  names:        namesI18nData ?? { fr: nameFr, en: nameFr, de: nameFr, es: nameFr, ja: nameFr },
  flavors:      flavors,
  effect_en:    effectEn,
  effect_long_en: effectLongEn,
  category:     category,
  games_map:    gamesMap,
};

// SEO
const title       = `${nameFr} — Objet Pokémon | Le Dresseur en Moi`;
const description = effectEn
  ? `${nameFr} : ${effectEn} ${cost !== null ? `Prix : ${cost}₽.` : ''}`
  : `Tout savoir sur l'objet ${nameFr} dans les jeux Pokémon.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Thing",
  "name": nameFr,
  "description": description,
  "url": `https://ledresseurenmoi.com/objet/${slug}`,
  ...(spriteUrl ? { "image": spriteUrl } : {}),
};
---

<Base
  title={title}
  description={description}
  canonical={`https://ledresseurenmoi.com/objet/${slug}`}
  ogImage={spriteUrl ?? '/img/pages/og-default.png'}
  schema={schema}
>
  <!-- Données i18n injectées pour le switch JS côté client — doit être DANS Base pour que meta charset soit lu avant -->
  <div id="item-i18n-data" style="display:none" aria-hidden="true" set:text={JSON.stringify(itemI18nPayload)} />
  <main id="main" class="container">
    <span id="page-title-i18n" style="display:none" data-name-el="item-name" data-name-fr={nameFr} data-suffix-key="title.suffix.item" />
    <Breadcrumb crumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Objets', href: '/' },
      { label: nameFr, pkmNames: namesI18nData ? Object.entries(namesI18nData as Record<string,string>).map(([l,n]) => `${l}:${n}`).join('|') : undefined },
    ]} />

    <!-- ── En-tête ── -->
    <header class="item-header">
      <div class="item-header__visual">
        {spriteUrl ? (
          <img
            src={spriteUrl}
            alt={`Sprite de ${nameFr}`}
            class="item-sprite"
            width="96" height="96"
            loading="eager"
          />
        ) : (
          <div class="item-sprite item-sprite--placeholder" aria-hidden="true">?</div>
        )}
      </div>

      <div class="item-header__info">
        {categoryLabel && <p class="item-category-badge" id="item-category-badge" data-category={category}>{categoryLabel}</p>}
        <h1 id="item-name">{nameFr}</h1>

        <dl class="item-quick-facts">
          {cost !== null && cost > 0 && (
            <><dt data-i18n-ui="item-price">Prix</dt><dd class="item-price">{cost.toLocaleString('fr-FR')} ₽</dd></>
          )}
          {flingPower !== null && (
            <><dt data-i18n-ui="item-fling">Lancer</dt><dd>{flingPower} {flingEffect ? `— ${flingEffect}` : ''}</dd></>
          )}
          {generations.length > 0 && (
            <><dt data-i18n-ui="item-generations">Disponible dans</dt>
            <dd>{generations.map(g => GEN_LABEL[g] ?? g.toUpperCase()).join(', ')}</dd></>
          )}
        </dl>
      </div>
    </header>

    <AdSlot slot="5466423598" format="auto" />

    <!-- ── Effet ── -->
    {(effectEn || effectLongEn) && (
      <section class="item-section">
        <h2 data-i18n-ui="item-effect">Effet</h2>
        <div class="item-effect-box">
          <p class="item-effect-lang-badge" id="item-effect-lang-badge" style="display:none">🇬🇧 EN</p>
          <p id="item-effect-short" class="item-effect-short">{effectEn}</p>
          {effectLongEn && effectLongEn !== effectEn && (
            <details>
              <summary data-i18n-ui="item-effect-detail">Détail complet</summary>
              <p id="item-effect-long" class="item-effect-long">{effectLongEn}</p>
            </details>
          )}
        </div>
      </section>
    )}
    {!effectEn && !effectLongEn && meta && (
      <section class="item-section">
        <h2 data-i18n-ui="item-effect">Effet</h2>
        <p class="item-soft" data-i18n-ui="item-no-effect">Aucun effet renseigné.</p>
      </section>
    )}

    <!-- ── Descriptions par jeu ── -->
    {Object.keys(flavors).some(lang => Object.keys(flavors[lang] ?? {}).length > 0) && (
      <section class="item-section">
        <h2 data-i18n-ui="item-descriptions">Descriptions par jeu</h2>
        <div id="item-flavors-container">
          {/* Rendu FR par défaut — remplacé par JS selon langue */}
          {Object.entries(flavors.fr ?? {}).length > 0 ? (
            <dl class="item-flavors-list" id="item-flavors-list">
              {Object.entries(flavors.fr ?? {}).map(([game, text]) => (
                <div class="flavor-entry">
                  <dt class="flavor-game">{game}</dt>
                  <dd class="flavor-text">{text}</dd>
                </div>
              ))}
            </dl>
          ) : (
            <dl class="item-flavors-list" id="item-flavors-list">
              {Object.entries(Object.values(flavors).find(l => Object.keys(l).length > 0) ?? {}).map(([game, text]) => (
                <div class="flavor-entry">
                  <dt class="flavor-game">{game}</dt>
                  <dd class="flavor-text">{text as string}</dd>
                </div>
              ))}
            </dl>
          )}
        </div>
      </section>
    )}

    <!-- ── Pokémon porteurs ── -->
    <section class="item-section">
      <h2 data-i18n-ui="item-held-by">Porté par des Pokémon</h2>
      {heldBy.length === 0 ? (
        <p class="item-soft" data-i18n-ui="item-no-held">Aucun Pokémon sauvage ne porte cet objet.</p>
      ) : (
        <div class="held-by-grid">
          {heldBy.map(h => {
            const frName = slugToFrPokemon[h.slug] ?? h.slug.replace(/-/g, ' ');
            const pkmSlug = toPokemonSlug(frName);
            const pkmData = pokemonMeta[frName] as { sprite?: string; id?: number } | undefined;
            const sprite  = pkmData?.sprite ?? `${SPRITE_BASE_PKM}/${pkmData?.id ?? ''}.png`;
            return (
              <a href={`/pokemon/${pkmSlug}`} class="held-by-card" title={`${frName} (${h.rarity}%)`}>
                {pkmData?.id ? (
                  <img
                    src={sprite}
                    alt={frName}
                    width="56" height="56"
                    loading="lazy"
                    onerror="this.style.opacity='0.3'"
                  />
                ) : (
                  <div class="held-by-card__no-sprite">?</div>
                )}
                <span class="held-by-card__name" data-pkm-names={pkmNamesAttr(frName) || undefined}>{frName}</span>
                {h.rarity > 0 && <span class="held-by-card__rarity">{h.rarity}%</span>}
              </a>
            );
          })}
        </div>
      )}
    </section>

    {heldBy.length > 3 && <AdSlot slot="2840260251" format="fluid" layout="in-article" />}

    <!-- ── Attributs techniques ── -->
    {attributes.length > 0 && (
      <section class="item-section item-section--compact">
        <h2>Attributs</h2>
        <div class="item-tags">
          {attributes.map(attr => (
            <span class="item-tag">{attr.replace(/-/g, ' ')}</span>
          ))}
        </div>
      </section>
    )}

    <AdSlot slot="1708205042" format="auto" />
  </main>
</Base>

<script>
  // ── Lecture des données i18n injectées ──────────────────────────
  const raw = document.getElementById('item-i18n-data')?.textContent ?? '{}';
  let data: {
    names: Record<string, string>;
    flavors: Record<string, Record<string, string>>;
    effect_en: string;
    effect_long_en: string;
    category: string;
    games_map: Record<string, Record<string, string>>;
  };
  try {
    data = JSON.parse(raw);
  } catch {
    data = { names: {}, flavors: {}, effect_en: '', effect_long_en: '', category: '', games_map: {} };
  }

  // ── Catégories d'objets (toutes langues) ──────────────────────
  const CATEGORY_I18N: Record<string, Record<string, string>> = {
    'held-items':              { fr:'Objet tenu',         en:'Held item',           de:'Gehaltenes Item',       es:'Objeto equipado',         ja:'持ち物',         it:'Oggetto tenuto',        ko:'지닌 도구',      'zh-Hans':'携带道具',   'zh-Hant':'攜帶道具',   'pt-BR':'Item segurado'         },
    'choice':                  { fr:'Choix',              en:'Choice item',          de:'Wahl-Item',             es:'Objeto de elección',      ja:'きのみ',         it:'Oggetto scelta',        ko:'선택 도구',      'zh-Hans':'选择道具',   'zh-Hant':'選擇道具',   'pt-BR':'Item de escolha'       },
    'bad-held-items':          { fr:'Objet tenu négatif', en:'Bad held item',        de:'Negatives Item',        es:'Objeto perjudicial',      ja:'悪い持ち物',      it:'Oggetto negativo',      ko:'악성 도구',      'zh-Hans':'负面道具',   'zh-Hant':'負面道具',   'pt-BR':'Item prejudicial'      },
    'type-enhancement':        { fr:'Boost de type',      en:'Type boost',           de:'Typ-Boost',             es:'Potenciador de tipo',     ja:'タイプ強化',      it:'Potenziamento tipo',    ko:'타입 강화',      'zh-Hans':'属性强化',   'zh-Hant':'屬性強化',   'pt-BR':'Boost de tipo'         },
    'plates':                  { fr:'Plaques',             en:'Plates',               de:'Platten',               es:'Placas',                  ja:'プレート',        it:'Lastre',                ko:'플레이트',       'zh-Hans':'石板',       'zh-Hant':'石板',       'pt-BR':'Placas'                },
    'memories':                { fr:'Mémoires',            en:'Memories',             de:'Speicher',              es:'Memorias',                ja:'メモリ',          it:'Memorie',               ko:'메모리',         'zh-Hans':'记忆碟',     'zh-Hant':'記憶碟',     'pt-BR':'Memórias'              },
    'jewels':                  { fr:'Joyaux',              en:'Gems',                 de:'Juwelen',               es:'Gemas',                   ja:'ジュエル',        it:'Gemme',                 ko:'보석',           'zh-Hans':'宝石',       'zh-Hant':'寶石',       'pt-BR':'Gemas'                 },
    'mega-stones':             { fr:'Méga-Gemmes',         en:'Mega Stones',          de:'Mega-Steine',           es:'Mega Piedras',            ja:'メガストーン',    it:'Megapietra',            ko:'메가돌',         'zh-Hans':'究极之石',   'zh-Hant':'究極之石',   'pt-BR':'Mega Pedras'           },
    'z-crystals':              { fr:'Z-Cristaux',          en:'Z-Crystals',           de:'Z-Kristalle',           es:'Z-Cristales',             ja:'Zクリスタル',    it:'Z-Cristalli',           ko:'Z크리스탈',     'zh-Hans':'Z纯晶',      'zh-Hant':'Z純晶',      'pt-BR':'Z-Cristais'            },
    'berries':                 { fr:'Baies',               en:'Berries',              de:'Beeren',                es:'Bayas',                   ja:'きのみ',          it:'Bacche',                ko:'열매',           'zh-Hans':'树果',       'zh-Hant':'樹果',       'pt-BR':'Frutas'                },
    'in-a-pinch-berries':      { fr:'Baies de secours',   en:'Pinch berries',        de:'Notfall-Beeren',        es:'Bayas de emergencia',     ja:'ピンチのみ',      it:'Bacche emergenza',      ko:'위기 열매',      'zh-Hans':'危机树果',   'zh-Hant':'危機樹果',   'pt-BR':'Frutas emergência'     },
    'picky-healing-berries':   { fr:'Baies de soin',      en:'Healing berries',      de:'Heil-Beeren',           es:'Bayas curativas',         ja:'回復のきのみ',    it:'Bacche curative',       ko:'회복 열매',      'zh-Hans':'恢复树果',   'zh-Hant':'恢復樹果',   'pt-BR':'Frutas curativas'      },
    'type-protection-berries': { fr:'Baies de protection',en:'Protection berries',   de:'Schutz-Beeren',         es:'Bayas protectoras',       ja:'守りのきのみ',    it:'Bacche protettive',     ko:'방어 열매',      'zh-Hans':'防御树果',   'zh-Hant':'防禦樹果',   'pt-BR':'Frutas protetoras'     },
    'effort-drop':             { fr:"Réducteur d'EV",     en:'EV reducer',           de:'EP-Reduzierer',         es:'Reductor de EV',          ja:'努力値下げ',      it:'Riduttore PS',          ko:'노력치 감소',    'zh-Hans':'努力值减少', 'zh-Hant':'努力值減少', 'pt-BR':'Redutor de EV'         },
    'species-specific':        { fr:"Spécifique à l'espèce",en:'Species-specific',   de:'Artspezifisch',         es:'Específico de especie',   ja:'種族特有',        it:'Specifico specie',      ko:'종족 전용',      'zh-Hans':'种族专用',   'zh-Hant':'種族專用',   'pt-BR':'Específico de espécie' },
    'loot':                    { fr:'Butin',               en:'Loot',                 de:'Beute',                 es:'Botín',                   ja:'落し物',          it:'Bottino',               ko:'전리품',         'zh-Hans':'战利品',     'zh-Hant':'戰利品',     'pt-BR':'Saque'                 },
    'collectibles':            { fr:'Objet à vendre',     en:'Collectible',          de:'Sammelgegenstand',      es:'Coleccionable',           ja:'売りもの',        it:'Vendibile',             ko:'수집품',         'zh-Hans':'可售道具',   'zh-Hant':'可售道具',   'pt-BR':'Colecionável'          },
    'medicine':                { fr:'Médecine',            en:'Medicine',             de:'Medizin',               es:'Medicina',                ja:'薬',              it:'Medicina',              ko:'의약품',         'zh-Hans':'药品',       'zh-Hant':'藥品',       'pt-BR':'Medicina'              },
    'baked-goods':             { fr:'Pâtisseries',         en:'Baked goods',          de:'Backwaren',             es:'Productos horneados',     ja:'焼き菓子',        it:'Dolci',                 ko:'제과류',         'zh-Hans':'烘焙食品',   'zh-Hant':'烘焙食品',   'pt-BR':'Produtos de padaria'   },
    'all-mail':                { fr:'Courrier',            en:'Mail',                 de:'Post',                  es:'Correo',                  ja:'メール',          it:'Posta',                 ko:'메일',           'zh-Hans':'邮件',       'zh-Hant':'郵件',       'pt-BR':'Correio'               },
    'stat-boosts':             { fr:'Boost de statistique',en:'Stat boost',          de:'Stat-Boost',            es:'Potenciador de estadística',ja:'ステータス強化', it:'Potenziamento stat',    ko:'능력치 강화',    'zh-Hans':'能力强化',   'zh-Hant':'能力強化',   'pt-BR':'Boost de estatística'  },
    'scarves':                 { fr:'Écharpes',            en:'Scarves',              de:'Schals',                es:'Bufandas',                ja:'バンダナ',        it:'Sciarpe',               ko:'스카프',         'zh-Hans':'围巾',       'zh-Hant':'圍巾',       'pt-BR':'Lenços'                },
    'flutes':                  { fr:'Flûtes',              en:'Flutes',               de:'Flöten',                es:'Flautas',                 ja:'笛',              it:'Flauti',                ko:'피리',           'zh-Hans':'笛子',       'zh-Hant':'笛子',       'pt-BR':'Flautas'               },
    'other':                   { fr:'Autre',               en:'Other',                de:'Sonstiges',             es:'Otro',                    ja:'その他',          it:'Altro',                 ko:'기타',           'zh-Hans':'其他',       'zh-Hant':'其他',       'pt-BR':'Outro'                 },
  };

  // ── Détection de langue ────────────────────────────────────────
  function detectLang(): string {
    const supported = ['fr', 'en', 'de', 'es', 'ja', 'it', 'ko', 'zh-Hans', 'zh-Hant', 'pt-BR'];
    const saved = localStorage.getItem('ldresseurenmoi_lang');
    if (saved && supported.includes(saved)) return saved;
    for (const l of (navigator.languages ?? [navigator.language])) {
      const lower = l.toLowerCase();
      if (lower === 'zh-hant' || lower.startsWith('zh-tw') || lower.startsWith('zh-hk')) return 'zh-Hant';
      if (lower.startsWith('zh')) return 'zh-Hans';
      if (lower.startsWith('pt')) return 'pt-BR';
      const short = lower.split('-')[0];
      const match = supported.find(s => s.split('-')[0] === short);
      if (match) return match;
    }
    return 'fr';
  }

  // ── Traduit un nom de jeu (clé FR courte → langue cible) ────────
  // Les clés flavors sont des noms courts ("X et Y") ; games_map a des clés longues ("Pokémon X et Y").
  function translateGame(frName: string, lang: string): string {
    if (lang === 'fr') return frName;
    const gm = data.games_map ?? {};
    // 1. Lookup direct (nom court déjà dans la map)
    const direct = gm[frName]?.[lang] ?? gm[frName]?.['en'];
    if (direct) return direct;
    // 2. Essai avec préfixe "Pokémon " ; on retire le préfixe du résultat
    const withPrefix = 'Pokémon ' + frName;
    const withPfxResult = gm[withPrefix]?.[lang] ?? gm[withPrefix]?.['en'];
    if (withPfxResult) return withPfxResult.replace(/^Pokémon\s+/, '');
    // 3. Fallback : nom français tel quel
    return frName;
  }

  // ── Application de la langue ───────────────────────────────────
  function applyItemLang(lang: string) {
    // Badge catégorie
    const catBadge = document.getElementById('item-category-badge');
    if (catBadge && data.category) {
      const catLabel = CATEGORY_I18N[data.category]?.[lang] ?? CATEGORY_I18N[data.category]?.['fr'];
      if (catLabel) catBadge.textContent = catLabel;
    }

    // Nom de l'objet
    const nameEl = document.getElementById('item-name');
    if (nameEl && data.names[lang]) {
      nameEl.textContent = data.names[lang];
    }

    // Descriptions par jeu
    const flavorsList = document.getElementById('item-flavors-list');
    if (flavorsList) {
      const langFlavors = data.flavors?.[lang] ?? data.flavors?.['fr'] ?? data.flavors?.['en'] ?? {};
      // Les clés des flavors sont en FR — on traduit le nom du jeu
      const sourceLang = data.flavors?.[lang] ? lang : (data.flavors?.['fr'] ? 'fr' : 'en');
      const entries = Object.entries(langFlavors);
      if (entries.length > 0) {
        flavorsList.innerHTML = entries.map(([game, text]) => {
          // Les clés de flavors sont toujours en FR — on traduit dans tous les cas
          const gameLabel = translateGame(game, lang);
          return `<div class="flavor-entry"><dt class="flavor-game">${gameLabel}</dt><dd class="flavor-text">${text}</dd></div>`;
        }).join('');
      }
    }

    // Effet — uniquement EN disponible, on affiche un badge si la langue n'est pas EN
    const badge = document.getElementById('item-effect-lang-badge');
    if (badge) badge.style.display = (lang !== 'en' && lang !== 'fr') ? '' : 'none';
  }

  // ── Init ──────────────────────────────────────────────────────
  const lang = detectLang();
  applyItemLang(lang);

  // Écoute les changements de langue depuis Base.astro
  document.addEventListener('pokenom-lang-change', (e: Event) => {
    applyItemLang((e as CustomEvent<string>).detail);
  });
</script>

