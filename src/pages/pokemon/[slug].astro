---
import Base from '../../layouts/Base.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import trainersRaw from '../../data/trainers.json';
import { toPokemonSlug } from '../../utils/slug';
import { sortPokedexEntries } from '../../utils/games';
// toPokemonSlug utilisé aussi côté serveur pour les liens d'évolution
import '../../styles/global.css';

// Charger les métadonnées PokéAPI si disponibles
let pokemonMeta: Record<string, any> = {};
try {
  const mod = await import('../../data/pokemon-meta.json');
  pokemonMeta = mod.default as Record<string, any>;
} catch { /* fichier optionnel — lance fetch-pokemon.py pour l'obtenir */ }

// Objets tenus traduits (optionnel — lance fetch-items.py)
let itemsI18n: Record<string, Record<string, string>> = {};
try {
  const mod = await import('../../data/items-i18n.json');
  itemsI18n = mod.default as Record<string, Record<string, string>>;
} catch { /* fichier optionnel */ }

// Cartes TCG (optionnel — lance fetch-tcg.py)
let pokemonTcg: Record<string, any[]> = {};
try {
  const mod = await import('../../data/pokemon-tcg.json');
  pokemonTcg = mod.default as Record<string, any[]>;
} catch { /* fichier optionnel */ }

export async function getStaticPaths() {
  const trainers = trainersRaw as any[];
  const bySlug = new Map<string, { name: string; trainers: any[] }>();

  for (const t of trainers) {
    for (const pkm of (t.team ?? [])) {
      const slug = toPokemonSlug(pkm);
      if (!bySlug.has(slug)) bySlug.set(slug, { name: pkm, trainers: [] });
      bySlug.get(slug)!.trainers.push(t);
    }
  }

  return [...bySlug.entries()].map(([slug, data]) => ({
    params: { slug },
    props: { slug, pokemonName: data.name, trainers: data.trainers },
  }));
}

const { slug, pokemonName, trainers } = Astro.props as {
  slug: string;
  pokemonName: string;
  trainers: any[];
};

const meta     = pokemonMeta[pokemonName] ?? null;
const tcgCards = pokemonTcg[meta?.slug ?? slug] ?? [];

// Sprites
const spriteUrl          = meta?.sprite_hd ?? meta?.sprite ?? null;
const spriteShinyUrl     = (meta?.sprite_hd_shiny ?? meta?.sprite_shiny ?? null) as string | null;
const spriteAnimUrl      = (meta?.sprite_anim ?? null) as string | null;
const spriteAnimShinyUrl = (meta?.sprite_anim_shiny ?? null) as string | null;
const hasShiny           = !!spriteShinyUrl;
const hasAnim            = !!spriteAnimUrl;
const hasAnimShiny       = !!spriteAnimShinyUrl;

// Base
const types        = (meta?.types ?? []) as string[];
const stats        = (meta?.stats ?? {}) as Record<string, number>;
const trainerCount = trainers.length;

// Données espèce
const descFr         = (meta?.description_fr ?? '') as string;
const descsByGame    = (meta?.descriptions_fr ?? {}) as Record<string, string>;
const categoryFr     = (meta?.category_fr ?? '') as string;
const categoryI18n   = { fr: categoryFr, en: meta?.category_en ?? categoryFr, de: meta?.category_de ?? categoryFr, es: meta?.category_es ?? categoryFr, ja: meta?.category_ja ?? categoryFr, it: meta?.category_it ?? categoryFr, ko: meta?.category_ko ?? categoryFr, 'zh-Hans': meta?.category_zh ?? categoryFr, 'zh-Hant': meta?.category_zh_hant ?? categoryFr, 'pt-BR': meta?.category_pt ?? categoryFr } as Record<string,string>;
const generation     = (meta?.generation ?? '') as string;
const captureRate    = meta?.capture_rate as number | null ?? null;
const isLegendary    = meta?.is_legendary ?? false;
const isMythical     = meta?.is_mythical ?? false;
const evolvesFrom    = (meta?.evolves_from ?? null) as string | null;
const evolvesTo      = (meta?.evolves_to ?? []) as string[];
const abilities      = (meta?.abilities ?? []) as {name_fr:string; desc_fr:string; name_en?:string; desc_en?:string; name_de?:string; desc_de?:string; name_es?:string; desc_es?:string; name_ja?:string; desc_ja?:string; name_it?:string; desc_it?:string; name_ko?:string; desc_ko?:string; 'name_zh-Hans'?:string; 'desc_zh-Hans'?:string; is_hidden:boolean}[];

// i18n — descriptions + noms par langue (injectés en JSON pour le switch JS)
const descriptionsI18n = {
  fr:         meta?.descriptions_fr      ?? {},
  en:         meta?.descriptions_en      ?? {},
  de:         meta?.descriptions_de      ?? {},
  es:         meta?.descriptions_es      ?? {},
  ja:         meta?.descriptions_ja      ?? {},
  it:         meta?.descriptions_it      ?? {},
  ko:         meta?.descriptions_ko      ?? {},
  'zh-Hans':  meta?.descriptions_zh      ?? {},
  'zh-Hant':  meta?.descriptions_zh_hant ?? {},
  'pt-BR':    meta?.descriptions_pt      ?? {},
} as Record<string, Record<string, string>>;

const namesI18n = {
  fr:         pokemonName,
  en:         (meta?.names_intl as any)?.en           ?? pokemonName,
  de:         (meta?.names_intl as any)?.de           ?? pokemonName,
  es:         (meta?.names_intl as any)?.es           ?? pokemonName,
  ja:         (meta?.names_intl as any)?.ja           ?? pokemonName,
  it:         (meta?.names_intl as any)?.it           ?? pokemonName,
  ko:         (meta?.names_intl as any)?.ko           ?? pokemonName,
  'zh-Hans':  (meta?.names_intl as any)?.['zh-Hans']  ?? pokemonName,
  'zh-Hant':  (meta?.names_intl as any)?.['zh-Hant']  ?? pokemonName,
  'pt-BR':    (meta?.names_intl as any)?.['pt-BR']    ?? pokemonName,
} as Record<string, string>;
const genderFr       = meta?.gender_fr ?? null;   // "Asexué" ou number (% femelle)
const habitatFr      = (meta?.habitat_fr ?? null) as string | null;
const baseHappiness  = meta?.base_happiness as number | null ?? null;
const hatchCounter   = meta?.hatch_counter as number | null ?? null;
const hatchSteps     = hatchCounter !== null ? (hatchCounter + 1) * 255 : null;
const baseExperience = meta?.base_experience as number | null ?? null;
const heldItems      = (meta?.held_items ?? []) as {item:string; rarity:number|null}[];

// Résumé biologique
const hasBio = genderFr !== null || habitatFr || baseHappiness !== null || hatchSteps !== null;

function genderLabel(g: string | number | null): string {
  if (g === null) return '';
  if (g === 'Asexué') return '⚪ Asexué';
  const f = Number(g);
  if (f === 0)   return '♂ 100 %';
  if (f === 100) return '♀ 100 %';
  return `♂ ${100 - f} % / ♀ ${f} %`;
}

// Noms internationaux
const namesIntl = (meta?.names_intl ?? {}) as Record<string, string>;
const LANG_FLAGS: Record<string, string> = {
  en:'🇬🇧', de:'🇩🇪', es:'🇪🇸', it:'🇮🇹',
  ja:'🇯🇵', ko:'🇰🇷', 'zh-Hans':'🇨🇳', 'zh-Hant':'🇹🇼',
};
const LANG_LABEL: Record<string, string> = {
  en:'EN', de:'DE', es:'ES', it:'IT',
  ja:'JA', ko:'KO', 'zh-Hans':'ZH', 'zh-Hant':'ZH',
};
// Filtre ja-Hrkt (romanisation, redondant) et dédoublonne ZH
const namesDisplay = Object.entries(namesIntl)
  .filter(([l]) => l !== 'ja-Hrkt' && !(l === 'zh-Hant' && namesIntl['zh-Hans']));

// Map slug anglais → nom français (pour les liens d'évolution)
const slugToFr: Record<string, string> = {};
for (const [frName, d] of Object.entries(pokemonMeta as Record<string, any>)) {
  if (d?.slug) slugToFr[d.slug] = frName;
}
const evFromFr = evolvesFrom ? slugToFr[evolvesFrom] : null;
const evToFr   = evolvesTo.map(s => ({ slug: s, fr: slugToFr[s] ?? s }));

// ── Radar chart SVG (6 stats) ─────────────────────────────────
const STAT_ORDER = ['hp','attack','defense','speed','special-defense','special-attack'];
const STAT_LABELS: Record<string,string> = {
  'hp':'PV', 'attack':'Atk', 'defense':'Déf',
  'special-attack':'Att.Spé', 'special-defense':'Déf.Spé', 'speed':'Vit',
};
const RADAR_CX = 120, RADAR_CY = 128, RADAR_R = 84;
const TEXT_ANCHORS = ['middle','start','start','middle','end','end'];

function rpt(i: number, fraction: number) {
  const a = (Math.PI * 2 * i / 6) - Math.PI / 2;
  return [RADAR_CX + fraction * RADAR_R * Math.cos(a), RADAR_CY + fraction * RADAR_R * Math.sin(a)] as [number,number];
}
function hexPts(frac: number) {
  return Array.from({length:6},(_,i)=>rpt(i,frac)).map(([x,y])=>`${x.toFixed(1)},${y.toFixed(1)}`).join(' ');
}
const radarAxes  = Array.from({length:6},(_,i)=>rpt(i,1));
const radarPoly  = STAT_ORDER.map((s,i)=>rpt(i,(stats[s]??0)/255)).map(([x,y])=>`${x.toFixed(1)},${y.toFixed(1)}`).join(' ');
const radarLabels = STAT_ORDER.map((s,i)=>{
  const lr = RADAR_R * 1.26;
  const a  = (Math.PI*2*i/6) - Math.PI/2;
  return {
    label: STAT_LABELS[s]??s,
    val:   stats[s]??0,
    x:     (RADAR_CX + lr*Math.cos(a)).toFixed(1),
    y:     (RADAR_CY + lr*Math.sin(a)).toFixed(1),
    anchor: TEXT_ANCHORS[i],
  };
});
const hasStats = STAT_ORDER.some(s => stats[s]);

// Jeux où ce Pokémon apparaît
const gamesSet = new Set(trainers.map((t: any) => t.game));
const games = [...gamesSet];

// Classes qui l'utilisent le plus
const classCount: Record<string, number> = {};
for (const t of trainers) {
  classCount[t.class] = (classCount[t.class] ?? 0) + 1;
}
const topClasses = Object.entries(classCount)
  .sort((a, b) => b[1] - a[1]).slice(0, 5);

const RARITY_FR: Record<string, string> = {
  'Common':           'Commune',
  'Uncommon':         'Peu commune',
  'Rare':             'Rare',
  'Rare Holo':        'Rare Holo',
  'Rare Holo V':      'Rare Holo V',
  'Rare Holo VMAX':   'Rare Holo VMAX',
  'Rare Holo VSTAR':  'Rare Holo VSTAR',
  'Rare Holo GX':     'Rare Holo GX',
  'Rare Holo EX':     'Rare Holo EX',
  'Rare Ultra':       'Ultra Rare',
  'Rare Rainbow':     'Rainbow Rare',
  'Rare Secret':      'Secrète Rare',
  'Rare Shiny':       'Chromatique Rare',
  'Rare Shiny GX':    'Chromatique GX',
  'Amazing Rare':     'Incroyable Rare',
  'Promo':            'Promo',
  'LEGEND':           'Légende',
  'Illustration Rare':       'Rare Illustrée',
  'Special Illustration Rare': 'Rare Illustrée Spéciale',
  'Hyper Rare':       'Hyper Rare',
  'Double Rare':      'Double Rare',
  'ACE SPEC Rare':    'ACE SPEC Rare',
};

const TYPE_COLORS: Record<string, string> = {
  fire:'#f08030', water:'#6890f0', grass:'#78c850', electric:'#f8d030',
  ice:'#98d8d8', fighting:'#c03028', poison:'#a040a0', ground:'#e0c068',
  flying:'#a890f0', psychic:'#f85888', bug:'#a8b820', rock:'#b8a038',
  ghost:'#705898', dragon:'#7038f8', dark:'#705848', steel:'#b8b8d0',
  fairy:'#ee99ac', normal:'#a8a878',
};
const TYPE_FR: Record<string, string> = {
  fire:'Feu', water:'Eau', grass:'Plante', electric:'Électrik',
  ice:'Glace', fighting:'Combat', poison:'Poison', ground:'Sol',
  flying:'Vol', psychic:'Psy', bug:'Insecte', rock:'Roche',
  ghost:'Spectre', dragon:'Dragon', dark:'Ténèbres', steel:'Acier',
  fairy:'Fée', normal:'Normal',
};

const title       = `${pokemonName} — ${trainerCount} dresseur${trainerCount>1?'s':''} l'utilisent | PokéNom`;
const description = `${trainerCount} dresseurs Pokémon utilisent ${pokemonName} dans leur équipe${types.length ? ` (type ${types.map(t => TYPE_FR[t]??t).join('/')})` : ''}. Retrouvez-les tous sur PokéNom.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Thing",
  "name": pokemonName,
  "description": description,
  "url": `https://pokenom.fr/pokemon/${slug}`,
};
---

<Base
  title={title}
  description={description}
  canonical={`https://pokenom.fr/pokemon/${slug}`}
  ogImage={spriteUrl ?? '/og-default.png'}
  schema={schema}
>
  <main id="main" class="container">
    <!-- Données i18n injectées pour le switch JS côté client -->
    <!-- Placé ici (dans <body>) pour que <meta charset="UTF-8"> soit vu en premier -->
    <div id="pkm-i18n-data" style="display:none" aria-hidden="true" set:text={JSON.stringify({
      names:        namesI18n,
      categories:   categoryI18n,
      items:        Object.fromEntries(heldItems.map(h => [h.item, itemsI18n[h.item] ?? { fr: h.item, en: h.item, de: h.item, es: h.item, ja: h.item }])),
      descriptions: descriptionsI18n,
      abilities:    abilities.map(ab => ({
        is_hidden: ab.is_hidden,
        names: { fr: ab.name_fr, en: ab.name_en??ab.name_fr, de: ab.name_de??ab.name_fr, es: ab.name_es??ab.name_fr, ja: ab.name_ja??ab.name_fr, it: ab.name_it??ab.name_fr, ko: ab.name_ko??ab.name_fr, 'zh-Hans': (ab as any)['name_zh-Hans']??ab.name_fr, 'zh-Hant': (ab as any)['name_zh-Hant']??ab.name_fr, 'pt-BR': (ab as any)['name_pt-BR']??ab.name_fr },
        descs: { fr: ab.desc_fr, en: ab.desc_en??ab.desc_fr, de: ab.desc_de??ab.desc_fr, es: ab.desc_es??ab.desc_fr, ja: ab.desc_ja??ab.desc_fr, it: ab.desc_it??ab.desc_fr, ko: ab.desc_ko??ab.desc_fr, 'zh-Hans': (ab as any)['desc_zh-Hans']??ab.desc_fr, 'zh-Hant': (ab as any)['desc_zh-Hant']??ab.desc_fr, 'pt-BR': (ab as any)['desc_pt-BR']??ab.desc_fr },
      })),
    })} />
    <Breadcrumb crumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Pokémon', href: '/' },
      { label: pokemonName },
    ]} />

    <header class="pkm-header">
      <div class="pkm-header__visual">
        <div class="sprite-pair">
          {/* Sprite normal (ou animé via toggle) */}
          <div class="sprite-slot">
            {spriteUrl ? (
              <img
                id="pkm-sprite-img"
                src={spriteUrl}
                data-normal={spriteUrl}
                data-anim={spriteAnimUrl ?? ''}
                alt={`Illustration officielle de ${pokemonName}`}
                width="120" height="120"
                class="pkm-sprite"
                loading="eager"
              />
            ) : (
              <div class="pkm-sprite pkm-sprite--placeholder" aria-hidden="true"><span>?</span></div>
            )}
            <span class="sprite-label">Normal{hasAnim ? ' / Animé' : ''}</span>
            {hasAnim && (
              <button class="sprite-btn-anim" id="sprite-anim-btn" data-mode="normal" title="Basculer animé">▶</button>
            )}
          </div>
          {/* Sprite shiny */}
          {hasShiny && (
            <div class="sprite-slot">
              <img
                id="pkm-sprite-shiny-img"
                src={spriteShinyUrl!}
                data-normal={spriteShinyUrl}
                data-anim={spriteAnimShinyUrl ?? ''}
                alt={`Forme Shiny de ${pokemonName}`}
                width="120" height="120"
                class="pkm-sprite"
                loading="lazy"
              />
              <span class="sprite-label">✨ Shiny{hasAnimShiny ? ' / Animé' : ''}</span>
              {hasAnimShiny && (
                <button class="sprite-btn-anim" id="sprite-anim-shiny-btn" data-mode="normal" title="Basculer animé shiny">▶</button>
              )}
            </div>
          )}
        </div>
      </div>

      <div class="pkm-header__info">
        <div class="pkm-meta-row">
          {meta?.id && <p class="pkm-id">#{String(meta.id).padStart(3,'0')}</p>}
          {categoryFr && <p class="pkm-category" data-i18n="pkm-category">{categoryFr}</p>}
          {generation && <p class="pkm-gen">{generation}</p>}
          {isLegendary && <p class="pkm-badge pkm-badge--legendary">⭐ <span data-i18n-ui="legendary-badge">Légendaire</span></p>}
          {isMythical  && <p class="pkm-badge pkm-badge--mythical">✨ <span data-i18n-ui="mythical-badge">Mythique</span></p>}
        </div>
        <h1 data-i18n="pkm-name">{pokemonName}</h1>

        {/* Noms internationaux */}
        {namesDisplay.length > 0 && (
          <div class="names-intl">
            {namesDisplay.map(([lang, name]) => (
              <span class="name-intl" title={LANG_LABEL[lang]}>
                <span class="name-intl__flag">{LANG_FLAGS[lang] ?? '🌐'}</span>
                <span class="name-intl__val">{name}</span>
              </span>
            ))}
          </div>
        )}

        {types.length > 0 && (
          <div class="pkm-types">
            {types.map((type: string) => (
              <span
                class="type-badge"
                data-type={type}
                style={`background:${TYPE_COLORS[type] ?? '#888'}`}
              >
                <img src={`/assets/types/${type}.svg`} alt="" width="14" height="14" style="vertical-align:middle;margin-right:5px;filter:brightness(10)" />
                <span class="type-name">{TYPE_FR[type] ?? type}</span>
              </span>
            ))}
          </div>
        )}

        {descFr && <blockquote class="pkm-desc" data-i18n="pkm-desc">{descFr}</blockquote>}

        <p class="pkm-summary">
          <strong>{trainerCount} dresseur{trainerCount > 1 ? 's' : ''}</strong>
          {trainerCount > 1 ? ' utilisent ' : ' utilise '}
          {pokemonName} dans les jeux Pokémon officiels,
          dans {games.length} jeu{games.length > 1 ? 'x' : ''} différent{games.length > 1 ? 's' : ''}.
        </p>

        {/* Évolutions */}
        {(evFromFr || evToFr.length > 0) && (
          <div class="pkm-evolutions">
            {evFromFr && (
              <a href={`/pokemon/${toPokemonSlug(evFromFr)}`} class="evo-chip evo-chip--from">
                ← {evFromFr}
              </a>
            )}
            <span class="evo-current">{pokemonName}</span>
            {evToFr.map(e => (
              <a href={`/pokemon/${toPokemonSlug(e.fr)}`} class="evo-chip evo-chip--to">
                {e.fr} →
              </a>
            ))}
          </div>
        )}

        {hasStats && (
          <div class="radar-wrap">
            <svg viewBox="0 0 240 260" class="stat-radar" aria-label="Radar des statistiques">
              {[0.25, 0.5, 0.75, 1].map(f => (
                <polygon points={hexPts(f)} class={`radar-grid${f===1?' radar-grid--outer':''}`} />
              ))}
              {radarAxes.map(([x,y]) => (
                <line x1={RADAR_CX} y1={RADAR_CY} x2={x} y2={y} class="radar-axis" />
              ))}
              <polygon points={radarPoly} class="radar-fill" />
              {radarLabels.map(l => (
                <>
                  <text x={l.x} y={l.y} class="radar-lbl" text-anchor={l.anchor}>{l.label}</text>
                  <text x={l.x} y={String(Number(l.y)+12)} class="radar-val" text-anchor={l.anchor}>{l.val}</text>
                </>
              ))}
            </svg>
            {captureRate !== null && (
              <p class="radar-capture">
                <span data-i18n-ui="capture-rate">Taux de capture</span> : <strong>{captureRate}</strong>
                <span class="radar-capture__hint" data-i18n-difficulty={captureRate >= 200 ? 'very-easy' : captureRate >= 100 ? 'easy' : captureRate >= 45 ? 'normal' : captureRate >= 10 ? 'hard' : 'very-hard'}>
                  {captureRate >= 200 ? ' · très facile' : captureRate >= 100 ? ' · facile' : captureRate >= 45 ? ' · normal' : captureRate >= 10 ? ' · difficile' : ' · très difficile'}
                </span>
              </p>
            )}
          </div>
        )}
      </div>
    </header>

    <AdSlot slot="4657802019" format="auto" />

    <!-- Infos biologiques -->
    {hasBio && (
      <section class="bio-section">
        <h2 data-i18n-ui="bio">Informations</h2>
        <dl class="bio-grid">
          {genderFr !== null && (
            <><dt data-i18n-ui="gender">Genre</dt><dd>{genderLabel(genderFr)}</dd></>
          )}
          {habitatFr && (
            <><dt data-i18n-ui="habitat">Habitat</dt><dd>{habitatFr}</dd></>
          )}
          {baseHappiness !== null && (
            <><dt data-i18n-ui="base-happiness">Bonheur de base</dt><dd>{baseHappiness}/255</dd></>
          )}
          {hatchSteps !== null && (
            <><dt data-i18n-ui="hatch-steps">Éclosion</dt><dd>~{hatchSteps.toLocaleString('fr-FR')} pas</dd></>
          )}
          {baseExperience !== null && (
            <><dt data-i18n-ui="base-exp">Exp. de base</dt><dd>{baseExperience} XP</dd></>
          )}
          {heldItems.length > 0 && (
            <><dt data-i18n-ui="item-held">Objet tenu</dt>
            <dd id="pkm-held-items">
              {heldItems.map((h, i) => (
                <>
                  {i > 0 && ', '}
                  <a href={`/objet/${h.item}`} class="item-link" data-item-slug={h.item}>
                    {itemsI18n[h.item]?.fr ?? h.item.replace(/-/g,' ')}
                  </a>
                </>
              ))}
            </dd></>
          )}
        </dl>
      </section>
    )}

    <!-- Talents -->
    {abilities.length > 0 && (
      <section class="abilities-section">
        <h2 data-i18n-ui="abilities">Talents</h2>
        <div class="abilities-list">
          {abilities.map((ab, idx) => (
            <div class={`ability-card${ab.is_hidden ? ' ability-card--hidden' : ''}`} data-ability-idx={idx}>
              <div class="ability-card__header">
                <span class="ability-card__name" data-i18n={`ability-name-${idx}`}>{ab.name_fr}</span>
                {ab.is_hidden && <span class="ability-card__badge" data-i18n-ui="hidden-ability">Talent caché</span>}
              </div>
              {ab.desc_fr && <p class="ability-card__desc" data-i18n={`ability-desc-${idx}`}>{ab.desc_fr}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Descriptions Pokédex par jeu -->
    {Object.keys(descsByGame).length > 0 && (
      <section class="pokedex-section">
        <h2 data-i18n-ui="pokedex-entries">Entrées Pokédex</h2>
        <dl class="pokedex-list" id="pokedex-list">
          {sortPokedexEntries(Object.entries(descsByGame) as [string,string][]).map(([game, desc]) => {
            const letsGoFr = game === 'Pikachu' ? "Let's Go, Pikachu" : game === 'Évoli' ? "Let's Go, Évoli" : null;
            const displayLabel = letsGoFr ?? ('Pokémon ' + game);
            return <><dt data-game-label={game}>{displayLabel}</dt><dd data-game={game} data-i18n="pokedex-desc">{desc}</dd></>;
          })}
        </dl>
      </section>
    )}

    <!-- Dresseurs -->
    <section class="trainers-section">
      <h2><span data-i18n-ui="trainers-using">Dresseurs utilisant</span> <span data-i18n="pkm-name">{pokemonName}</span></h2>
      <p style="color:var(--text-soft);margin:8px 0 20px;font-size:0.9rem">
        {trainerCount} dresseur{trainerCount > 1 ? 's' : ''} dans la base
