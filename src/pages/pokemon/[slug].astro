</Base>

<script>
  // ── Toggle Animé ─────────────────────────────────────────────
  const img     = document.getElementById('pkm-sprite-img') as HTMLImageElement | null;
  const animBtn = document.getElementById('sprite-anim-btn') as HTMLButtonElement | null;

  if (img && animBtn) {
    const normalSrc = img.dataset.normal ?? '';
    const animSrc   = img.dataset.anim   ?? '';
    animBtn.addEventListener('click', () => {
      const isAnim = animBtn.dataset.mode === 'anim';
      img.style.opacity = '0';
      setTimeout(() => {
        if (isAnim) {
          img.src = normalSrc;
          img.style.imageRendering = 'pixelated';
          animBtn.dataset.mode = 'normal';
          animBtn.textContent = '▶';
          animBtn.title = 'Voir animé';
        } else {
          img.src = animSrc;
          img.style.imageRendering = 'auto';
          animBtn.dataset.mode = 'anim';
          animBtn.textContent = '⏹';
          animBtn.title = 'Voir normal';
        }
        img.style.opacity = '1';
      }, 120);
    });
  }

  // ── TCG show more ─────────────────────────────────────────────
  const moreBtn = document.getElementById('tcg-more-btn');
  const moreDiv = document.getElementById('tcg-more');
  moreBtn?.addEventListener('click', () => {
    if (moreDiv) (moreDiv as HTMLElement).style.display = 'grid';
    moreBtn.style.display = 'none';
  });

  // ── TCG card zoom modal ────────────────────────────────────────
  const modal        = document.getElementById('tcg-modal') as HTMLElement | null;
  const modalImg     = document.getElementById('tcg-modal-img') as HTMLImageElement | null;
  const modalCaption = document.getElementById('tcg-modal-caption') as HTMLElement | null;
  const modalClose   = modal?.querySelector('.tcg-modal__close') as HTMLElement | null;
  const modalBackdrop = modal?.querySelector('.tcg-modal__backdrop') as HTMLElement | null;

  function openModal(hires: string, caption: string) {
    if (!modal || !modalImg) return;
    modalImg.src = hires;
    if (modalCaption) modalCaption.textContent = caption;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
    if (modalImg) modalImg.src = '';
  }

  document.querySelectorAll<HTMLImageElement>('.tcg-card__img').forEach(img => {
    img.style.cursor = 'pointer';
    img.addEventListener('click', () => {
      const hires   = img.dataset.hires   ?? img.src;
      const caption = img.dataset.caption ?? img.alt;
      openModal(hires, caption);
    });
  });

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

<script>
// ── i18n — Détection locale + switch de contenu ────────────────
(function () {
  const raw = document.getElementById('pkm-i18n-data')?.textContent ?? '{}';
  const data = JSON.parse(raw) as {
    names:        Record<string, string>;
    categories:   Record<string, string>;
    items:        Record<string, Record<string, string>>;
    descriptions: Record<string, Record<string, string>>;
    abilities:    { is_hidden: boolean; names: Record<string,string>; descs: Record<string,string> }[];
  };

  // Maps de traduction des types par langue
  const TYPE_I18N: Record<string, Record<string, string>> = {
    fr: { fire:'Feu', water:'Eau', grass:'Plante', electric:'Électrik', ice:'Glace', fighting:'Combat', poison:'Poison', ground:'Sol', flying:'Vol', psychic:'Psy', bug:'Insecte', rock:'Roche', ghost:'Spectre', dragon:'Dragon', dark:'Ténèbres', steel:'Acier', fairy:'Fée', normal:'Normal' },
    en: { fire:'Fire', water:'Water', grass:'Grass', electric:'Electric', ice:'Ice', fighting:'Fighting', poison:'Poison', ground:'Ground', flying:'Flying', psychic:'Psychic', bug:'Bug', rock:'Rock', ghost:'Ghost', dragon:'Dragon', dark:'Dark', steel:'Steel', fairy:'Fairy', normal:'Normal' },
    de: { fire:'Feuer', water:'Wasser', grass:'Pflanze', electric:'Elektro', ice:'Eis', fighting:'Kampf', poison:'Gift', ground:'Boden', flying:'Flug', psychic:'Psycho', bug:'Käfer', rock:'Gestein', ghost:'Geist', dragon:'Drache', dark:'Unlicht', steel:'Stahl', fairy:'Fee', normal:'Normal' },
    es: { fire:'Fuego', water:'Agua', grass:'Planta', electric:'Eléctrico', ice:'Hielo', fighting:'Lucha', poison:'Veneno', ground:'Tierra', flying:'Volador', psychic:'Psíquico', bug:'Bicho', rock:'Roca', ghost:'Fantasma', dragon:'Dragón', dark:'Siniestro', steel:'Acero', fairy:'Hada', normal:'Normal' },
    ja: { fire:'ほのお', water:'みず', grass:'くさ', electric:'でんき', ice:'こおり', fighting:'かくとう', poison:'どく', ground:'じめん', flying:'ひこう', psychic:'エスパー', bug:'むし', rock:'いわ', ghost:'ゴースト', dragon:'ドラゴン', dark:'あく', steel:'はがね', fairy:'フェアリー', normal:'ノーマル' },
  };

  // Labels UI par langue
  const UI_I18N: Record<string, Record<string, string>> = {
    fr: {
      'abilities': 'Talents', 'hidden-ability': 'Talent caché', 'pokedex-entries': 'Entrées Pokédex',
      'bio': 'Informations', 'gender': 'Genre', 'habitat': 'Habitat',
      'base-happiness': 'Bonheur de base', 'hatch-steps': 'Éclosion', 'base-exp': 'Exp. de base',
      'capture-rate': 'Taux de capture', 'which-games': 'Dans quels jeux ?',
      'trainers-using': 'Dresseurs utilisant', 'who-uses': 'Qui utilise',
      'legendary-badge': 'Légendaire', 'mythical-badge': 'Mythique',
    },
    en: {
      'abilities': 'Abilities', 'hidden-ability': 'Hidden ability', 'pokedex-entries': 'Pokédex Entries',
      'bio': 'Info', 'gender': 'Gender', 'habitat': 'Habitat',
      'base-happiness': 'Base happiness', 'hatch-steps': 'Hatch time', 'base-exp': 'Base exp.',
      'capture-rate': 'Catch rate', 'which-games': 'In which games?',
      'trainers-using': 'Trainers using', 'who-uses': 'Who uses',
      'legendary-badge': 'Legendary', 'mythical-badge': 'Mythical',
    },
    de: {
      'abilities': 'Fähigkeiten', 'hidden-ability': 'Versteckte Fähigkeit', 'pokedex-entries': 'Pokédex-Einträge',
      'bio': 'Informationen', 'gender': 'Geschlecht', 'habitat': 'Lebensraum',
      'base-happiness': 'Grundfreundschaft', 'hatch-steps': 'Schritte bis Schlupf', 'base-exp': 'Basis-EP',
      'capture-rate': 'Fangrate', 'which-games': 'In welchen Spielen?',
      'trainers-using': 'Trainer, die nutzen', 'who-uses': 'Wer benutzt',
      'legendary-badge': 'Legendär', 'mythical-badge': 'Mysteriös',
    },
    es: {
      'abilities': 'Habilidades', 'hidden-ability': 'Habilidad oculta', 'pokedex-entries': 'Entradas de la Pokédex',
      'bio': 'Información', 'gender': 'Género', 'habitat': 'Hábitat',
      'base-happiness': 'Felicidad base', 'hatch-steps': 'Pasos de eclosión', 'base-exp': 'Exp. base',
      'capture-rate': 'Tasa de captura', 'which-games': '¿En qué juegos?',
      'trainers-using': 'Entrenadores que usan', 'who-uses': 'Quién usa',
      'legendary-badge': 'Legendario', 'mythical-badge': 'Mítico',
    },
    ja: {
      'abilities': '特性', 'hidden-ability': '隠れ特性', 'pokedex-entries': '図鑑の説明',
      'bio': '情報', 'gender': '性別', 'habitat': '生息地',
      'base-happiness': '基本なつき度', 'hatch-steps': '孵化歩数', 'base-exp': '基本経験値',
      'capture-rate': '捕捉率', 'which-games': 'どのゲームに？',
      'trainers-using': '使用トレーナー', 'who-uses': '誰が使う',
      'legendary-badge': '伝説', 'mythical-badge': '幻',
    },
  };

  // Détecte la meilleure langue disponible (localStorage > navigator.languages > fr)
  function detectLang(): string {
    const supported = ['fr', 'en', 'de', 'es', 'ja'];
    const saved = localStorage.getItem('pokenom_lang');
    if (saved && supported.includes(saved)) return saved;
    for (const l of navigator.languages ?? [navigator.language]) {
      const short = l.split('-')[0].toLowerCase();
      if (supported.includes(short)) return short;
    }
    return 'fr';
  }

  function applyLocale(lang: string) {
    // Nom du Pokémon
    document.querySelectorAll<HTMLElement>('[data-i18n="pkm-name"]').forEach(el => {
      el.textContent = data.names[lang] ?? data.names['fr'];
    });

    // Catégorie
    document.querySelectorAll<HTMLElement>('[data-i18n="pkm-category"]').forEach(el => {
      el.textContent = data.categories[lang] ?? data.categories['fr'];
    });

    // Description courte
    const descEl = document.querySelector<HTMLElement>('[data-i18n="pkm-desc"]');
    if (descEl) {
      const descs = data.descriptions[lang] ?? {};
      const games = Object.keys(descs);
      if (games.length) descEl.textContent = descs[games[games.length - 1]];
    }

    // Types
    document.querySelectorAll<HTMLElement>('[data-type]').forEach(el => {
      const type = el.dataset.type!;
      el.textContent = TYPE_I18N[lang]?.[type] ?? TYPE_I18N['fr'][type] ?? type;
    });

    // Capacités
    data.abilities.forEach((ab, idx) => {
      const nameEl = document.querySelector<HTMLElement>(`[data-i18n="ability-name-${idx}"]`);
      const descEl = document.querySelector<HTMLElement>(`[data-i18n="ability-desc-${idx}"]`);
      if (nameEl) nameEl.textContent = ab.names[lang] ?? ab.names['fr'];
      if (descEl) descEl.textContent = ab.descs[lang] ?? ab.descs['fr'];
    });

    // Descriptions Pokédex par jeu
    const allDescs = data.descriptions[lang] ?? {};
    document.querySelectorAll<HTMLElement>('[data-i18n="pokedex-desc"]').forEach(dd => {
      const game = dd.dataset.game!;
      if (allDescs[game]) dd.textContent = allDescs[game];
    });

    // Objets tenus
    const heldEl = document.getElementById('pkm-held-items');
    if (heldEl && Object.keys(data.items).length > 0) {
      const translated = Object.entries(data.items)
        .map(([, names]) => names[lang] ?? names['fr'])
        .join(', ');
      if (translated) heldEl.textContent = translated;
    }

    // Labels UI
    document.querySelectorAll<HTMLElement>('[data-i18n-ui]').forEach(el => {
      const key = el.dataset.i18nUi!;
      el.textContent = UI_I18N[lang]?.[key] ?? UI_I18N['fr'][key] ?? el.textContent;
    });
  }

  const lang = detectLang();
  if (lang !== 'fr') applyLocale(lang);
})();
</script>

