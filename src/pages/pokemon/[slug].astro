      <p id="tcg-modal-caption" class="tcg-modal__caption"></p>
    </div>
  </div>
</Base>

<script>
  // ── Toggle Animé (helper générique) ─────────────────────────
  function setupAnimToggle(imgId: string, btnId: string) {
    const img = document.getElementById(imgId) as HTMLImageElement | null;
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    if (!img || !btn) return;
    const normalSrc = img.dataset.normal ?? '';
    const animSrc   = img.dataset.anim   ?? '';
    if (!animSrc) return;
    btn.addEventListener('click', () => {
      const isAnim = btn.dataset.mode === 'anim';
      img.style.opacity = '0';
      setTimeout(() => {
        if (isAnim) {
          img.src = normalSrc;
          img.style.imageRendering = 'pixelated';
          btn.dataset.mode = 'normal';
          btn.textContent = '▶';
          btn.title = 'Voir animé';
        } else {
          img.src = animSrc;
          img.style.imageRendering = 'auto';
          btn.dataset.mode = 'anim';
          btn.textContent = '⏹';
          btn.title = 'Voir normal';
        }
        img.style.opacity = '1';
      }, 120);
    });
  }

  setupAnimToggle('pkm-sprite-img',       'sprite-anim-btn');
  setupAnimToggle('pkm-sprite-shiny-img', 'sprite-anim-shiny-btn');

  // ── TCG show more ─────────────────────────────────────────────
  const moreBtn = document.getElementById('tcg-more-btn');
  const moreDiv = document.getElementById('tcg-more');
  moreBtn?.addEventListener('click', () => {
    if (moreDiv) (moreDiv as HTMLElement).style.display = 'grid';
    moreBtn.style.display = 'none';
  });

  // ── TCG card zoom modal ────────────────────────────────────────
  const modal        = document.getElementById('tcg-modal') as HTMLElement | null;
  const modalImg     = document.getElementById('tcg-modal-img') as HTMLImageElement | null;
  const modalCaption = document.getElementById('tcg-modal-caption') as HTMLElement | null;
  const modalClose   = modal?.querySelector('.tcg-modal__close') as HTMLElement | null;
  const modalBackdrop = modal?.querySelector('.tcg-modal__backdrop') as HTMLElement | null;

  function openModal(hires: string, caption: string) {
    if (!modal || !modalImg) return;
    modalImg.src = hires;
    if (modalCaption) modalCaption.textContent = caption;
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal) return;
    modal.style.display = 'none';
    document.body.style.overflow = '';
    if (modalImg) modalImg.src = '';
  }

  document.querySelectorAll<HTMLImageElement>('.tcg-card__img').forEach(img => {
    img.style.cursor = 'pointer';
    img.addEventListener('click', () => {
      const hires   = img.dataset.hires   ?? img.src;
      const caption = img.dataset.caption ?? img.alt;
      openModal(hires, caption);
    });
  });

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

