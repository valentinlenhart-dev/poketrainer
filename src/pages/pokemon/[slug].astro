              Voir les {tcgCards.length - 8} autres cartes ↓
            </button>
          </>
        )}
      </section>
    )}

    <AdSlot slot="6779505269" format="auto" />
  </main>

  <!-- Modal zoom carte TCG -->
  <div id="tcg-modal" class="tcg-modal" aria-modal="true" role="dialog" aria-label="Carte agrandie" style="display:none">
