  // ── Traductions rareté TCG ────────────────────────────────────────
  const TCG_RARITY_I18N: Record<string, Record<string, string>> = {
    de: {'Common':'Häufig','Uncommon':'Ungewöhnlich','Rare':'Selten','Rare Holo':'Selten Holo','Rare Ultra':'Ultra Selten','Rare Rainbow':'Regenbogen Selten','Rare Secret':'Geheim Selten','Rare Shiny':'Chrom Selten','Promo':'Promo','LEGEND':'Legende'},
    es: {'Common':'Común','Uncommon':'Poco común','Rare':'Rara','Rare Holo':'Rara Holo','Rare Ultra':'Ultra Rara','Promo':'Promo'},
    it: {'Common':'Comune','Uncommon':'Non comune','Rare':'Rara','Rare Holo':'Rara Holo','Rare Ultra':'Ultra Rara','Promo':'Promo'},
    pt: {'Common':'Comum','Uncommon':'Incomum','Rare':'Rara','Rare Ultra':'Ultra Rara','Promo':'Promo'},
  };

  // Détecte la meilleure langue disponible (localStorage > navigator.languages > fr)
  function detectLang(): string {
    const supported = ['fr', 'en', 'de', 'es', 'ja', 'it', 'ko', 'zh-Hans', 'zh-Hant', 'pt-BR'];
    const saved = localStorage.getItem('pokenom_lang');
    if (saved && supported.includes(saved)) return saved;
    for (const l of navigator.languages ?? [navigator.language]) {
      // Chinois traditionnel : zh-Hant, zh-TW, zh-HK, zh-MO
      if (l.startsWith('zh-Hant') || l === 'zh-TW' || l === 'zh-HK' || l === 'zh-MO') return 'zh-Hant';
      // Chinois simplifié : zh-Hans, zh-CN, zh-SG
      if (l.startsWith('zh-Hans') || l === 'zh-CN' || l === 'zh-SG' || l === 'zh') return 'zh-Hans';
      // Portugais brésilien : pt-BR ou pt tout court
      if (l === 'pt-BR' || l === 'pt') return 'pt-BR';
      const short = l.split('-')[0].toLowerCase();
      if (supported.includes(short)) return short;
    }
    return 'fr';
  }

  function applyLocale(lang: string) {
    // Nom du Pokémon
    document.querySelectorAll<HTMLElement>('[data-i18n="pkm-name"]').forEach(el => {
      el.textContent = data.names[lang] ?? data.names['fr'];
    });

    // Catégorie
    document.querySelectorAll<HTMLElement>('[data-i18n="pkm-category"]').forEach(el => {
      el.textContent = data.categories[lang] ?? data.categories['fr'];
    });

    // Description courte
    const descEl = document.querySelector<HTMLElement>('[data-i18n="pkm-desc"]');
    if (descEl) {
      const descs = data.descriptions[lang] ?? {};
      const games = Object.keys(descs);
      if (games.length) descEl.textContent = descs[games[games.length - 1]];
    }

    // Types — on cible le <span class="type-name"> pour préserver l'<img>
    document.querySelectorAll<HTMLElement>('[data-type]').forEach(el => {
      const type = el.dataset.type!;
      const nameEl = el.querySelector<HTMLElement>('.type-name') ?? el;
      nameEl.textContent = TYPE_I18N[lang]?.[type] ?? TYPE_I18N['fr'][type] ?? type;
    });

    // Capacités
    data.abilities.forEach((ab, idx) => {
      const nameEl = document.querySelector<HTMLElement>(`[data-i18n="ability-name-${idx}"]`);
      const descEl = document.querySelector<HTMLElement>(`[data-i18n="ability-desc-${idx}"]`);
      if (nameEl) nameEl.textContent = ab.names[lang] ?? ab.names['fr'];
      if (descEl) descEl.textContent = ab.descs[lang] ?? ab.descs['fr'];
    });

    // Descriptions Pokédex par jeu
    const allDescs = data.descriptions[lang] ?? {};
    document.querySelectorAll<HTMLElement>('[data-i18n="pokedex-desc"]').forEach(dd => {
      const game = dd.dataset.game!;
      if (allDescs[game]) dd.textContent = allDescs[game];
    });

    // Objets tenus — on traduit le texte de chaque lien <a data-item-slug>
    const heldLinks = document.querySelectorAll<HTMLAnchorElement>('#pkm-held-items a[data-item-slug]');
    heldLinks.forEach(link => {
      const itemSlug = link.dataset.itemSlug!;
      const names = data.items[itemSlug];
      if (names) link.textContent = names[lang] ?? names['fr'] ?? link.textContent;
    });

    // Labels UI
    document.querySelectorAll<HTMLElement>('[data-i18n-ui]').forEach(el => {
      const key = el.dataset.i18nUi!;
      el.textContent = UI_I18N[lang]?.[key] ?? UI_I18N['fr'][key] ?? el.textContent;
    });

    // Pokédex dt labels — traduit + re-ajoute le prefix
    const letsGoKeys = new Set(['Pikachu', 'Évoli']);
    document.querySelectorAll<HTMLElement>('dt[data-game-label]').forEach(dt => {
      const frKey = dt.dataset.gameLabel!;
      const translated = VERSION_I18N[lang]?.[frKey] ?? frKey;
      dt.textContent = letsGoKeys.has(frKey)
        ? "Let's Go, " + translated
        : 'Pokémon ' + translated;
    });

    // Trainer cards — noms de jeux (data-game-fr)
    document.querySelectorAll<HTMLElement>('[data-game-fr]').forEach(el => {
      const gameFr = el.dataset.gameFr!;
      const translated = GAME_I18N[lang]?.[gameFr];
      if (translated) {
        const img = el.querySelector('img');
        el.textContent = translated;
        if (img) el.prepend(img);
      }
    });

    // TCG rarity labels
    document.querySelectorAll<HTMLElement>('[data-rarity-key]').forEach(el => {
      const key = el.dataset.rarityKey!;
      const translated = TCG_RARITY_I18N[lang]?.[key];
      if (translated) el.textContent = translated;
    });
  }

  const lang = detectLang();
  if (lang !== 'fr') applyLocale(lang);
})();
</script>

