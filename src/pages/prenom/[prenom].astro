---
import Base from '../../layouts/Base.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import trainersRaw from '../../data/trainers.json';
import { toPokemonSlug, placeLabel } from '../../utils/slug';
import { sortGamesByRelease, gameLabel, toGameSlug } from '../../utils/games';
import '../../styles/global.css';


export async function getStaticPaths() {
  const trainers = trainersRaw as any[];
  const bySlug = new Map<string, any[]>();

  for (const t of trainers) {
    const key = t.name_slug;
    if (!bySlug.has(key)) bySlug.set(key, []);
    bySlug.get(key)!.push(t);
  }

  return [...bySlug.entries()].map(([prenom, group]) => ({
    params: { prenom },
    props: { prenom, trainers: group },
  }));
}

const { prenom, trainers } = Astro.props as { prenom: string; trainers: any[] };

// Données de rareté (basées sur le 1er dresseur)
const first     = trainers[0];
const count     = trainers.length;
const displayName = first.name; // nom original avec accents

// Rareté
const rarityKey   = count === 1 ? 'legendaire' : count <= 3 ? 'rare' : count <= 10 ? 'repandu' : 'partout';
const rarityEmoji = count === 1 ? '🏆' : count <= 3 ? '💜' : count <= 10 ? '👀' : '🔥';
const rarityLabel = count === 1 ? 'Légendaire' : count <= 3 ? 'Rare' : count <= 10 ? 'Répandu' : 'Partout !';
const rarityDesc  = count === 1
  ? `Un seul dresseur légendaire dans tout l'univers Pokémon s'appelle ${displayName} !`
  : count <= 3
  ? `Ce prénom est assez rare — seulement ${count} dresseurs le portent.`
  : count <= 10
  ? `${count} dresseurs portent ce prénom dans les jeux Pokémon.`
  : `${count} dresseurs s'appellent ${displayName}, c'est l'un des prénoms les plus répandus !`;

// Pokémon utilisés par ces dresseurs (pour maillage + SEO)
const pokemonUsed = [...new Set(trainers.flatMap(t => t.team ?? []))];

// Jeux représentés — triés par ordre de sortie
const gamesUsed = sortGamesByRelease([...new Set(trainers.map(t => t.game))]);

// Meta
const title       = `${displayName} — Dresseur${count > 1 ? 's' : ''} Pokémon (${rarityLabel}) | Le Dresseur en Moi`;
const description = count === 1
  ? `Le dresseur ${first.class} ${displayName} est un dresseur Pokémon de ${first.game}. ${rarityDesc} Découvrez son équipe : ${(first.team ?? []).join(', ')}.`
  : `${count} dresseurs Pokémon s'appellent ${displayName}. ${rarityDesc} Retrouvez-les dans ${gamesUsed.slice(0,3).join(', ')}${gamesUsed.length > 3 ? '…' : ''}.`;

// Schema.org — ItemList + FAQ
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `Existe-t-il un dresseur Pokémon nommé ${displayName} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": count === 0
          ? `Non, aucun dresseur ne s'appelle ${displayName} dans les jeux Pokémon officiels.`
          : count === 1
          ? `Oui ! Le ${first.class} ${displayName} est le seul dresseur Pokémon à porter ce prénom. On le trouve dans ${first.game}, à ${first.place ? placeLabel(first.place) : 'un lieu mystérieux'}.`
          : `Oui ! ${count} dresseurs Pokémon s'appellent ${displayName}, dans ${gamesUsed.length} jeu${gamesUsed.length > 1 ? 'x' : ''} différent${gamesUsed.length > 1 ? 's' : ''}.`
      }
    },
    ...(count === 1 && (first.team ?? []).length > 0 ? [{
      "@type": "Question",
      "name": `Quel Pokémon utilise ${first.class} ${displayName} ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `${first.class} ${displayName} utilise ${first.team!.join(', ')} dans ${first.game}.`
      }
    }] : []),
    {
      "@type": "Question",
      "name": `Le prénom ${displayName} est-il rare dans Pokémon ?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": rarityDesc
      }
    },
  ]
};

const schemaList = count > 0 ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Dresseurs Pokémon nommés ${displayName}`,
  "numberOfItems": count,
  "itemListElement": trainers.map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Person",
      "name": `${t.class} ${t.name}`,
      "description": `Dresseur ${t.class} dans ${t.game}`,
      "url": `https://ledresseurenmoi.com/dresseur/${t.slug}`
    }
  }))
} : null;
---

<!-- ── i18n dynamique (rarityDesc, FAQ answers) ──────────────────── -->
<script define:vars={{ displayName, count, rarityKey, firstClass: first.class, firstGame: first.game, firstTeam: first.team ?? [] }}>
  function prenomRarityDesc(lang, displayName, count, rarityKey) {
    const n = count;
    const d = {
      legendaire: {
        fr: `Un seul dresseur légendaire dans tout l'univers Pokémon s'appelle ${displayName} !`,
        en: `Only one legendary trainer in the entire Pokémon universe is named ${displayName}!`,
        de: `Nur ein legendärer Trainer im gesamten Pokémon-Universum heißt ${displayName}!`,
        es: `¡Solo un entrenador legendario en todo el universo Pokémon se llama ${displayName}!`,
        ja: `ポケモン世界で${displayName}という名前の伝説のトレーナーはたった1人！`,
        it: `Solo un allenatore leggendario in tutto l'universo Pokémon si chiama ${displayName}!`,
        ko: `포켓몬 세계 전체에서 ${displayName}라는 이름의 전설적인 트레이너는 딱 한 명뿐!`,
        'zh-Hans': `整个宝可梦世界中只有一位传说级训练家叫${displayName}！`,
        'zh-Hant': `整個寶可夢世界中只有一位傳說級訓練家叫${displayName}！`,
        'pt-BR': `Apenas um treinador lendário em todo o universo Pokémon se chama ${displayName}!`,
      },
      rare: {
        fr: `Ce prénom est assez rare — seulement ${n} dresseurs le portent.`,
        en: `This name is quite rare — only ${n} trainers have it.`,
        de: `Dieser Name ist ziemlich selten — nur ${n} Trainer tragen ihn.`,
        es: `Este nombre es bastante raro — solo ${n} entrenadores lo tienen.`,
        ja: `この名前はかなり珍しい — ${n}人のトレーナーしかいない。`,
        it: `Questo nome è piuttosto raro — solo ${n} allenatori lo portano.`,
        ko: `이 이름은 꽤 희귀 — ${n}명의 트레이너만 갖고 있습니다.`,
        'zh-Hans': `这个名字相当罕见 — 只有${n}位训练家拥有。`,
        'zh-Hant': `這個名字相當罕見 — 只有${n}位訓練家擁有。`,
        'pt-BR': `Este nome é bem raro — apenas ${n} treinadores o têm.`,
      },
      repandu: {
        fr: `${n} dresseurs portent ce prénom dans les jeux Pokémon.`,
        en: `${n} trainers have this name in the Pokémon games.`,
        de: `${n} Trainer tragen diesen Namen in den Pokémon-Spielen.`,
        es: `${n} entrenadores tienen este nombre en los juegos Pokémon.`,
        ja: `ポケモンゲームで${n}人のトレーナーがこの名前を持っています。`,
        it: `${n} allenatori hanno questo nome nei giochi Pokémon.`,
        ko: `포켓몬 게임에서 ${n}명의 트레이너가 이 이름을 가지고 있습니다.`,
        'zh-Hans': `宝可梦游戏中有${n}位训练家拥有这个名字。`,
        'zh-Hant': `寶可夢遊戲中有${n}位訓練家擁有這個名字。`,
        'pt-BR': `${n} treinadores têm este nome nos jogos Pokémon.`,
      },
      partout: {
        fr: `${n} dresseurs s'appellent ${displayName}, c'est l'un des prénoms les plus répandus !`,
        en: `${n} trainers are named ${displayName} — one of the most common names!`,
        de: `${n} Trainer heißen ${displayName} — einer der häufigsten Namen!`,
        es: `${n} entrenadores se llaman ${displayName} — ¡uno de los nombres más comunes!`,
        ja: `${n}人のトレーナーが${displayName}という名前 — 最もよくある名前の一つ！`,
        it: `${n} allenatori si chiamano ${displayName} — uno dei nomi più diffusi!`,
        ko: `${n}명의 트레이너가 ${displayName}이라는 이름 — 가장 흔한 이름 중 하나!`,
        'zh-Hans': `${n}位训练家叫${displayName}，是最常见的名字之一！`,
        'zh-Hant': `${n}位訓練家叫${displayName}，是最常見的名字之一！`,
        'pt-BR': `${n} treinadores se chamam ${displayName} — um dos nomes mais comuns!`,
      },
    };
    return d[rarityKey]?.[lang] ?? d[rarityKey]?.['fr'] ?? '';
  }

  function prenomFaqExistsA(lang, displayName, count, firstClass, firstGame) {
    if (count === 1) {
      const m = {
        fr: `Oui ! Le ${firstClass} ${displayName} est le seul dresseur Pokémon à porter ce prénom — c'est un prénom légendaire. On le trouve dans ${firstGame}.`,
        en: `Yes! ${firstClass} ${displayName} is the only Pokémon Trainer with this name — a legendary name. Found in ${firstGame}.`,
        de: `Ja! ${firstClass} ${displayName} ist der einzige Pokémon-Trainer mit diesem Namen — ein legendärer Name. Zu finden in ${firstGame}.`,
        es: `¡Sí! ${firstClass} ${displayName} es el único Entrenador Pokémon con este nombre — un nombre legendario. Se encuentra en ${firstGame}.`,
        ja: `はい！${firstClass} ${displayName}はこの名前を持つ唯一のポケモントレーナー — 伝説の名前。${firstGame}に登場。`,
        it: `Sì! ${firstClass} ${displayName} è l'unico Allenatore Pokémon con questo nome — un nome leggendario. Si trova in ${firstGame}.`,
        ko: `네! ${firstClass} ${displayName}은(는) 이 이름을 가진 유일한 포켓몬 트레이너 — 전설의 이름. ${firstGame}에 등장.`,
        'zh-Hans': `是的！${firstClass} ${displayName}是唯一拥有此名字的宝可梦训练家——一个传奇名字。出现在${firstGame}。`,
        'zh-Hant': `是的！${firstClass} ${displayName}是唯一擁有此名字的寶可夢訓練家——一個傳奇名字。出現在${firstGame}。`,
        'pt-BR': `Sim! ${firstClass} ${displayName} é o único Treinador Pokémon com este nome — um nome lendário. Encontrado em ${firstGame}.`,
      };
      return m[lang] ?? m['fr'];
    } else {
      const m = {
        fr: `Oui ! ${count} dresseurs s'appellent ${displayName} dans les jeux Pokémon officiels.`,
        en: `Yes! ${count} trainers are named ${displayName} in the official Pokémon games.`,
        de: `Ja! ${count} Trainer heißen ${displayName} in den offiziellen Pokémon-Spielen.`,
        es: `¡Sí! ${count} entrenadores se llaman ${displayName} en los juegos Pokémon oficiales.`,
        ja: `はい！公式ポケモンゲームで${count}人のトレーナーが${displayName}という名前です。`,
        it: `Sì! ${count} allenatori si chiamano ${displayName} nei giochi Pokémon ufficiali.`,
        ko: `네! 공식 포켓몬 게임에서 ${count}명의 트레이너가 ${displayName}라는 이름입니다.`,
        'zh-Hans': `是的！在官方宝可梦游戏中有${count}位训练家叫${displayName}。`,
        'zh-Hant': `是的！在官方寶可夢遊戲中有${count}位訓練家叫${displayName}。`,
        'pt-BR': `Sim! ${count} treinadores se chamam ${displayName} nos jogos Pokémon oficiais.`,
      };
      return m[lang] ?? m['fr'];
    }
  }

  function prenomFaqTeamA(lang, firstClass, displayName, team, firstGame) {
    const teamStr = team.join(', ');
    const m = {
      fr: `${firstClass} ${displayName} utilise ${teamStr} dans ${firstGame}.`,
      en: `${firstClass} ${displayName} uses ${teamStr} in ${firstGame}.`,
      de: `${firstClass} ${displayName} nutzt ${teamStr} in ${firstGame}.`,
      es: `${firstClass} ${displayName} usa ${teamStr} en ${firstGame}.`,
      ja: `${firstClass} ${displayName}は${firstGame}で${teamStr}を使います。`,
      it: `${firstClass} ${displayName} usa ${teamStr} in ${firstGame}.`,
      ko: `${firstClass} ${displayName}은(는) ${firstGame}에서 ${teamStr}을(를) 사용합니다.`,
      'zh-Hans': `${firstClass} ${displayName}在${firstGame}中使用${teamStr}。`,
      'zh-Hant': `${firstClass} ${displayName}在${firstGame}中使用${teamStr}。`,
      'pt-BR': `${firstClass} ${displayName} usa ${teamStr} em ${firstGame}.`,
    };
    return m[lang] ?? m['fr'];
  }

  // Build the i18n payload for all languages
  const SUPPORTED_LANGS = ['fr','en','de','es','ja','it','ko','zh-Hans','zh-Hant','pt-BR'];
  const prenomI18n = {};
  for (const lang of SUPPORTED_LANGS) {
    prenomI18n[lang] = {
      rarityDesc: prenomRarityDesc(lang, displayName, count, rarityKey),
      faqExistsA: prenomFaqExistsA(lang, displayName, count, firstClass, firstGame),
      faqTeamA:   firstTeam.length > 0 ? prenomFaqTeamA(lang, firstClass, displayName, firstTeam, firstGame) : null,
    };
  }
  window.__prenom_i18n = prenomI18n;
</script>

<Base
  title={title}
  description={description}
  canonical={`https://ledresseurenmoi.com/prenom/${prenom}`}
  schema={[schemaFAQ, ...(schemaList ? [schemaList] : [])]}
>
  <main id="main" class="container">
    <span id="page-title-i18n" style="display:none" data-name-fr={displayName} data-suffix-key="title.suffix.prenom" />
    <Breadcrumb crumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Prénoms', href: '/' },
      { label: displayName },
    ]} />

    <!-- En-tête -->
    <header class="prenom-header">
      <div class="prenom-header__badge">
        <span class={`rarity rarity--${rarityKey}`} data-i18n-rarity={rarityKey}>
          <img src={`/assets/rarity/${rarityKey}.svg`} alt="" width="14" height="14" style="vertical-align:middle;margin-right:4px;" /> {rarityLabel}
        </span>
      </div>
      <h1>{displayName}</h1>
      <p class="prenom-header__desc" id="prenom-rarity-desc">{rarityDesc}</p>
    </header>

    <!-- Pub leaderboard — après le titre, avant les résultats -->
    <AdSlot slot="9030340068" format="auto" />

    <!-- Résultats -->
    {count === 0 ? (
      <div class="empty-state">
        <p class="empty-state__emoji">✨</p>
        <h2>Prénom introuvable</h2>
        <p>Aucun dresseur ne s'appelle <strong>{displayName}</strong> dans notre base.<br />
           C'est littéralement unique au monde Pokémon !</p>
        <a href="/" class="btn-red" style="margin-top:24px">Chercher un autre prénom</a>
      </div>
    ) : (
      <>
        <!-- Filtre par jeu (affiché seulement si plusieurs jeux) -->
        {gamesUsed.length > 1 && (
          <div class="game-filter" id="game-filter">
            <button class="game-filter__btn game-filter__btn--active" data-filter="all" data-i18n-ui="prenom.filter-all" data-count={count}>
              Tous ({count})
            </button>
            {gamesUsed.map(g => {
              const gs = toGameSlug(g);
              const cnt = trainers.filter(t => t.game === g).length;
              return (
                <button class="game-filter__btn" data-filter={gs} data-game-fr={g} data-count={cnt}>
                  {gameLabel(g)} ({cnt})
                </button>
              );
            })}
          </div>
        )}

        <section aria-label={`${count} dresseur${count>1?'s':''} nommé${count>1?'s':''} ${displayName}`}>
          <div class="cards-grid" id="trainers-grid">
            {trainers.map(t => (
              <div class="trainer-filter-item" data-game={t.game_slug}>
                <TrainerCard trainer={t} headingLevel="h2" />
              </div>
            ))}
          </div>
          <p class="filter-empty" id="filter-empty" style="display:none" data-i18n-ui="prenom.filter-empty">
            Aucun dresseur dans ce jeu.
          </p>
          {count > 3 && (
            <AdSlot slot="6404176727" format="fluid" layout="in-article" />
          )}
        </section>

        <!-- Pokémon utilisés — maillage interne -->
        {pokemonUsed.length > 0 && (
          <section class="related-section">
            <h2 data-i18n-ui="prenom.pokemon-of" data-trainer-name={displayName}>Pokémon de {displayName}</h2>
            <p style="color:var(--text-soft);margin:8px 0 16px;font-size:0.9rem" data-i18n-ui="prenom.team-used">
              Les Pokémon que ces dresseurs utilisent dans leurs équipes.
            </p>
            <div class="related-chips">
              {pokemonUsed.map(p => (
                <a
                  href={`/pokemon/${toPokemonSlug(p)}`}
                  class="pkm-link"
                >
                  {p}
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- FAQ visible pour SEO -->
        <section class="faq-section" aria-label="Questions fréquentes">
          <h2 data-i18n-ui="prenom.faq-title" data-trainer-name={displayName}>Questions fréquentes sur {displayName}</h2>
          <dl class="faq-list">
            <div class="faq-item">
              <dt data-i18n-ui="prenom.exists-q" data-trainer-name={displayName}>Existe-t-il un dresseur Pokémon nommé {displayName} ?</dt>
              <dd id="prenom-faq-exists-a">
                {count === 1
                  ? `Oui ! Le ${first.class} ${displayName} est le seul dresseur Pokémon à porter ce prénom — c'est un prénom légendaire. On le trouve dans ${first.game}.`
                  : `Oui ! ${count} dresseurs s'appellent ${displayName} dans les jeux Pokémon officiels.`
                }
              </dd>
            </div>
            <div class="faq-item">
              <dt data-i18n-ui="prenom.rare-q" data-trainer-name={displayName}>Le prénom {displayName} est-il rare dans Pokémon ?</dt>
              <dd id="prenom-faq-rare-a">{rarityDesc}</dd>
            </div>
            {count === 1 && first.team && first.team.length > 0 && (
              <div class="faq-item">
                <dt data-i18n-ui="prenom.team-q" data-trainer-name={displayName}>Quelle est l'équipe du dresseur {displayName} ?</dt>
                <dd id="prenom-faq-team-a">{first.class} {displayName} utilise {first.team.join(', ')} dans {first.game}.</dd>
              </div>
            )}
          </dl>
        </section>

        <!-- Maillage jeux -->
        {gamesUsed.length > 0 && (
          <section class="related-section">
            <h2 data-i18n-ui="which-games">Dans quels jeux ?</h2>
            <div class="related-chips">
              {gamesUsed.map(g => {
                const gs = g.replace('Pokémon ','').toLowerCase()
                  .normalize('NFD').replace(/[̀-ͯ]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'');
                return <a href={`/jeu/${gs}`} class="pkm-link" data-game-fr={g}>{g.replace('Pokémon ','')}</a>;
              })}
            </div>
          </section>
        )}

        <!-- Pub bas de page -->
        <AdSlot slot="2844205661" format="auto" />
      </>
    )}
  </main>
</Base>

<script>
  const filterBtns  = document.querySelectorAll<HTMLButtonElement>('.game-filter__btn');
  const items       = document.querySelectorAll<HTMLElement>('.trainer-filter-item');
  const emptyMsg    = document.getElementById('filter-empty') as HTMLElement | null;

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';

      // Active state
      filterBtns.forEach(b => b.classList.toggle('game-filter__btn--active', b === btn));

      // Show/hide items
      let visible = 0;
      items.forEach(item => {
        const show = filter === 'all' || item.dataset.game === filter;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (emptyMsg) emptyMsg.style.display = visible === 0 ? '' : 'none';
    });
  });
