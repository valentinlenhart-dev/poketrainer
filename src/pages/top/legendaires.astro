---
import Base from '../../layouts/Base.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import trainersRaw from '../../data/trainers.json';
import '../../styles/global.css';

const trainers = trainersRaw as any[];

// Utilise rarity_key généré par build-data.py (plus fiable que recompter)
const legendaires = trainers.filter(t => t.rarity_key === 'legendaire');
const count = legendaires.length;

const title = `${count} prénoms légendaires Pokémon — uniques au monde | PokéNom`;
const description = `${count} dresseurs sont absolument uniques dans toute la saga Pokémon — aucun autre ne partage leur prénom. Découvrez ces champions introuvables.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Prénoms légendaires Pokémon",
  "description": description,
  "url": "https://pokenom.fr/top/legendaires",
  "numberOfItems": count,
  "itemListElement": legendaires.slice(0, 50).map((t, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Person",
      "name": `${t.class} ${t.name}`,
      "url": `https://pokenom.fr/dresseur/${t.slug}`
    }
  }))
};

// Divise en deux moitiés pour insérer une pub au milieu
const half = Math.ceil(legendaires.length / 2);
const firstHalf  = legendaires.slice(0, half);
const secondHalf = legendaires.slice(half);
---

<script define:vars={{ count, totalCount: trainers.length }}>
  const LEG_SUB = {
    en: `<strong>${count} trainers</strong> are the only ones in the entire Pokémon saga to carry their name. A unique name = legendary status.`,
    de: `<strong>${count} Trainer</strong> sind in der gesamten Pokémon-Saga die einzigen, die ihren Namen tragen. Ein einzigartiger Name = Legendenstatus.`,
    es: `<strong>${count} entrenadores</strong> son los únicos en toda la saga Pokémon que llevan su nombre. Un nombre único = un estatus legendario.`,
    ja: `ポケモンシリーズ全体で、<strong>${count}人のトレーナー</strong>だけが自分の名前を持つ唯一の存在です。ユニークな名前 = 伝説のステータス。`,
    it: `<strong>${count} allenatori</strong> sono gli unici in tutta la saga Pokémon a portare il loro nome. Un nome unico = uno status leggendario.`,
    ko: `<strong>${count}명의 트레이너</strong>만이 포켓몬 시리즈 전체에서 자신의 이름을 가진 유일한 존재입니다. 유일한 이름 = 전설의 지위.`,
    'zh-Hans': `<strong>${count}名训练家</strong>是整个宝可梦系列中唯一拥有自己名字的存在。独一无二的名字 = 传说地位。`,
    'zh-Hant': `<strong>${count}名訓練家</strong>是整個寶可夢系列中唯一擁有自己名字的存在。獨一無二的名字 = 傳說地位。`,
    'pt-BR': `<strong>${count} treinadores</strong> são os únicos em toda a saga Pokémon a carregar seu nome. Um nome único = status lendário.`,
  };
  window.__page_html_i18n = { 'leg-header-sub': LEG_SUB };
</script>

<Base
  title={title}
  description={description}
  canonical="https://pokenom.fr/top/legendaires"
  schema={schema}
>
  <main id="main" class="container">
    <Breadcrumb crumbs={[
      { label: 'Accueil', href: '/' },
      { label: 'Top prénoms', href: '/top/repandus' },
      { label: 'Légendaires' },
    ]} />

    <header class="top-header">
      <div class="top-header__label" data-i18n-ui="top.legendary-label">🏆 Exclusivité absolue</div>
      <h1 data-i18n-ui="top.legendary-title">Prénoms légendaires</h1>
      <p class="top-header__sub" id="leg-header-sub">
        <strong>{count} dresseurs</strong> sont les seuls au monde à porter leur prénom dans toute la saga Pokémon.
        Un prénom unique = un statut de légende.
      </p>
      <div class="top-header__stats">
        <div class="stat-chip">
          <span class="stat-chip__val">{count}</span>
          <span class="stat-chip__lbl" data-i18n-ui="top.stat-unique">prénoms uniques</span>
        </div>
        <div class="stat-chip">
          <span class="stat-chip__val">{trainers.length}</span>
          <span class="stat-chip__lbl" data-i18n-ui="top.stat-total">dresseurs au total</span>
        </div>
        <div class="stat-chip">
          <span class="stat-chip__val">{Math.round(count / trainers.length * 100)}%</span>
          <span class="stat-chip__lbl" data-i18n-ui="top.stat-pct-legendary">sont légendaires</span>
        </div>
      </div>
    </header>

    <AdSlot slot="4031116056" format="auto" />

    <!-- Première moitié -->
    <section aria-label="Dresseurs légendaires (1ère partie)">
      <div class="cards-grid" style="margin-top:24px">
        {firstHalf.map(t => <TrainerCard trainer={t} />)}
      </div>
    </section>

    <!-- Pub in-article au milieu de la liste -->
    <AdSlot slot="5330692227" format="fluid" layout="in-article" />

    <!-- Deuxième moitié -->
    <section aria-label="Dresseurs légendaires (2ème partie)">
      <div class="cards-grid">
        {secondHalf.map(t => <TrainerCard trainer={t} />)}
      </div>
    </section>

    <AdSlot slot="7956855567" format="auto" />

    <!-- Lien croisé -->
    <div class="crosslink">
      <a href="/top/repandus" class="crosslink__btn" data-i18n-ui="top.crosslink-repandus">
        🔥 Voir les prénoms les plus répandus →
      </a>
    </div>
  </main>
</Base>

<style>
.top-header {
  padding: 40px 0 32px;
  border-bottom: 1.5px solid var(--border);
  margin-bottom: 32px;
}
.top-header__label {
  font-size: 0.7rem; font-weight: 800; letter-spacing: 0.16em;
  text-transform: uppercase; color: var(--red); margin-bottom: 10px;
}
.top-header h1 { margin-bottom: 14px; }
.top-header__sub { color: var(--soft); font-size: 1.05rem; max-width: 560px; line-height: 1.65; }

.top-header__stats {
  display: flex; flex-wrap: wrap; gap: 12px; margin-top: 24px;
}
.stat-chip {
  display: flex; flex-direction: column; align-items: center;
  padding: 14px 24px; background: var(--cream);
  border: 1.5px solid var(--border); border-radius: var(--radius-sm);
  min-width: 110px;
}
.stat-chip__val { font-size: 1.6rem; font-weight: 800; color: var(--dark); line-height: 1; }
.stat-chip__lbl { font-size: 0.72rem; color: var(--soft); margin-top: 4px; text-align: center; }

.crosslink { margin: 48px 0 32px; text-align: center; }
.crosslink__btn {
  display: inline-block; padding: 14px 28px;
  background: var(--red); color: #fff;
  border-radius: var(--radius); font-weight: 700; font-size: 0.95rem;
  transition: background 0.15s; text-decoration: none;
}
.crosslink__btn:hover { background: var(--red-dark); }
</style>
