---
import Base from '../../layouts/Base.astro';
import TrainerCard from '../../components/TrainerCard.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import AdSlot from '../../components/AdSlot.astro';
import trainersRaw from '../../data/trainers.json';
import typeTrainersRaw from '../../data/type-trainers.json';
import '../../styles/global.css';
import I18nScript from '../../components/I18nScript.astro';

const typeTrainers = typeTrainersRaw as Record<string, string[]>;
const allTrainers  = trainersRaw as any[];

// Index slug → trainer
const bySlug = new Map<string, any>(allTrainers.map(t => [t.slug, t]));

const TYPE_FR: Record<string, string> = {
  fire:'Feu', water:'Eau', grass:'Plante', electric:'Électrik',
  ice:'Glace', fighting:'Combat', poison:'Poison', ground:'Sol',
  flying:'Vol', psychic:'Psy', bug:'Insecte', rock:'Roche',
  ghost:'Spectre', dragon:'Dragon', dark:'Ténèbres', steel:'Acier',
  fairy:'Fée', normal:'Normal',
};

const TYPE_EMOJI: Record<string, string> = {
  fire:'🔥', water:'💧', grass:'🌿', electric:'⚡',
  ice:'❄️', fighting:'🥊', poison:'☠️', ground:'🌍',
  flying:'🦋', psychic:'🔮', bug:'🐛', rock:'🪨',
  ghost:'👻', dragon:'🐉', dark:'🌑', steel:'⚙️',
  fairy:'✨', normal:'⭐',
};

export function getStaticPaths() {
  return Object.keys(typeTrainersRaw as Record<string, string[]>).map(type => ({
    params: { type },
  }));
}

const { type } = Astro.params as { type: string };
const typeFr = TYPE_FR[type] ?? type;
const typeEmoji = TYPE_EMOJI[type] ?? '⚪';
const slugs = typeTrainers[type] ?? [];
const trainers = slugs.map(s => bySlug.get(s)).filter(Boolean) as any[];
const count = trainers.length;

// Jeux représentés
const games = [...new Set(trainers.map((t: any) => t.game))] as string[];

const title = `Dresseurs ${typeFr} (${count}) — Pokémon de type ${typeFr} | PokéNom`;
const description = `${count} dresseurs Pokémon qui utilisent des Pokémon de type ${typeFr}. Découvrez leurs prénoms, équipes et jeux d'origine.`;
const canonical = `https://pokenom.fr/type/${type}`;
---

<Base title={title} description={description} canonical={canonical}>
  <main id="main" class="container">
    <Breadcrumb crumbs={[
      { label: 'Accueil', href: '/' },
      { label: `Type ${typeFr}` },
    ]} />

    <header class="page-header">
      <div class="type-badge"><img src={`/assets/types/${type}.svg`} alt="" width="22" height="22" style="vertical-align:middle;margin-right:6px;" /> Type</div>
      <h1 class={`type-title type-title--${type}`}>{typeFr}</h1>
      <p class="page-sub">{count} dresseurs utilisent des Pokémon de type {typeFr}</p>
    </header>

    <AdSlot slot="2896100570" format="auto" />

    <!-- Jeux représentés -->
    <section class="section-block">
      <h2>Jeux représentés</h2>
      <div class="related-chips">
        {games.map((g: string) => {
          const gs = trainers.find((t: any) => t.game === g)?.game_slug ?? '';
          return <a href={`/jeu/${gs}`} class="pkm-link" data-game-fr={g}>{g.replace('Pokémon ','')}</a>;
        })}
      </div>
    </section>

    <!-- Autres types (navigation inter-type) -->
    <section class="section-block">
      <h2 data-i18n-ui="related">Explorer par type</h2>
      <div class="type-nav">
        {Object.entries(TYPE_FR).map(([t, label]) => (
          <a
            href={`/type/${t}`}
            class={`type-chip type-chip--${t}${t === type ? ' type-chip--active' : ''}`}
            aria-current={t === type ? 'page' : undefined}
          >
            <img src={`/assets/types/${t}.svg`} alt="" width="16" height="16" style="vertical-align:middle;margin-right:5px;" /><span class="type-name" data-type={t}>{label}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Dresseurs -->
    <section class="section-block">
      <h2>Dresseurs avec des Pokémon de type {typeFr}</h2>
      <div class="cards-grid" style="margin-top:16px">
        {trainers.slice(0, 6).map((t: any) => <TrainerCard trainer={t} />)}
      </div>
      {count > 6 && (
        <>
          <AdSlot slot="6643773892" format="fluid" layout="in-article" />
          <div class="cards-grid" style="margin-top:16px">
            {trainers.slice(6, 30).map((t: any) => <TrainerCard trainer={t} />)}
          </div>
        </>
      )}
      {count > 30 && (
        <>
          <AdSlot slot="9395123375" format="auto" />
          <div class="cards-grid" style="margin-top:16px">
            {trainers.slice(30).map((t: any) => <TrainerCard trainer={t} />)}
          </div>
        </>
      )}
    </section>

  </main>
</Base>
<I18nScript />

<style>
.page-header { padding: 36px 0 28px; border-bottom: 1.5px solid var(--border); margin-bottom: 32px; }
.type-badge { font-size:0.7rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:var(--red); margin-bottom:8px; }
.type-title { font-size: clamp(2rem,5vw,3rem); font-weight:900; }
.page-sub { color:var(--text-soft); margin-top:8px; font-size:1rem; }
.section-block { margin: 32px 0; }
.section-block h2 { margin-bottom: 14px; }
.related-chips { display:flex; flex-wrap:wrap; gap:8px; }
.pkm-link { padding:6px 14px; background:var(--surface); border:1.5px solid var(--border); border-radius:999px; font-size:0.85rem; font-weight:500; color:var(--text-mid); transition:border-color 0.15s,color 0.15s; }
.pkm-link:hover { border-color:var(--red); color:var(--red); text-decoration:none; }

/* Type nav */
.type-nav { display:flex; flex-wrap:wrap; gap:8px; }
.type-chip {
  padding: 6px 14px;
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 600;
  text-decoration: none;
  border: 1.5px solid transparent;
  transition: opacity 0.15s, transform 0.1s;
  color: #fff;
}
.type-chip:hover { opacity:0.85; transform:translateY(-1px); text-decoration:none; }
.type-chip--active { box-shadow: 0 0 0 2px var(--text); }

/* Couleurs de types */
.type-chip--fire,.type-title--fire{color:#c05000}
.type-chip--fire{background:#f08030}
.type-chip--water,.type-title--water{color:#2060c0}
.type-chip--water{background:#6890f0}
.type-chip--grass,.type-title--grass{color:#207040}
.type-chip--grass{background:#78c850}
.type-chip--electric,.type-title--electric{color:#a08000}
.type-chip--electric{background:#f8d030}
.type-chip--ice,.type-title--ice{color:#208080}
.type-chip--ice{background:#98d8d8}
.type-chip--fighting,.type-title--fighting{color:#fff}
.type-chip--fighting{background:#c03028}
.type-chip--poison,.type-title--poison{color:#fff}
.type-chip--poison{background:#a040a0}
.type-chip--ground,.type-title--ground{color:#806020}
.type-chip--ground{background:#e0c068}
.type-chip--flying,.type-title--flying{color:#4060a0}
.type-chip--flying{background:#a890f0}
.type-chip--psychic,.type-title--psychic{color:#fff}
.type-chip--psychic{background:#f85888}
.type-chip--bug,.type-title--bug{color:#506010}
.type-chip--bug{background:#a8b820}
.type-chip--rock,.type-title--rock{color:#806030}
.type-chip--rock{background:#b8a038}
.type-chip--ghost,.type-title--ghost{color:#fff}
.type-chip--ghost{background:#705898}
.type-chip--dragon,.type-title--dragon{color:#fff}
.type-chip--dragon{background:#7038f8}
.type-chip--dark,.type-title--dark{color:#fff}
.type-chip--dark{background:#705848}
.type-chip--steel,.type-title--steel{color:#408080}
.type-chip--steel{background:#b8b8d0}
.type-chip--fairy,.type-title--fairy{color:#c04080}
.type-chip--fairy{background:#ee99ac}
.type-chip--normal,.type-title--normal{color:#707050}
.type-chip--normal{background:#a8a878}
</style>
